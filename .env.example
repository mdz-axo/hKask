# hKask MCP Server API Keys
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# GitHub — Personal Access Token (classic or fine-grained)
# Scopes needed: repo, read:org
HKASK_GITHUB_TOKEN=

# Financial Modeling Prep — API Key
# https://financialmodelingprep.com/developer/docs/
HKASK_FMP_API_KEY=

# Telnyx — API Key v2
# https://portal.telnyx.com/#/app/api-keys
HKASK_TELNYX_API_KEY=

# Fal.ai — API Key
# https://fal.ai/dashboard/keys
HKASK_FAL_API_KEY=

# RSS Reader — SQLite database path (optional, defaults to hkask-rss-reader.db)
HKASK_RSS_DB=

# OCAP — HMAC secret for capability tokens (optional, defaults to "hkask-ocap-dev")
HKASK_OCAP_SECRET=

# Keystore — OS keychain service name (optional, defaults to hkask-keystore)
HKASK_KEYSTORE_SERVICE=

# CNS — Variety deficit threshold for algedonic alerts (optional, defaults to 10)
HKASK_CNS_THRESHOLD=

# Git — Base path for repository operations (optional)
HKASK_GIT_BASE_PATH=

# Brave Search — API key for web search
# https://brave.com/search/api/
HKASK_BRAVE_API_KEY=

# Firecrawl — API key for web extract/browse (optional, degraded without it)
# https://www.firecrawl.dev/
HKASK_FIRECRAWL_API_KEY=

# Semantic Scholar — API key for academic search
# https://www.semanticscholar.org/product/api
HKASK_SEMANTIC_SCHOLAR_API_KEY=

# Scholar — SQLite database path (optional, defaults to hkask-scholar.db)
HKASK_SCHOLAR_DB=

# Web — Cache TTL in seconds (optional, defaults to 300)
HKASK_WEB_CACHE_TTL_SECS=

# Web — Cache max entries (optional, defaults to 50)
HKASK_WEB_CACHE_MAX_ENTRIES=
