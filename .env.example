# hKask Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Legend:
#   [REQUIRED]  System will not function without this
#   [OPTIONAL]  System degrades gracefully if absent
#   [DERIVED]   Can be derived from HKASK_MASTER_KEY via Argon2id + HKDF-SHA256

# =============================================================================
# Sovereignty & Security
# =============================================================================
# These secrets control encryption, signing, and capability verification.
# Setting HKASK_MASTER_KEY is the simplest path — all other secrets below
# can be derived from it. Without HKASK_MASTER_KEY, each secret must be
# set individually.

# Master key for secret derivation. All internal secrets (ACP, MCP, OCAP,
# capability) derive from this via Argon2id + HKDF-SHA256. This is the
# single most important env var for a working system.
# Consumed by: hkask-cli (bootstrap), hkask-keystore (resolve_secret_chain)
# [OPTIONAL] if individual secrets are set; [REQUIRED] for derived secrets
HKASK_MASTER_KEY=

# Database encryption passphrase. Used by ~10 MCP servers and the CLI
# for SQLCipher encryption. Required whenever a database path is set.
# Consumed by: hkask-storage, all MCP servers with DB paths, hkask-cli
# [OPTIONAL] if no persistent databases are used; [REQUIRED] with any HKASK_*_DB
HKASK_DB_PASSPHRASE=

# ACP (Agent Capability Protocol) HMAC signing secret.
# Used for inter-agent message authentication and token verification.
# Consumed by: hkask-agents (AcpRuntime), hkask-mcp-replicant (agent_loader)
# [DERIVED from HKASK_MASTER_KEY] or set directly. Legacy alias: HKASK_ACP_SECRET_KEY
HKASK_ACP_SECRET=

# Legacy alias for HKASK_ACP_SECRET (backward compatibility).
# [DERIVED from HKASK_MASTER_KEY] or set directly.
HKASK_ACP_SECRET_KEY=

# MCP dispatch and tool invocation signing key.
# Consumed by: hkask-mcp (dispatch, security gateway)
# [DERIVED from HKASK_MASTER_KEY] or set directly.
# Falls back to ACP secret if not set.
HKASK_MCP_SECRET=

# MCP transport security key (API authentication HMAC).
# Consumed by: hkask-mcp (security gateway)
# [DERIVED from HKASK_MASTER_KEY] or set directly.
HKASK_MCP_SECURITY_KEY=

# OCAP capability token signing key.
# Consumed by: hkask-mcp-ocap (HMAC for capability tokens)
# [REQUIRED] for ocap server; [DERIVED from HKASK_MASTER_KEY] or set directly
HKASK_OCAP_SECRET=

# Capability token signing key (used by SOAP/capability tokens).
# Consumed by: hkask-cli (serve), hkask-api (resolve_soap_capability_secret)
# [DERIVED from HKASK_MASTER_KEY] or set directly.
HKASK_CAPABILITY_KEY=

# Capability secret (alternative to HKASK_CAPABILITY_KEY for CLI serve).
# Consumed by: hkask-cli (serve)
# [OPTIONAL] — dev default "hkask-dev-capability-secret" used if absent
HKASK_CAPABILITY_SECRET=

# =============================================================================
# Agent Identity
# =============================================================================
# These control which agent persona runs and how the agent identifies itself.

# Replicant persona name. Used for WebID derivation (deterministic UUID
# from persona name) and as the display persona string.
# Consumed by: hkask-mcp (run_stdio_server WebID resolution), hkask-mcp-replicant
# [OPTIONAL] — default: "Curator"
HKASK_AGENT_PERSONA=

# Direct UUID override for agent identity (highest precedence).
# Consumed by: hkask-mcp (run_stdio_server WebID resolution)
# [OPTIONAL] — if set, overrides HKASK_AGENT_PERSONA for WebID derivation
HKASK_WEBID=

# Default LLM model for the replicant server and CLI chat.
# Consumed by: hkask-mcp-replicant, hkask-cli (chat)
# [OPTIONAL] — default: "deepseek-v4-pro"
HKASK_DEFAULT_MODEL=

# =============================================================================
# MCP Server API Keys
# =============================================================================
# Third-party service keys. Each is required only if the corresponding
# MCP server is enabled. Without the key, that server cannot start.

# GitHub — Personal Access Token (classic or fine-grained)
# Scopes needed: repo, read:org
# Consumed by: hkask-mcp-github, hkask-cli (git_archival)
# [REQUIRED] for github server
HKASK_GITHUB_TOKEN=

# Financial Modeling Prep — API Key
# https://financialmodelingprep.com/developer/docs/
# Consumed by: hkask-mcp-fmp
# [REQUIRED] for fmp server
HKASK_FMP_API_KEY=

# Telnyx — API Key v2
# https://portal.telnyx.com/#/app/api-keys
# Consumed by: hkask-mcp-telnyx
# [REQUIRED] for telnyx server
HKASK_TELNYX_API_KEY=

# Fal.ai — API Key
# https://fal.ai/dashboard/keys
# Consumed by: hkask-mcp-fal
# [REQUIRED] for fal server
HKASK_FAL_API_KEY=

# Brave Search — API key for web search
# https://brave.com/search/api/
# Consumed by: hkask-mcp-web
# [REQUIRED] if no other search provider key is set
HKASK_BRAVE_API_KEY=

# Firecrawl — API key for web extract/browse
# https://www.firecrawl.dev/
# Consumed by: hkask-mcp-web
# [OPTIONAL] — degraded operation without it
HKASK_FIRECRAWL_API_KEY=

# Tavily — API key for AI-optimized web search
# https://tavily.com/
# Consumed by: hkask-mcp-web
# [OPTIONAL] — at least one search provider required
HKASK_TAVILY_API_KEY=

# SerpAPI — API key for Google search results
# https://serpapi.com/
# Consumed by: hkask-mcp-web
# [OPTIONAL] — at least one search provider required
HKASK_SERPAPI_API_KEY=

# Exa — API key for neural/semantic web search
# https://exa.ai/
# Consumed by: hkask-mcp-web
# [OPTIONAL] — at least one search provider required
HKASK_EXA_API_KEY=

# Browserbase — API key for headless browser browsing
# https://www.browserbase.com/
# Consumed by: hkask-mcp-web
# [OPTIONAL]
HKASK_BROWSERBASE_API_KEY=

# =============================================================================
# Database Paths
# =============================================================================
# Each MCP server can use a persistent encrypted SQLite database.
# If the path env var is absent, the server uses an in-memory database.
# HKASK_DB_PASSPHRASE is required whenever a path is set.

# Generic database path. Used by condenser and agent_loader for
# episodic persistence and registry database access.
# Consumed by: hkask-mcp-condenser, hkask-mcp-replicant (agent_loader), hkask-cli (config)
# [OPTIONAL] — in-memory if absent
HKASK_DB_PATH=

# Per-agent memory database. Used for episodic and semantic memory storage.
# Consumed by: hkask-mcp-episodic, hkask-mcp-semantic, hkask-mcp-doc-knowledge
# [REQUIRED] for episodic/semantic servers
HKASK_MEMORY_DB=

# Spec server database path.
# Consumed by: hkask-mcp-spec
# [OPTIONAL] — in-memory if absent
HKASK_SPEC_DB_PATH=

# API server database path (consent records, escalation queue, standing sessions).
# Consumed by: hkask-api (ApiState), hkask-cli (ensemble)
# [OPTIONAL] — in-memory if absent
HKASK_API_DB=

# Goal server database path.
# Consumed by: hkask-mcp-goal
# [OPTIONAL] — in-memory if absent
HKASK_GOAL_DB=

# Registry database path.
# Consumed by: hkask-mcp-registry
# [OPTIONAL] — registry uses YAML files if absent
HKASK_REGISTRY_DB=

# RSS reader database path.
# Consumed by: hkask-mcp-rss-reader
# [OPTIONAL] — in-memory if absent
HKASK_RSS_DB=

# =============================================================================
# Infrastructure
# =============================================================================
# Paths, directories, and system-level configuration.

# Keystore vault directory. Stores encrypted secret entries as JSON.
# Consumed by: hkask-mcp-keystore
# [OPTIONAL] — default: ~/.hkask/keystore/
HKASK_KEYSTORE_DIR=

# OS keychain service name for hkask-keystore entries.
# Consumed by: hkask-mcp-keystore
# [OPTIONAL] — default: "hkask-mcp-keystore"
HKASK_KEYSTORE_SERVICE=

# CNS configuration file path (YAML). Contains set-points and curation thresholds.
# Consumed by: hkask-cns (cybernetics_loop), hkask-cli (curation_config)
# [OPTIONAL] — defaults are compiled in
HKASK_CNS_CONFIG=

# CNS variety deficit threshold for algedonic alerts.
# See also: HKASK_CNS_CONFIG for full set-point configuration.
# Consumed by: hkask-mcp-cns
# [OPTIONAL] — default: 100
HKASK_CNS_THRESHOLD=

# Embedding vector dimensionality for semantic memory.
# Consumed by: hkask-storage (embedding_dim)
# [OPTIONAL] — default: 768
HKASK_EMBEDDING_DIM=

# YAML registry discovery path for agent definitions.
# Consumed by: hkask-mcp-replicant (agent_loader), hkask-cli (config)
# [OPTIONAL] — default: "registry/bots"
HKASK_REGISTRY_PATH=

# Jinja2 template directory path.
# Consumed by: hkask-templates (registry, lexicon)
# [OPTIONAL] — default: "registry/templates"
HKASK_TEMPLATES_PATH=

# Russell inference binary path.
# Consumed by: hkask-cli (chat)
# [OPTIONAL] — default: "russell-acp-server"
HKASK_RUSSELL_BINARY=

# Git base path for repository operations.
# Consumed by: hkask-mcp-git
# [OPTIONAL]
HKASK_GIT_BASE_PATH=

# Content-addressed storage home directory.
# Each of the 7 snapshot repos (registry, memory, cns-audit, sovereignty,
# goals-specs, sessions, vault) gets its own subdirectory under this path.
# Blobs are stored as files named by BLAKE3 hex hash in a cas/ subdir.
# Snapshots are git commits enabling rollback and verification.
# Consumed by: hkask-mcp (GixCasAdapter), hkask-mcp-git, hkask-cli (kask git)
# [OPTIONAL] — default: ~/.hkask/repos/
HKASK_CAS_HOME=

# =============================================================================
# SOAP Model Configuration
# =============================================================================
# Used by the Russell SOAP inference pipeline (hkask-api).

# SOAP inference model name.
# Consumed by: hkask-api (soap_config)
# [OPTIONAL] — default: compiled-in model name
HKASK_SOAP_MODEL=

# SOAP inference temperature.
# Consumed by: hkask-api (soap_config)
# [OPTIONAL] — default: compiled-in temperature
HKASK_SOAP_TEMPERATURE=

# SOAP inference max output tokens.
# Consumed by: hkask-api (soap_config)
# [OPTIONAL] — default: compiled-in max_tokens
HKASK_SOAP_MAX_TOKENS=

# SOAP inference timeout in seconds.
# Consumed by: hkask-api (soap_config)
# [OPTIONAL] — default: compiled-in timeout
HKASK_SOAP_TIMEOUT_SECS=

# SOAP persona system prompt path (e.g., hkask-templates/personas/jack-nurse.md).
# Consumed by: hkask-api (soap_config)
# [OPTIONAL] — default: "hkask-templates/personas/jack-nurse.md"
HKASK_SOAP_PERSONA_PATH=

# =============================================================================
# Web Server Configuration
# =============================================================================

# Web server response cache TTL in seconds.
# Consumed by: hkask-mcp-web
# [OPTIONAL] — default: 300
HKASK_WEB_CACHE_TTL_SECS=

# Web server response cache max entries.
# Consumed by: hkask-mcp-web
# [OPTIONAL] — default: 50
HKASK_WEB_CACHE_MAX_ENTRIES=

# =============================================================================
# Debug / Dev
# =============================================================================
# These are for development and debugging. Not needed in production.

# Trace WebID attribution flag. When set to "1", full UUIDs are shown
# at TRACE log level instead of redacted display.
# Consumed by: hkask-types (id::WebID)
# [OPTIONAL]
HKASK_TRACE_WEBIDS=

# Okapi API base URL (non-HKASK prefix — used by inference port).
# Consumed by: hkask-mcp-replicant, hkask-templates (okapi_config), hkask-api, hkask-cli (ensemble)
# [OPTIONAL] — default: "http://127.0.0.1:11435"
OKAPI_BASE_URL=
