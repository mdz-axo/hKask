# =============================================================================
# hKask — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# Tiers: CORE (minimal) → STANDARD (recommended) → FULL (everything)
# Run `kask doctor` to validate your configuration.
# =============================================================================

# ─── TIER: CORE ─────────────────────────────────────────────────────────────
# Minimum to run hKask with inference. Fill these first.

# Inference Provider API Keys (at least ONE required)
# Provider prefix: DI/ (DeepInfra), FA/ (fal.ai), TG/ (Together), OR/ (OpenRouter), KC/ (KiloCode)
# See: docs/guides/provider-api-keys.md for setup instructions

# DeepInfra — $1.30/month free credits | https://deepinfra.com/
DI_API_KEY=

# fal.ai — pay-per-use, generous free tier | https://fal.ai/
FA_API_KEY=

# Together AI — $5 free credits | https://together.ai/
TG_API_KEY=

# OpenRouter — unified API for 200+ models | https://openrouter.ai/
OR_API_KEY=

# KiloCode (Kilo Gateway) — unified API for 500+ models, server-side auto-routing | https://kilo.ai/
KC_API_KEY=

# Default provider for unprefixed model names (DI, FA, TG, OR, KC)
HKASK_DEFAULT_PROVIDER=KC

# Default model (supports provider prefixes: DI/meta-llama/Llama-3.3-70B-Instruct)
HKASK_DEFAULT_MODEL=KC/z-ai/glm-5.2

# Default embedding model for vectorization (supports provider prefixes).
# Override: HKASK_EMBEDDING_MODEL env var.
# Default: DI/Qwen/Qwen3-Embedding-0.6B
#HKASK_EMBEDDING_MODEL=DI/Qwen/Qwen3-Embedding-0.6B

# Default onboarding thresholds (model discovery using OpenRouter API)
HKASK_OR_MAX_PRICE=1.0
HKASK_OR_MIN_INTELLIGENCE_INDEX=40.0



# ─── Fusion / Multi-Model Deliberation ───────────────────────────────────────
# Fusion is opt-in: uncomment and set these to enable multi-model deliberation.
# hKask orchestrates fusion itself — sends your prompt to all panel models
# in parallel, collects their responses, then has the judge synthesize.
# Each model can route through a different provider using its 2-letter prefix.
#
# ── Example: OpenRouter ──
#   HKASK_FUSION_JUDGE_MODEL=deepseek-v4-pro
#   HKASK_FUSION_PANEL_MODELS=Kimi2.7,Qwen3.7 Max,GLM5.2,Minimax3
#   (unprefixed names route through default provider)
#
# ── Example: KiloCode (KC/ prefix) ──
#   KC_API_KEY=sk-...
#   HKASK_FUSION_JUDGE_MODEL=KC/deepseek/deepseek-v4-pro
#   HKASK_FUSION_PANEL_MODELS=KC/moonshotai/kimi-k2.5,KC/z-ai/glm-5.1,KC/minimax/minimax-m2.7
#   (use kilo_list_models or https://kilo.ai/models to find exact model IDs)
#
# ── Example: Mixed providers ──
#   HKASK_FUSION_JUDGE_MODEL=DI/deepseek-v4-pro
#   HKASK_FUSION_PANEL_MODELS=OR/auto,KC/anthropic/claude-sonnet-4.5,DI/qwen/qwen3
#
# Recommended kask defaults (uses default provider for unprefixed names):
#   HKASK_FUSION_JUDGE_MODEL=deepseek-v4-pro
#   HKASK_FUSION_PANEL_MODELS=Kimi2.7,Qwen3.7 Max,GLM5.2,Minimax3
#
# To disable after enabling:
#   HKASK_FUSION_DISABLED=1
#   (or use /fusion off in the REPL)

# Judge model that synthesizes panel responses (supports provider prefix)
HKASK_FUSION_JUDGE_MODEL=KC/z-ai/glm-5.2

# Comma-separated panel models, 1-8 allowed (each supports provider prefix)
HKASK_FUSION_PANEL_MODELS=KC/z-ai/glm-5.2,KC/deepseek/deepseek-v4-pro,KC/minimax/minimax-m3,KC/moonshotai/kimi-k2.6

# Judge deliberation mode: synthesis | best-of-n | critique | deliberation | pi
HKASK_FUSION_MODE=synthesis

# Skills that anchor the judge's reasoning (comma-separated)
# Available: pragmatic-semantics, pragmatic-cybernetics, pragmatic-laziness,
#           coding-guidelines, deep-module, essentialist, constraint-forces,
#           superforecasting, mcda, tdd, rust-expertise
#HKASK_FUSION_SKILLS=pragmatic-semantics,pragmatic-cybernetics,pragmatic-laziness

# Max rounds for deliberation mode (default: 5)
#HKASK_FUSION_MAX_ROUNDS=5

# Set to 1 to disable fusion
HKASK_FUSION_DISABLED=0



# ─── Classifier Model (canonical) ───────────────────────────────────────────
# Classification uses a SINGLE canonical classifier model (below). Multi-model
# epistemic integrity is handled by the fusion orchestrator (judge: "algo"),
# which runs a panel in parallel and merges JSON outputs algorithmically (union,
# dedup, diverging fields annotated [A:... B:...]). Configure the panel via
# HKASK_FUSION_PANEL_MODELS above or the `fusion:` block in corpus.yaml /
# FlowDef manifests.
#
# Reference: OWASP LLM Top 10 (LLM09: Misinformation — multi-model panel merge
# mitigates single-model bias). See docs/how-to/fusion-mode.md.

# Primary classifier model (corpus pipeline + algo fusion panel)
# Override: HKASK_CLASSIFIER_MODEL env var
# Default: DI/Qwen/Qwen3-235B-A22B-Instruct-2507 (22B active MoE, DeepInfra)
#HKASK_CLASSIFIER_MODEL=DI/Qwen/Qwen3-235B-A22B-Instruct-2507

# Corpus pipeline multi-model: configure via fusion block in corpus.yaml
# Example fusion block:
#   fusion:
#     judge: algo
#     panel:
#       - DI/Qwen/Qwen3-235B-A22B-Instruct-2507
#       - DI/google/gemma-4-E4B-it



# ─── Content Safety Guard (hkask-guard) ──────────────────────────────────────
# Core scanners are ALWAYS active — not configurable off. Aligned with:
#   OWASP Top 10 for LLM Applications (owasp.org/www-project-top-10-for-llm)
#   - LLM01: Prompt Injection (BanSubstrings + Deobfuscate)
#   - LLM02: Insecure Output Handling (Secrets scanner, strips before storage)
#   - LLM04: Model Denial of Service (TokenLimit: configurable via HKASK_GUARD_TOKEN_LIMIT)
#   - LLM06: Sensitive Information Disclosure (Secrets scanner on output)
#
# Configure guard parameters:
#   HKASK_GUARD_TOKEN_LIMIT — max input tokens before model invocation (default: 32000)
#   HKASK_GUARD_VIOLATION_RATE_MAX — max fraction of requests blocked before Curator alert (default: 0.20)
#   Set lower for chat (8K-16K), higher for document processing (64K-128K)
#HKASK_GUARD_TOKEN_LIMIT=32000
#HKASK_GUARD_VIOLATION_RATE_MAX=0.20
#
# Optional scanners (not yet wired, available in llm-guard):
#   - LLM03: Training Data Poisoning (ScriptMix — Unicode look-alike detection)
#   - LLM08: Vector Weaknesses (InvisibleText — zero-width/bidi smuggling)



# ─── TIER: STANDARD ──────────────────────────────────────────────────────────
# Adds web search, financial data, adapter support, and database backups.

# --- Web Search Providers (at least ONE recommended) ---
# Brave Search API — free tier: 2,000 queries/month | https://brave.com/search/api/
HKASK_BRAVE_API_KEY=

# Firecrawl — web scraping + search | https://firecrawl.dev/
HKASK_FIRECRAWL_API_KEY=

# Tavily — AI-optimized search | https://tavily.com/
HKASK_TAVILY_API_KEY=

# SerpAPI — Google Search API | https://serpapi.com/
HKASK_SERPAPI_API_KEY=

# Exa — semantic search | https://exa.ai/
HKASK_EXA_API_KEY=

# Browserbase — headless browser for web browsing | https://browserbase.com/
HKASK_BROWSERBASE_API_KEY=

# Web cache configuration
HKASK_WEB_CACHE_TTL_SECS=3600
HKASK_WEB_CACHE_MAX_ENTRIES=1000



# --- Financial Data Providers ---
# Financial Modeling Prep — US company data | https://financialmodelingprep.com/
HKASK_FMP_API_KEY=

# EOD Historical Data — global markets data | https://eodhd.com/
HKASK_EODHD_API_KEY=



# --- Litestream: SQLite Continuous Backup to Object Storage ---
# Litestream is the canonical hKask persistence strategy. Used everywhere.
# Provides: sub-second RPO, cross-provider pod migration, disaster recovery.
# Backs up both kask.db and conduit.db.
# Compatible with any S3-protocol object storage. Choose one backend:
#
#   Backblaze B2    — cheapest, 10GB free, publish drive failure stats openly
#   Hetzner OS       — €5/TB/mo, EU data residency, same provider as K3s
#   Akamai/Linode OS — $5/250GB, S3-compatible, same provider as LKE
#   Cloudflare R2    — 10GB free, zero egress, global edge caching
#
# Backblaze B2 example:
#   LITESTREAM_ENDPOINT=https://s3.us-west-000.backblazeb2.com
#   LITESTREAM_REGION=us-west-000
#   LITESTREAM_FORCE_PATH_STYLE=true
#
# Hetzner Object Storage example:
#   LITESTREAM_ENDPOINT=https://nbg1.your-objectstorage.com
#   LITESTREAM_REGION=nbg1
#   LITESTREAM_FORCE_PATH_STYLE=true
#
# Akamai/Linode Object Storage example:
#   LITESTREAM_ENDPOINT=https://us-east-1.linodeobjects.com
#   LITESTREAM_REGION=us-east-1
#   LITESTREAM_FORCE_PATH_STYLE=false

# Your bucket name
LITESTREAM_BUCKET=hkask-pods-backup

# Object storage endpoint (set for your chosen backend)
LITESTREAM_ENDPOINT=

# Object storage region
LITESTREAM_REGION=auto

# Object storage credentials (B2: Application Key, Hetzner: Access Key, Linode: Access Key)
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# Set to "true" for Backblaze B2 / Hetzner (path-style); "false" for Linode / R2 (virtual hosted-style)
LITESTREAM_FORCE_PATH_STYLE=



# --- Adapter / Training Providers ---
# RunPod — GPU cloud for inference + training | https://runpod.io/
# Get your API key at: https://www.runpod.io/console/user/api
RUNPOD_API_KEY=

# RunPod serverless template ID for the OCR endpoint
# Create the template at: https://www.runpod.io/console/serverless
# See: deploy/runpod-ocr/README.md for full setup instructions
RUNPOD_TEMPLATE_ID=

# Baseten — model deployment platform | https://baseten.co/
BASETEN_API_KEY=

# HuggingFace — model/adapter repository access | https://huggingface.co/
HF_TOKEN=



# --- MCP Server Configuration ---
# The MCP servers below are started automatically by kask chat.
# Most use sensible defaults and need no configuration.
# The two below are the only ones that unlock additional functionality.

# DocProc OCR Model — required for scanned PDF extraction and OCR tools.
# Must be a vision-capable model available in your inference catalog.
# Default: DI/allenai/olmOCR-2-7B-1025 (via DeepInfra)
# Alternative: RP/olmocr-2-7b (via RunPod serverless — see deploy/runpod-ocr/)
# Without this, extract_text and ocr_document tools fail for scanned PDFs.
HKASK_OCR_MODEL=DI/allenai/olmOCR-2-7B-1025

# DocProc OCR concurrency — number of parallel OCR requests (default: 8)
# Must match the RunPod template's --parallel setting if using RP/ models.
#HKASK_OCR_CONCURRENCY=8

# Research RSS Database — enables RSS feed reading in hkask-mcp-research.
# Path to a SQLite database for RSS feed subscriptions and articles.
# Without this, RSS tools are unavailable (web search still works).
# HKASK_RSS_DB=/home/youruser/.local/share/hkask/rss.db

# Media Models — required for image generation, speech, and vision tools.
# These override the defaults when the media MCP server processes media.
# All support provider prefixes (DI/, FA/, etc.).
#
# TTS model: Qwen3-TTS (Apache 2.0).
# Default: FA/qwen-3-tts
#HKASK_MEDIA_TTS_MODEL=FA/qwen-3-tts
#
# STT model: fal.ai Wizper (optimized Whisper v3).
# Default: FA/wizper
#HKASK_MEDIA_STT_MODEL=FA/wizper
#
# Vision model: Qwen3-VL (Apache 2.0, via KiloCode).
# Default: KC/qwen/qwen3-vl-235b-a22b-instruct
#HKASK_MEDIA_VISION_MODEL=KC/qwen/qwen3-vl-235b-a22b-instruct
#
# Image generation: FLUX.2 [dev] by Black Forest Labs (open-source).
# Default: FA/flux-2
#HKASK_MEDIA_IMAGE_GEN_MODEL=FA/flux-2



# ─── TIER: FULL ───────────────────────────────────────────────────────────────
# Adds cloud deployment, Matrix federation, provider base URLs, and advanced config.

# --- Matrix / Cross-Pod Communication ---
# Matrix homeserver URL — set by the Curator during system install.
# Pod agent credentials are auto-generated by kask pod create.
HKASK_MATRIX_URL=http://localhost:8008
# Registration token for Conduit Matrix homeserver (default: hkask-dev)
HKASK_MATRIX_REGISTRATION_TOKEN=hkask-dev

# --- Email / SMTP (Curator + Replicant email delivery) ---
# MXroute SMTP settings — used by the Curator to send invites, notifications,
# and by replicants to send email on behalf of their human.
# Server hostname from MXroute Control Panel → Email Clients page.
# Port: 465 (SSL) or 587 (STARTTLS). Encryption: TLS.
HKASK_SMTP_HOST=
HKASK_SMTP_PORT=465
# MXroute email credentials (HTTP API at smtpapi.mxroute.com)
HKASK_MXROUTE_SERVER=
HKASK_SMTP_USERNAME=curator@replicant.partners
HKASK_SMTP_PASSWORD=AllostericReactionTime
# Domain for this hKask installation (used for email routing + Matrix federation)
HKASK_DOMAIN=replicant.partners
# From address for Curator-sent emails (invites, notifications, alerts)
HKASK_CURATOR_EMAIL=curator@replicant.partners

# --- Provider Base URLs (override defaults for self-hosted/custom endpoints) ---
# DI_BASE_URL=https://api.deepinfra.com
# FA_BASE_URL=https://api.fal.ai
# FA_MEDIA_BASE_URL=https://fal.run
# FA_QUEUE_BASE_URL=https://queue.fal.run
# TG_BASE_URL=https://api.together.xyz
# OR_BASE_URL=https://openrouter.ai/api
# KC_BASE_URL=https://api.kilo.ai/api/gateway

# --- Cloud Provider API Tokens ---
# Choose one. Hetzner is the primary recommendation. Akamai/Linode is a managed alternative.

# Hetzner Cloud — cost leader, self-managed K3s
# Create: Hetzner Console → Security → API Tokens → Read & Write
# Docs: https://docs.hetzner.cloud/
HCLOUD_TOKEN=

# Akamai Cloud (formerly Linode) — managed LKE or self-managed K3s
# Create: https://cloud.linode.com/profile/tokens → Create Personal Access Token
# Scopes needed: Linodes (Read/Write), Kubernetes (Read/Write), Object Storage (Read/Write)
# Docs: https://techdocs.akamai.com/cloud-computing/reference/api
# LKE (managed K8s): https://www.akamai.com/products/kubernetes
LINODE_TOKEN=

# --- Container Registry ---
# Docker/OCI registry for pushing the kask container image
# GitHub Container Registry: ghcr.io/your-org/hkask
# Docker Hub: docker.io/your-org/hkask
CONTAINER_REGISTRY=

# Registry credentials (if private)
CONTAINER_REGISTRY_USERNAME=
CONTAINER_REGISTRY_PASSWORD=

# Docker Hub — credentials for pushing/pulling container images
# Create an access token at: https://hub.docker.com/settings/security
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=



# ─── OPERATIONAL ──────────────────────────────────────────────────────────────
# Runtime configuration, paths, and storage.

# Base URL for this hKask installation (used for Matrix federation, API endpoints, TLS).
# In development: http://localhost:3000
HKASK_BASE_URL=http://localhost:3000

# Pod identity (auto-generated by kask pod create if not set)
POD_ID=

# Database provider — `sqlite` (default) or `postgres` (future).
# Set to `postgres` to use a PostgreSQL database instead of SQLite.
HKASK_DB_PROVIDER=sqlite

# Data directory for SQLite databases (default: data/ locally, /data in container)
HKASK_DATA_DIR=./data

# Primary database path (default: data/hkask.db relative to working directory)
# HKASK_DB_PATH=data/hkask.db

# Per-agent memory database path (default: agents/{name}/memory.db)
# HKASK_MEMORY_DB_PATH=

# Episodic memory retention in days (default: 90)
# HKASK_MEMORY_LIFE_DAYS=90

# Template cache path for Jinja2 templates (default: registry/templates/.cache)
# HKASK_TEMPLATE_CACHE_PATH=registry/templates/.cache

# Registry YAML path for agent definitions (default: registry/bots)
# HKASK_REPLICANT_REGISTRY_PATH=registry/replicants

# Keystore master passphrase (generated on first run if not set)
# Store in OS keychain for production: kask keystore load
HKASK_KEYSTORE_PASSPHRASE=

# Replicant name for MCP server identity (default: "anonymous")
HKASK_MCP_HOST=kask-agent

# Inference timeout (seconds, default: 120)
HKASK_INFERENCE_TIMEOUT_SECS=120

# HTTP client pool max idle connections (default: 5)
HKASK_POOL_MAX_IDLE=5
