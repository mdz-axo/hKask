# =============================================================================
# hKask — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# Tiers: CORE (minimal) → STANDARD (recommended) → FULL (everything)
# Run `kask doctor` to validate your configuration.
# =============================================================================

# ─── TIER: CORE ─────────────────────────────────────────────────────────────
# Minimum to run hKask with inference. Fill these first.

# Inference Provider API Keys (at least ONE required)
# Provider prefix: DI/ (DeepInfra), FA/ (fal.ai), TG/ (Together), OR/ (OpenRouter)
# See: docs/guides/provider-api-keys.md for setup instructions

# DeepInfra — $1.30/month free credits | https://deepinfra.com/
DI_API_KEY=

# fal.ai — pay-per-use, generous free tier | https://fal.ai/
FA_API_KEY=

# Together AI — $5 free credits | https://together.ai/
TOGETHER_API_KEY=

# OpenRouter — unified API for 200+ models | https://openrouter.ai/
OPENROUTER_API_KEY=

# Default provider for unprefixed model names (DI, FA, TG, OR)
HKASK_DEFAULT_PROVIDER=DI

# Default model (supports provider prefixes: DI/meta-llama/Llama-3.3-70B-Instruct)
HKASK_DEFAULT_MODEL=DI/meta-llama/Llama-3.3-70B-Instruct

# ─── TIER: STANDARD ──────────────────────────────────────────────────────────
# Adds web search, financial data, and adapter support.

# --- Web Search Providers (at least ONE recommended) ---
# Brave Search API — free tier: 2,000 queries/month | https://brave.com/search/api/
HKASK_BRAVE_API_KEY=

# Firecrawl — web scraping + search | https://firecrawl.dev/
HKASK_FIRECRAWL_API_KEY=

# Tavily — AI-optimized search | https://tavily.com/
HKASK_TAVILY_API_KEY=

# SerpAPI — Google Search API | https://serpapi.com/
HKASK_SERPAPI_API_KEY=

# Exa — semantic search | https://exa.ai/
HKASK_EXA_API_KEY=

# Browserbase — headless browser for web browsing | https://browserbase.com/
HKASK_BROWSERBASE_API_KEY=

# Web cache configuration
HKASK_WEB_CACHE_TTL_SECS=3600
HKASK_WEB_CACHE_MAX_ENTRIES=1000

# --- Financial Data Providers ---
# Financial Modeling Prep — US company data | https://financialmodelingprep.com/
HKASK_FMP_API_KEY=

# EOD Historical Data — global markets data | https://eodhd.com/
HKASK_EODHD_API_KEY=

# --- Adapter / Training Providers ---
# RunPod — GPU cloud for inference + training | https://runpod.io/
RUNPOD_API_KEY=

# Baseten — model deployment platform | https://baseten.co/
BASETEN_API_KEY=

# HuggingFace — model/adapter repository access | https://huggingface.co/
HF_TOKEN=

# ─── TIER: FULL ───────────────────────────────────────────────────────────────
# Adds cloud deployment, Matrix federation, and persistent database backups.

# --- Matrix / Cross-Pod Communication ---
# Matrix homeserver URL — set by the Curator during system install.
# Points to the shared Conduit instance (Model B) or localhost (Model A per-pod).
# Pod agent credentials are auto-generated by `kask pod create`, not manually configured.
HKASK_MATRIX_URL=http://localhost:8008

# ─── TIER: FULL ───────────────────────────────────────────────────────────────
# --- Cloud Provider API Tokens ---
# Fly.io — edge container platform, primary cloud target
# Create: fly tokens create deploy (or fly auth token)
FLY_API_TOKEN=

# Fly.io organization slug (from fly orgs list)
FLY_ORG_SLUG=

# Hetzner Cloud — IaaS, cost-optimized secondary cloud target
# Create: Hetzner Console → API Tokens
HCLOUD_TOKEN=

# --- Litestream — SQLite Continuous Backup to S3 ---
# S3-compatible bucket for Litestream WAL replication
LITESTREAM_S3_BUCKET=hkask-pods-backup

# S3 endpoint (Backblaze B2, Cloudflare R2, Tigris, AWS S3, etc.)
LITESTREAM_S3_ENDPOINT=

# S3 region
LITESTREAM_S3_REGION=auto

# S3 credentials (Backblaze B2: Application Key ID + Application Key)
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# Set to "true" for Backblaze B2 / MinIO (path-style URLs)
LITESTREAM_FORCE_PATH_STYLE=false

# --- Container Registry ---
# Docker/OCI registry for pushing the kask container image
# GitHub Container Registry: ghcr.io/your-org/hkask
# Docker Hub: docker.io/your-org/hkask
CONTAINER_REGISTRY=

# Registry credentials (if private)
CONTAINER_REGISTRY_USERNAME=
CONTAINER_REGISTRY_PASSWORD=

# ─── OPERATIONAL ──────────────────────────────────────────────────────────────
# Runtime configuration.

# Pod identity (auto-generated by kask pod create if not set)
POD_ID=

# Data directory for SQLite databases (default: /data in container, ./data locally)
HKASK_DATA_DIR=./data

# Keystore master passphrase (generated on first run if not set)
# Store in OS keychain for production: kask keystore load
HKASK_KEYSTORE_PASSPHRASE=

# Replicant name for MCP server identity (default: "anonymous")
HKASK_REPLICANT=kask-agent

# Inference timeout (seconds, default: 120)
HKASK_INFERENCE_TIMEOUT_SECS=120

# HTTP client pool max idle connections (default: 5)
HKASK_POOL_MAX_IDLE=5
