# =============================================================================
# hKask Axolotl LoRA Trainer — General-purpose LoRA fine-tuning image
# =============================================================================
# Slim image: PyTorch + CUDA base, axolotl installed via pip.
# Config is generated by the Rust AxolotlHarness::render_config() and passed
# as the HKASK_AXOLOTL_CONFIG env var. This image just writes it to a file
# and runs `axolotl train`.
#
# No baked-in model weights. No Unsloth. No Python config generator.
# All configuration comes from environment variables at pod creation time.
#
# Build:
#   podman build -t docker.io/mdzaxo/axolotl-lora-trainer:latest .
# Push:
#   podman push docker.io/mdzaxo/axolotl-lora-trainer:latest
# =============================================================================

FROM docker.io/pytorch/pytorch:2.4.0-cuda12.1-cudnn9-devel

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    wget \
    curl \
    openssh-server \
    && rm -rf /var/lib/apt/lists/*

# Install axolotl and dependencies
RUN pip install --no-cache-dir \
    "axolotl[transformers]" \
    huggingface_hub \
    accelerate \
    bitsandbytes \
    peft \
    transformers \
    datasets \
    liger-kernel

# Copy the entrypoint (bash only — no Python)
COPY entrypoint.sh /workspace/entrypoint.sh
RUN chmod +x /workspace/entrypoint.sh

WORKDIR /workspace
RUN mkdir -p /workspace/data /workspace/outputs

# Environment variables (set by RunpodHost::submit in Rust)
ENV HKASK_AXOLOTL_CONFIG=""
ENV HKASK_HF_TOKEN=""
ENV HKASK_HF_MODEL_REPOSITORY=""
ENV HKASK_JOB_ID=""
ENV HKASK_COMPLETION_MANIFEST_PATH="/workspace/completion.json"
ENV HKASK_OUTPUT_DIR="/workspace/outputs"
ENV HF_HOME="/workspace/.hf-cache"
ENV HF_HUB_ENABLE_HF_TRANSFER="1"

ENTRYPOINT ["/bin/bash", "/workspace/entrypoint.sh"]
