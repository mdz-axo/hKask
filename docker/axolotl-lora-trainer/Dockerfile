# Minimal Axolotl LoRA Trainer Image
#
# Design (per AGENTS.md tooling policy — Rust only, no Python in our code):
#   - Base: debian:bookworm-slim (~80MB). No CUDA devel image, no PyTorch image.
#   - We install only python3 + pip + bash + ca-certificates + curl here.
#   - All heavy packages (axolotl, torch, transformers, peft, huggingface_hub)
#     are pip-installed at pod startup by entrypoint.sh — NOT baked in.
#   - The axolotl YAML config is generated by Rust (AxolotlHarness::render_config)
#     and passed as the HKASK_AXOLOTL_CONFIG env var. The entrypoint writes it
#     to /workspace/config.yml. No Python config generator.
#   - Target image size: <100MB. Push to docker.io/mdzaxo/axolotl-lora-trainer:latest.
#
# Unsloth is intentionally absent (deprecated; see project policy).

FROM debian:bookworm-slim

# Install python3-minimal + bash + ca-certificates + curl only. We avoid
# python3-pip (pulls ~30MB of recommended deps) and bootstrap pip manually
# via get-pip.py — this is the standard slim-Python pattern and keeps the
# image under 100MB. axolotl ships prebuilt wheels for torch/transformers/
# peft/tokenizers, so we do NOT need build-essential or git in the image.
# If a pip install at pod startup needs a compiler for an edge-case wheel,
# entrypoint.sh installs build-essential transiently and removes it after.
# No CUDA, no torch wheels baked in.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3-minimal \
        python3-distutils \
        bash \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSLO https://bootstrap.pypa.io/get-pip.py \
    && python3 get-pip.py --break-system-packages \
    && rm get-pip.py

# Create the workspace directory where the config and outputs live.
RUN mkdir -p /workspace/outputs

# Drop the entrypoint in place. It is the ONLY script in the image and it is
# bash — no Python scripts ship in the image (Rust generates the config).
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /workspace

# Default command: run the bash entrypoint. RunPod's docker_args (set by
# RunpodHost::submit) invoke this directly. After training completes the
# entrypoint execs `sleep infinity` so the pod stays alive for SSH debugging.
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
