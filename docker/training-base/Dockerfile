# hkask-training-base
#
# The ONE generic minimal Docker image for ALL hKask training jobs.
# Contains nothing but the bones: Python, pip, bash, curl, git, build-essential.
# No axolotl, no TRL, no Ludwig, no PyTorch, no CUDA toolkit, no pre-baked anything.
#
# At pod startup, the entrypoint reads HKASK_INSTALL_SCRIPT (a bash script
# generated by Rust at submit time) which:
#   1. pip-installs the harness-specific packages (axolotl / trl / ludwig)
#   2. Writes the rendered training config (YAML or Python) to /workspace
#   3. Logs in to HuggingFace (if HF_TOKEN is set)
#   4. Runs the training command (axolotl train / python train.py / ludwig train)
#   5. Uploads the adapter to HuggingFace
#   6. Writes a completion manifest
#   7. exec sleep infinity for SSH debugging
#
# This image is ~130MB. The heavy packages are pip-installed at pod startup
# into the workspace volume (persists across container restarts). This avoids
# the 22-31GB pre-baked image failure pattern documented in Lesson 11.
#
# Pushed to: docker.io/mdzaxo/hkask-training-base:latest

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        curl \
        git \
        build-essential \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
