# hKask Environment Variables
# Copy this file to .env or export these variables in your shell.
# See docs/user-guides/ for setup instructions.

# ── Required ──────────────────────────────────────────────────────────
# Master passphrase for secret derivation (first-run onboarding creates this)
# HKASK_MASTER_KEY="your-master-passphrase"

# ── Inference ─────────────────────────────────────────────────────────
# Default model for chat/completion (default: deepseek-v4-pro)
# HKASK_DEFAULT_MODEL="qwen3:8b"

# Embedding model for semantic search (default: all-MiniLM-L6-v2)
# HKASK_EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
# HKASK_EMBEDDING_DIM=384

# ── Storage ───────────────────────────────────────────────────────────
# Database path (default: data/hkask.db)
# HKASK_DB_PATH="data/hkask.db"
# HKASK_DB_PASSPHRASE="your-db-passphrase"

# Memory database path (default: data/hkask-memory.db)
# HKASK_MEMORY_DB_PATH="data/hkask-memory.db"
# HKASK_MEMORY_DB_PASSPHRASE="your-memory-db-passphrase"

# ── Identity ───────────────────────────────────────────────────────────
# WebID for agent identity (default: did:web:localhost)
# HKASK_WEBID="did:web:your-domain.com"

# Replicant name for this agent instance
# HKASK_REPLICANT_NAME="my-agent"
# HKASK_REPLICANT="my-agent"

# Agent persona profile (default: assistant)
# HKASK_AGENT_PERSONA="researcher"

# ── Registry ──────────────────────────────────────────────────────────
# Path to YAML agent definitions (default: registry/bots)
# HKASK_REGISTRY_PATH="registry/bots"

# Template paths
# HKASK_TEMPLATES_PATH="registry/templates"
# HKASK_TEMPLATE_CACHE_PATH="/tmp/hkask-templates"

# ── CNS (Cybernetic Nervous System) ──────────────────────────────────
# CNS configuration file path
# HKASK_CNS_CONFIG="config/cns.toml"

# Seam watcher check interval in seconds (default: 1800 = 30 min)
# HKASK_SEAM_CHECK_INTERVAL_SECS=1800

# Deposit monitor interval in seconds (default: 300 = 5 min)
# HKASK_DEPOSIT_MONITOR_INTERVAL_SECS=300

# ── Backup ────────────────────────────────────────────────────────────
# Passphrase for backup encryption
# HKASK_BACKUP_PASSPHRASE="your-backup-passphrase"

# Content-addressable storage home directory
# HKASK_CAS_HOME="data/cas"

# ── Web Cache ─────────────────────────────────────────────────────────
# Maximum cache entries (default: 1000)
# HKASK_WEB_CACHE_MAX_ENTRIES=1000

# Cache TTL in seconds (default: 3600 = 1 hour)
# HKASK_WEB_CACHE_TTL_SECS=3600

# ── Matrix / Agent Communication ──────────────────────────────────────
# Matrix homeserver URL (default: http://localhost:8008)
# HKASK_MATRIX_URL="http://localhost:8008"

# Matrix agent credentials (auto-registered on first launch)
# HKASK_MATRIX_AGENT_USERNAME="hkask-agent"
# HKASK_MATRIX_AGENT_PASSWORD="your-matrix-password"

# Matrix registration token (if homeserver requires it)
# HKASK_MATRIX_REGISTRATION_TOKEN="your-registration-token"

# ── MCP Servers ───────────────────────────────────────────────────────
# Financial data API keys
# HKASK_EODHD_API_KEY="your-eodhd-key"

# Fal.ai API key — for AI media generation (images, video, TTS)
# HKASK_FAL_API_KEY="your-fal-key"

# Use fal.ai for document processing (OCR, PDF extraction)
# HKASK_USE_FAL_DOCRES=true

# OCR configuration
# HKASK_OCR_MODEL="microsoft/trocr-base-printed"
# HKASK_OCR_SAMPLE_RATE=1.0
# HKASK_OCR_SIMPLE_MAX=50
# HKASK_OCR_MODERATE_MAX=200
# HKASK_OCR_TUNEABLE=true

# Python path for MCP servers that use Python tooling
# HKASK_PYTHON_PATH="/usr/bin/python3"

# Dataset URL for training data ingestion
# HKASK_DATASET_URL="https://example.com/dataset.jsonl"

# ── Training ──────────────────────────────────────────────────────────
# Training cache directory
# HKASK_TRAINING_CACHE_DIR="data/training-cache"

# Cloud dispatch for training jobs (e.g., "baseten", "runpod")
# HKASK_TRAINING_CLOUD_DISPATCH="baseten"

# Training harness mode (e.g., "local", "cloud")
# HKASK_TRAINING_HARNESS="local"

# Training host endpoint
# HKASK_TRAINING_HOST="http://localhost:8080"

# ── Axolotl (Fine-tuning) ─────────────────────────────────────────────
# Path to axolotl configuration directory
# HKASK_AXOLOTL_PATH="config/axolotl"

# ── Chain / Wallet (feature-gated) ────────────────────────────────────
# Solana
# SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# SOLANA_TREASURY_PUBKEY="your-solana-pubkey"
# SOLANA_TEST_DESTINATION="your-test-destination"

# Hedera
# HEDERA_CONSENSUS_NODE_URL="https://mainnet.hedera.com"
# HEDERA_MIRROR_NODE_URL="https://mainnet.mirror.hedera.com"
# HEDERA_TREASURY_ACCOUNT="0.0.12345"
# HEDERA_TEST_DESTINATION="0.0.67890"

# Hinkal (privacy layer)
# HINKAL_RELAYER_URL="https://api.hinkal.io"
# HINKAL_TREASURY_ACCOUNT="your-hinkal-account"
