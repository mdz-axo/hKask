# hKask Environment Variables
# Copy this file to .env or export these variables in your shell.
# See docs/user-guides/ for setup instructions.

# ── Required ──────────────────────────────────────────────────────────
# Master passphrase for secret derivation (first-run onboarding creates this)
# HKASK_MASTER_KEY="your-master-passphrase"

# ── Inference ─────────────────────────────────────────────────────────
# Model to use (default: deepseek-v4-pro)
# HKASK_MODEL="qwen3:8b"

# Ollama endpoint (default: http://localhost:11434)
# HKASK_OLLAMA_ENDPOINT="http://localhost:11434"

# Fireworks API key (for cloud inference)
# HKASK_FIREWORKS_API_KEY="your-fireworks-key"

# DeepInfra API key (for cloud inference)
# HKASK_DEEPINFRA_API_KEY="your-deepinfra-key"

# ── Storage ───────────────────────────────────────────────────────────
# Database path (default: data/hkask.db)
# HKASK_DB_PATH="data/hkask.db"

# Memory database path (default: data/hkask-memory.db)
# HKASK_MEMORY_DB_PATH="data/hkask-memory.db"

# ── MCP Servers ───────────────────────────────────────────────────────
# Financial Modeling Prep API key — for stock/financial data
# HKASK_FMP_API_KEY="your-fmp-api-key"

# Fal.ai API key — for AI media generation
# HKASK_FAL_API_KEY="your-fal-api-key"

# ── OCAP / Security ───────────────────────────────────────────────────
# OCAP secret for MCP authorization
# HKASK_OCAP_SECRET="your-ocap-secret"

# ── Registry ──────────────────────────────────────────────────────────
# Path to YAML agent definitions (default: registry/bots)
# HKASK_REGISTRY_PATH="registry/bots"

# Template cache path (default: /tmp/hkask-templates)
# HKASK_TEMPLATE_CACHE_PATH="/tmp/hkask-templates"
