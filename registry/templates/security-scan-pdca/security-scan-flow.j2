[inference]
template_type: KnowAct
lexicon_terms:
- scan
- detect
- measure
- improve
- converge
contract:
  input:
    scan_target: string
    service_pair: array
    dependency_manifest_ref: string  # Snyk — unverified mapping (needs dependency manifest check)
    iac_rules_ref: string            # Semgrep — mechanism verified; domain bridge unverified (needs FIBO analog spec per §P5.4)
    previous_cycle_result: object
    replicant_webid: string          # §P12.1 — no anonymous agency
    delegation_token_ref: string     # §P4.1 — OCAP enforcement
  output:
    scan_plan: object
    scan_execution_steps: array
    state_results: object            # DC+BIBO state axis — §P5.4 line 94
    cns_spans_emitted: array         # §P9.1 — canonical namespace invariant
    convergence_metric: number
    loop_decision: string            # close / iterate / escalate
energy_cap: 4096
visibility: Public
