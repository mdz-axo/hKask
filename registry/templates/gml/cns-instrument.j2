{# gml/cns-instrument.j2 - CNS instrumentation macros #}
{# Purpose: Emit CNS span events for monitoring #}

{% macro start_span(operation, concept_id) -%}
{% do reg.emit({
    "event": "span_start",
    "span": "reg.gml." ~ operation,
    "concept_id": concept_id | default('unknown'),
    "timestamp": now() | default('unknown'),
    "actor": capability.subject | default('anonymous')
}) %}
{%- endmacro %}

{% macro end_span(operation, status, attributes) -%}
{% do reg.emit({
    "event": "span_end",
    "span": "reg.gml." ~ operation,
    "status": status,
    "attributes": attributes | default({}),
    "timestamp": now() | default('unknown')
}) %}
{%- endmacro %}

{% macro record_error(operation, error_code, message) -%}
{% do reg.emit({
    "event": "error",
    "span": "reg.gml." ~ operation,
    "error_code": error_code,
    "message": message,
    "timestamp": now() | default('unknown')
}) %}
{%- endmacro %}

{% macro check_variety(counter_name, threshold) -%}
{% set variety = reg.get_variety(counter_name) | default(0) %}
{% if variety > threshold %}
{% do reg.emit({
    "event": "algedonic_alert",
    "alert": "reg.algedonic.variety_deficit",
    "counter": counter_name,
    "value": variety,
    "threshold": threshold,
    "level": "warning",
    "timestamp": now() | default('unknown')
}) %}
{% endif %}
{%- endmacro %}

{% macro audit_log(operation, concept_id, before_r_bar, after_r_bar, result) -%}
{% do reg.emit({
    "event": "audit_log",
    "operation": operation,
    "concept_id": concept_id | default('unknown'),
    "capability_hash": capability.id.hash() | default('unknown'),
    "before_r_bar": before_r_bar,
    "after_r_bar": after_r_bar,
    "result": result,
    "timestamp": now() | default('unknown')
}) %}
{%- endmacro %}
