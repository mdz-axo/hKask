  "contract_location": "path/to/implementation/file.rs:LINE",
  "user_expectation": "I can check whether an agent has enough gas before executing",
  "goal_principle": {
    "principle": "P9",
    "name": "Homeostatic Self-Regulation",
    "rationale": "Prevents runaway agent execution"
  },
  "constraining_principles": [
    {
      "principle": "P4",
      "name": "Clear Boundaries",
      "constraint": "Cap enforces resource boundary — no unbounded execution"
    }
  ],
  "test_code": "// REQ: P9-cns-energy-budget-can-proceed — energy budget check\n#[test]\nfn energy_budget_can_proceed() { ... }",
  "test_file_path": "path/to/test/file.rs",
  "implementation_code": "// The minimal code to satisfy the contract",
  "implementation_file_path": "path/to/implementation/file.rs",
