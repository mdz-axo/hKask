{# Template: magna-carta-verifier/mc-verify-testcase.j2 #}
{# KnowAct — Render Rust test case skeletons from assertion definitions #}
{# ℏKask v0.28.0 — A Minimal Viable Container for Agents #}

[inference]
temperature = 0.2
