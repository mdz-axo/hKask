{# goal: Select the best adversarial target and map its vulnerability surface against hKask's actual deployed defenses. #}
[inference]
template_type: KnowAct
lexicon_terms:
- select
- calibrate
- target
- assess
- adversarial
- classify
contract:
  input:
    target_output: string
    target_domain: string
    adversarial_categories: array
    intensity: string
    defense_layers: array
  output:
    selected_target: string
    domain: string
    vulnerability_surface: array
    categories_to_test: array
    intensity_level: string
