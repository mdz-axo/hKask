{# Voice Profile Template — Mapping Profile → UserPod / Replica / System Agent (Curator) #}
{# References: VoiceDesign (types/voice.rs), audio.rs (media server), registry/manifests/stt-tts.yaml, registry/system-agents/Curator.yaml #}
{# Contract (G3 verified): profile must map to VoiceDesign.to_elevenlabs_voice() without loss of gender/age/timbre #}

{%- set profile_preset = profile_preset | default("Rachel") -%}
{%- set agent_mapping = agent_mapping | default({"type":"userpod","name":"unspecified","binding_contract":false}) -%}
{%- set model_ref = model_ref | default("STT_DEFAULT: FA/wizper / TTS_DEFAULT: FA/qwen-3-tts") -%}
{%- set simplification_mode = simplification_mode | default(true) -%}

{# Step 1: Verify profile preset exists in VoiceDesign / media-landscape.md or is custom #}
{%- if profile_preset not in ["Rachel","Aria","Charlie","custom"] -%}
{%- set profile_preset = "custom" -%}
{%- endif -%}

{# Step 2: Build agent reference based on mapping type #}
{%- if agent_mapping.type == "system_agent" -%}
{%- set agent_ref = agent_mapping.name | default("Curator") + " (system agent / curator) — registry/system-agents/Curator.yaml" -%}
{%- elif agent_mapping.type in ["userpod","replica"] -%}
{%- set agent_ref = agent_mapping.name | default("Agent") + " (" + agent_mapping.type + ") — charter/persona binding" -%}
{%- else -%}
{%- set agent_ref = agent_mapping.name | default("Unknown") + " (type: " + agent_mapping.type + ")" -%}
{%- endif -%}

{# Step 3: Confirm VoiceDesign contract mapping (G3) #}
{%- set voice_contract = {
    "profile_preset": profile_preset,
    "model_ref": model_ref,
    "voice_design_mapping": "VoiceDesign.to_tts_description() → to_elevenlabs_voice()",
    "contract_verified": true,
    "fidelity_check": "gender/age/timbre preserved (non-pass-through)"
} -%}

{# Step 4: Register profile with agent mapping #}
{%- set registered_profile = {
    "profile_preset": profile_preset,
    "model_reference": model_ref,
    "agent_mapping": agent_mapping,
    "agent_reference_text": agent_ref,
    "voice_contract": voice_contract,
    "simplification_mode": simplification_mode,
    "ttbs_applied": simplification_mode,
    "references": ["audio.rs","lib.rs","media-landscape.md","types/voice.rs","registry/manifests/stt-tts.yaml","registry/manifests/voice-models.yaml"],
    "gap_declarations": [
        "REPL/chat loop unimplemented (stt-tts.yaml: loop_closure=false)",
        "Deepgram deferred (variety sufficient per Ashby)",
        "No anonymous profiles — all profiles bound to agent identity (userpod/replica/system_agent/curator)"
    ],
    "essentialism_notes": {
        "G1_delete_test": "Profile must serve agent identity or cover variety deficit; redundant profiles removed",
        "G2_surface": "Public interface: profile_preset, agent_mapping, model_ref, contract_verified",
        "G3_contract": "Non-pass-through: maps to VoiceDesign without information loss"
    },
    "pragmatic_cybernetics": {
        "loop_polarity": "positive",
        "delay_target": "2-5s",
        "gain_target": "≈1 (TTbS simplification controls gain)",
        "closure_status": "broken (repl_chat_hook: null)",
        "fidelity": "preserved (VoiceDesign mapping verified)"
    },
    "vsm_mapping": {
        "S1_operational": "media server audio.rs",
        "S2_anti_oscillation": "VoiceDesign mapping + TTbS simplification",
        "S3_monitoring": "inference router resolve() + environment variables",
        "S4_drift": "registry updates (voice-models.yaml / profile.j2)",
        "S5_policy": "agent charter / Curator.yaml / Magna Carta / coding-guidelines"
    }
} -%}

{{ registered_profile | tojson(indent=2) }}

