[inference]
template_type: KnowAct
lexicon_terms:
- evaluate
- converge
- classify
- verify
- calibrate
contract:
  input:
    plan_result: object
    execute_result: object
    verify_result: object
  output:
    convergence_metric: number
    rationale: string
    blockers: array
energy_cap: 2048
visibility: Public
