      ]
    }
  ],
  "alignment_check": {
    "question_to_hypothesis": "aligned|partial_misalignment|misaligned",
    "hypothesis_to_aim": "aligned|partial_misalignment|misaligned",
    "aim_to_objectives": "aligned|partial_misalignment|misaligned",
    "objectives_to_outcome": "aligned|partial_misalignment|misaligned",
    "hypothesis_to_null": "aligned|partial_misalignment|misaligned",
    "misalignments": [
      { "gap": "description of misalignment", "correction": "proposed fix" }
    ],
    "overall_alignment": "aligned|minor_gaps|significant_gaps"
  },
  "feasibility_recheck": {
    "sample_size_feasible": true,
    "methods_feasible": true,
    "timeline_feasible": true,
