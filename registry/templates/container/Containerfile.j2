{# Template: registry/templates/container/Containerfile.j2 #}
{# Functional Role: WordAct (container build specification) #}
{# Implementation: Jinja2 template — rendered by kask pod export-container #}
{# Produces: Containerfile for building a pod container image #}
{# Pod Container — Generated by hKask v{{ version }} #}
FROM hkask-runtime:{{ version }}
LABEL hkask.pod.id="{{ pod_id }}"
LABEL hkask.pod.kind="{{ pod_kind }}"
LABEL hkask.pod.webid="{{ webid }}"
LABEL hkask.exported.at="{{ exported_at }}"

COPY pods/{{ pod_id }}.db /data/pod.db
COPY pods/{{ pod_id }}.webid /data/pod.webid
COPY pods/{{ pod_id }}/persona.yaml /etc/hkask/persona.yaml
COPY pods/{{ pod_id }}/templates/ /etc/hkask/templates/

ENV HKASK_POD_ID={{ pod_id }}
ENV HKASK_POD_KIND={{ pod_kind }}
ENV HKASK_POD_MODE=standalone

ENTRYPOINT ["kask", "pod", "serve", "--pod-id", "{{ pod_id }}"]
