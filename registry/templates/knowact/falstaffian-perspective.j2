template_type: Cognition
lexicon_terms: [calibrate, affirm, select, execute, verify]
contract:
  input:
    input_criticism: string
    context: string
    desired_outcome: string
    iteration_count: integer
    base_seed: integer
  output:
    perspective: string
    variance_report: object
  energy_cap: 4096
  visibility: Shared

