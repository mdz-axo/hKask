{# goal: Fallback goal verification with minimal evaluation. Produces a continue verdict and default confidence for lightweight judgment. #}
{# goal_judge_simple.j2 — Fallback goal verification #}
{# functional_role: knowact #}
{# implementation_type: jinja2 #}
{# lexicon_terms: [assert, acknowledge] #}
[inference]
template_type: KnowAct
functional_role: KnowAct
implementation_type: jinja2
lexicon_terms: [assert, acknowledge]
energy_cap: 2048
visibility: Public
contract:
  input:
    goal_text: string
    outcome_summary: string
  output:
    verdict: "continue"
    reason: string
    confidence: 0.5

