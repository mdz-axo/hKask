template_type: KnowAct
lexicon_terms:
- detect
- evaluate
- regulate
- orient
contract:
  input:
    topic: string
    current_level: integer
    solid_ratio: float
    total_questions: integer
  output:
    new_level: integer
    action: string
    reason: string
energy_cap: 2048
visibility: Public
