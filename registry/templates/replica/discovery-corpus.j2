{# Replica Discovery Corpus YAML Generator
   Generates a corpus.yaml from discovered academic works.

   Inputs:
   - author_name: string (e.g., "David Dunning")
   - author_name_lower: string (e.g., "david dunning")
   - works: array of {title, slug, url, year, type, source}
   - foundational_rules: array of {slug, text, type} (optional)
   - entities: {characters, places, events, concepts} (optional)
   - methods: array of {name, description, signal} (optional)
#}
---
# {{ author_name }} Style Corpus Configuration
# Generated by: replica-discovery pipeline
# Date: {{ generation_date }}
#
# Academic author corpus — works discovered across:
#   - Semantic Scholar (academic papers)
#   - arXiv (preprints)
#   - Web search (institutional pages, open web)
#   - YouTube transcripts (talks, interviews)
#
# Pipeline: replica_discover → corpus.yaml → replica_build

author: {{ author_name_lower | replace(" ", "-") }}
author_full: "{{ author_name }}"

# ── Embedding Model Configuration ──────────────────────────────────────────
embedding:
  model: "DI/Qwen/Qwen3-Embedding-0.6B"
  dim: 1024
  batch_size: 64

# ── Corpus Sources ─────────────────────────────────────────────────────────
works:
{% for work in works %}
  - title: "{{ work.title }}"
    slug: {{ work.slug }}
    url: "{{ work.url }}"
{% if work.year %}
    year: {{ work.year }}
{% endif %}
    type: {{ work.type }}
{% if work.source %}
    source: {{ work.source }}
{% endif %}
{% endfor %}

# ── Foundational Rules ─────────────────────────────────────────────────────
{% if foundational_rules %}
foundational_rules:
{% for rule in foundational_rules %}
  - title: "{{ rule.title | default(rule.slug) }}"
    slug: {{ rule.slug }}
    text: |
      {{ rule.text | indent(6) }}
    type: {{ rule.type | default("concept_definition") }}
{% endfor %}
{% endif %}

# ── Chunking Configuration ─────────────────────────────────────────────────
chunking:
  min_words: 50
  max_words: 200
  split_on: paragraph
  sentence_boundary: ".!? "
  overlap_words: 0

# ── Entity Reference Format ────────────────────────────────────────────────
entity_ref_pattern: "style:{author}:{slug}:{index}"
centroid_entity_ref: "style:{{ author_name_lower | replace(" ", "-") }}:centroid"

# ── Quality Thresholds ─────────────────────────────────────────────────────
validation:
  centroid_distance_max: 0.25
  exemplar_count_min: 3
  exemplar_count_max: 7

# ── Entity Declarations (5W1H Metadata Layer) ───────────────────────────────
{% if entities %}
entities:
{% if entities.characters %}
  characters:
{% for c in entities.characters %}
    - name: "{{ c.name }}"
{% if c.appears_in %}
      appears_in: {{ c.appears_in | tojson }}
{% endif %}
{% endfor %}
{% endif %}
{% if entities.places %}
  places:
{% for p in entities.places %}
    - name: "{{ p.name }}"
{% endfor %}
{% endif %}
{% if entities.events %}
  events:
{% for e in entities.events %}
    - name: "{{ e.name }}"
{% endfor %}
{% endif %}
{% if entities.concepts %}
  concepts:
{% for c in entities.concepts %}
    - name: "{{ c.name }}"
{% endfor %}
{% endif %}
{% endif %}

# ── Declared Methods ────────────────────────────────────────────────────────
{% if methods %}
methods:
{% for method in methods %}
  - name: "{{ method.name }}"
    description: "{{ method.description }}"
{% if method.signal %}
    signal:
{% for key, value in method.signal.items() %}
      {{ key }}: {{ value }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

# ── Budget ──────────────────────────────────────────────────────────────────
budget:
  per_100_pages: 3750
