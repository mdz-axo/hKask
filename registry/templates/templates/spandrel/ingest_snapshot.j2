{# Spandrel: Ingest Snapshot #}
{# Load ontology snapshot into bitemporal store #}

{% set timestamp = namespace(value=now()) %}
{% set graph_iri = namespace(value="") %}

{% if not ontology %}
  {{ raise_error("spandrel.invalid_input", "ontology is required") }}
{% endif %}

{% if ontology not in ["esco", "openalex", "nace"] %}
  {{ raise_error("spandrel.invalid_input", "ontology must be esco, openalex, or nace") }}
{% endif %}

{% if not upstream_version %}
  {{ raise_error("spandrel.invalid_input", "upstream_version is required") }}
{% endif %}

{% if not rdf_format %}
  {{ raise_error("spandrel.invalid_input", "rdf_format is required") }}
{% endif %}

{% if rdf_format not in ["n-triples", "n-quads"] %}
  {{ raise_error("spandrel.invalid_input", "rdf_format must be n-triples or n-quads") }}
{% endif %}

{% if not payload %}
  {{ raise_error("spandrel.invalid_input", "payload is required") }}
{% endif %}

{% if not license %}
  {{ raise_error("spandrel.invalid_input", "license is required") }}
{% endif %}

{# Generate graph IRI #}
{% set graph_iri.value = "graph:" + ontology + ":" + upstream_version %}

{# Parse RDF payload #}
parse_result:
  format: {{ rdf_format }}
  payload_size: {{ payload | length }}
  status: parsed

{# Tag entities with graph IRI #}
tagging:
  graph_iri: {{ graph_iri.value }}
  status: tagged

{# Register in snapshot index #}
snapshot_index:
  ontology: {{ ontology }}
  upstream_version: {{ upstream_version }}
  graph_iri: {{ graph_iri.value }}
  license: {{ license }}
  source_urls: {{ source_urls | default([]) }}
  is_current: false
  ingested_at: {{ timestamp.value }}

{# Result #}
result:
  graph_iri: {{ graph_iri.value }}
  ontology: {{ ontology }}
  upstream_version: {{ upstream_version }}
  status: ingested
  is_current: false
  note: "Call spandrel_promote_snapshot to set as current"

{# CNS span emission #}
span:
  namespace: cns.tool.spandrel_ingest_snapshot
  phase: observe
  observation:
    ontology: {{ ontology }}
    version: {{ upstream_version }}
    graph_iri: {{ graph_iri.value }}
    outcome: ingested
