{# Spandrel: Create Reference #}
{# Create a Reference page in the catalogue #}

{% set timestamp = namespace(value=now()) %}

{% if not slug %}
  {{ raise_error("spandrel.invalid_input", "slug is required") }}
{% endif %}

{% if not category %}
  {{ raise_error("spandrel.invalid_input", "category is required") }}
{% endif %}

{% if category not in ["academic", "industry", "skill"] %}
  {{ raise_error("spandrel.invalid_input", "category must be academic, industry, or skill") }}
{% endif %}

{% if not source_locator %}
  {{ raise_error("spandrel.invalid_input", "source_locator is required") }}
{% endif %}

{% if not accessed_on %}
  {{ raise_error("spandrel.invalid_input", "accessed_on is required") }}
{% endif %}

{# Build Reference page #}
reference:
  slug: "{{ slug }}"
  category: {{ category }}
  source_locator: "{{ source_locator }}"
  published_on: {{ published_on | default("null") }}
  accessed_on: {{ accessed_on }}
  last_verified_on: {{ last_verified_on | default("null") }}
  notes: {{ notes | default("null") }}
  created_at: {{ timestamp.value }}
  page_path: "References/{{ slug }}"

{# Result #}
result:
  slug: "{{ slug }}"
  page_path: "References/{{ slug }}"
  status: created

{# CNS span emission #}
span:
  namespace: cns.tool.spandrel_create_reference
  phase: observe
  observation:
    slug: "{{ slug }}"
    category: {{ category }}
    outcome: created
