{# Maps each finding to OSC&R + OWASP Supply Chain dual taxonomy #}
{# Emits cns.taxonomy.map CNS span per mapping (P9) — namespace registered #}
{# Applies pragmatic-cybernetics: feedback loop, variety, Good Regulator #}

INPUT: findings_to_map = {{ findings_to_map }} (structured array from select-evidence phase)
INPUT: existing_taxonomy_mappings = {{ existing_taxonomy_mappings | default([]) }} (skip — already mapped)
INPUT: osc_r_reference = {{ osc_r_reference | default([]) }} (OSC&R category list verified against oscar.io — see SKILL.md §OSC&R Taxonomy Reference)
INPUT: replicant_host = {{ replicant_host | default("REQUIRED") }} (P12 — no anonymous mapping)

