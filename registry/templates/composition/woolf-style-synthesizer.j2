{{ accumulative_reflection("She",
    "was not beautiful",
    "no, she could not be called beautiful",
    "she had something more rare — a radiance, a gift of significance that made you forget whether she was beautiful or not",
    "beauty was only the beginning; what she had went deeper than beauty") }}

{{ window_moment("She", "the trees were bare and beautiful in the winter light", "and something in her rose to meet the bareness, the clarity, the silence") }}

=============================================================================
#}
