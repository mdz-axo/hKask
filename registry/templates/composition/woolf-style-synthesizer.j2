[inference]
template_type: WordAct
lexicon_terms: [compose, synthesize, write, render, evoke]
contract:
  input:
    prompt: string
    exemplar_passages: array
    centroid_distance_threshold: float
  output:
    prose: string
    centroid_distance: float
  energy_cap: 4096
  visibility: Shared

---
