[inference]
template_type: Prompt
lexicon_terms: [compose, synthesize, write, edit, refine, render]
contract:
  input:
    clauses: array
    style: string
    subject: string
    action: string
    context: string
  output:
    prose: string
  energy_cap: 4096
  visibility: Shared

---
