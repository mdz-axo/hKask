# output (Lesson 6 precedent: PiSSA portability).
#
# LoRA initialization is rendered from the typed TrainingParams boundary.
# EVA is the canonical data-driven initializer. PiSSA is not used because its
# mutated-base save contract is not portable across verified environments.

import os
import sys

# ── TRL version assertion ──────────────────────────────────────────────────
# Fail fast if the installed TRL version is incompatible. The pod template
# pins TRL to a specific version; this assertion catches drift.
try:
    import trl
    _trl_version = getattr(trl, "__version__", "unknown")
except ImportError as e:
    print(f"FATAL: trl not installed: {e}", file=sys.stderr)
    sys.exit(1)

from trl import {{ config_class }}, {{ trainer_class }}
from datasets import load_dataset
from peft import LoraConfig
from transformers import AutoModelForCausalLM
import torch

# ── Base model ──────────────────────────────────────────────────────────────
base_model = "{{ base_model }}"

# ── PEFT / LoRA configuration ───────────────────────────────────────────────
# Rendered from the typed LoraParams boundary — same fields as SFT.
# PEFT is trainer-agnostic: the same LoRA config works for SFT, DPO, KTO, ORPO.
peft_config = LoraConfig(
    r={{ lora_r }},
    lora_alpha={{ lora_alpha }},
    lora_dropout={{ lora_dropout | default(0) }},
    target_modules=[
{% for module in lora_target_modules %}
        "{{ module }}",
{% endfor %}
    ],
{% if peft_init_lora_weights %}
    init_lora_weights="{{ peft_init_lora_weights }}",
{% endif %}
{% if use_rslora == "true" %}
    use_rslora=True,
{% endif %}
{% if use_dora == "true" %}
    use_dora=True,
{% endif %}
)

# ── Dataset ────────────────────────────────────────────────────────────────
# Expected format: {{ expected_dataset_format }}
# TRL preference trainers accept conversational preference datasets directly.
{% if data_files %}
dataset = load_dataset("{{ dataset_path }}", data_files="{{ data_files }}", split="train")
{% else %}
dataset = load_dataset("{{ dataset_path }}", split="train")
{% endif %}

# ── Model loading ──────────────────────────────────────────────────────────
# Load the base model. For preference optimization, the model is loaded with
# AutoModelForCausalLM (not passed as a string to the trainer, because some
# preference trainers need a reference model or specific model setup).
{% if load_in_4bit %}
from transformers import BitsAndBytesConfig
quantization_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type="{{ bnb_4bit_quant_type | default("nf4") }}",
    bnb_4bit_compute_dtype=torch.{{ bnb_4bit_compute_dtype | default("bfloat16") }},
    bnb_4bit_use_double_quant={{ bnb_4bit_use_double_quant | default(true) }},
)
model = AutoModelForCausalLM.from_pretrained(
    base_model,
    quantization_config=quantization_config,
    torch_dtype=torch.bfloat16,
    trust_remote_code=True,
)
{% else %}
model = AutoModelForCausalLM.from_pretrained(
    base_model,
    torch_dtype=torch.bfloat16,
    trust_remote_code=True,
)
{% endif %}

# ── {{ trainer_class }} configuration ───────────────────────────────────────
# Rendered from the typed TrainingParams boundary. Preference trainers use
# lower learning rates than SFT (typically 1e-5 to 5e-6 for DPO/KTO/ORPO).
config = {{ config_class }}(
    output_dir="{{ output_dir }}",
    num_train_epochs={{ num_epochs | default(2) }},
    per_device_train_batch_size={{ micro_batch_size | default(1) }},
    eval_batch_size=1,
    gradient_accumulation_steps={{ gradient_accumulation_steps | default(16) }},
    learning_rate={{ learning_rate | default(0.0001) }},
    bf16=True,
    gradient_checkpointing=True,
{% if lr_scheduler %}
    lr_scheduler_type="{{ lr_scheduler }}",
{% endif %}
{% if warmup_steps %}
    warmup_steps={{ warmup_steps }},
{% endif %}
{% if weight_decay %}
    weight_decay={{ weight_decay }},
{% endif %}
{% if max_grad_norm %}
    max_grad_norm={{ max_grad_norm }},
{% endif %}
{% if optim %}
    optim="{{ optim }}",
{% endif %}
{% if sequence_len %}
    max_length={{ sequence_len }},
{% endif %}
    eval_strategy="steps",
    eval_steps=200,
    save_strategy="steps",
    save_steps=200,
    save_total_limit=5,
    load_best_model_at_end=True,
    metric_for_best_model="loss",
    report_to="none",
    logging_steps=10,
    trust_remote_code=True,
)

# ── Trainer ────────────────────────────────────────────────────────────────
# DPO/KTO/ORPO trainers accept peft_config for LoRA adaptation.
# RewardTrainer also accepts peft_config for reward model adaptation.
trainer = {{ trainer_class }}(
    model=model,
    args=config,
    train_dataset=dataset,
    peft_config=peft_config,
)

# ── Train ──────────────────────────────────────────────────────────────────
trainer.train()

# ── Save adapter ───────────────────────────────────────────────────────────
# TRL + PEFT saves adapter_model.safetensors + adapter_config.json to output_dir.
# The RunPod host's completion_marker checks for adapter_model.safetensors.
trainer.save_model("{{ output_dir }}")

# ── Completion manifest ────────────────────────────────────────────────────
# Written by the pod entrypoint (bash heredoc, no Python) after this script
# exits successfully. The entrypoint reads HKASK_COMPLETION_MANIFEST_PATH.
print(f"TRL {{ trainer_class }} training complete. Adapter saved to {{ output_dir }}")
