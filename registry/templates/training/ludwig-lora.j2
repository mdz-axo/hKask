# Auto-generated by hKask Training Server (harness: ludwig)
# Rendered from registry/templates/training/ludwig-lora.j2
# Evolvable via gpa-evolution / skill-maintenance — no Rust recompile needed.
#
# Ludwig is a declarative deep-learning framework (Linux Foundation AI & Data,
# Apache-2.0). This config drives `ludwig train --config model.yaml` on the
# RunPod pod. All trainer types are supported via `trainer.type`:
# finetune (SFT), dpo, kto, orpo, grpo.
#
# References:
# - https://ludwig.ai/latest/getting_started/llm_fine_tuning/
# - https://ludwig.ai/latest/configuration/
model_type: llm
base_model: {{ base_model }}

{% if load_in_4bit %}
quantization:
  bits: 4
{% endif %}

adapter:
  type: lora
  r: {{ lora_r }}
  alpha: {{ lora_alpha }}
  dropout: {{ lora_dropout | default(0) }}
{% if use_rslora == "true" %}
  use_rslora: true
{% endif %}
{% if use_dora == "true" %}
  use_dora: true
{% endif %}
{% if peft_init_lora_weights %}
  # Explicit PEFT initialization strategy from the accepted operator config.
  # Ludwig supports: pissa, eva, corda, loftq, gaussian, random, default.
  init_weights: {{ peft_init_lora_weights }}
{% endif %}
  target_modules:
{% for module in lora_target_modules %}
    - {{ module }}
{% endfor %}

input_features:
  - name: prompt
    type: text

output_features:
  - name: output
    type: text

prompt:
  template: |
    ### Instruction:
    {instruction}

    ### Input:
    {input}

    ### Response:

{% if data_files %}
# Dataset is loaded from the HuggingFace repository by the pod entrypoint
# (HKASK_HF_DATASET_REPOSITORY + HKASK_HF_DATASET_PATH) and written to a local
# path before `ludwig train` runs. Ludwig reads it as a CSV/JSONL table.
dataset:
  path: {{ dataset_path }}
  file: {{ data_files }}
{% else %}
dataset:
  path: {{ dataset_path }}
{% endif %}

# Training
trainer:
  type: {{ trainer_type | default("finetune") }}
  epochs: {{ num_epochs | default(2) }}
  learning_rate: {{ learning_rate | default(0.0001) }}
  batch_size: {{ micro_batch_size | default(1) }}
  gradient_accumulation_steps: {{ gradient_accumulation_steps | default(16) }}
{% if warmup_steps %}
  learning_rate_scheduler:
    warmup_steps: {{ warmup_steps }}
{% endif %}
{% if lr_scheduler %}
    decay: {{ lr_scheduler }}
{% endif %}
{% if weight_decay and weight_decay > 0 %}
  weight_decay: {{ weight_decay }}
{% endif %}
{% if max_grad_norm %}
  max_grad_norm: {{ max_grad_norm }}
{% endif %}
{% if val_set_size %}
  validation_split: {{ val_set_size }}
{% endif %}

{% if sequence_len %}
preprocessing:
  text:
    max_sequence_length: {{ sequence_len }}
{% endif %}

backend:
  type: local

output_dir: {{ output_dir | default("/workspace/outputs") }}
