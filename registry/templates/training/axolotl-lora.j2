# Auto-generated by hKask Training Server (harness: axolotl)
# Rendered from registry/templates/training/axolotl-lora.j2
# Evolvable via gpa-evolution / skill-maintenance — no Rust recompile needed.
base_model: {{ base_model }}
adapter: lora
load_in_4bit: {{ load_in_4bit | default("false") }}
load_in_8bit: false
trust_remote_code: true

sequence_len: {{ sequence_len | default(4096) }}
bf16: true

{% if peft_init_lora_weights %}
# PiSSA — SVD-based LoRA initialization from principal singular values.
# Gives 30-50% faster convergence. Must keep dropout=0.
lora_r: {{ lora_r }}
lora_alpha: {{ lora_alpha }}
lora_dropout: 0
peft_init_lora_weights: {{ peft_init_lora_weights }}
{% else %}
lora_r: {{ lora_r }}
lora_alpha: {{ lora_alpha }}
lora_dropout: {{ lora_dropout | default(0) }}
{% endif %}
lora_target_modules:
  - q_proj
  - k_proj
  - v_proj
  - o_proj
  - gate_proj
  - up_proj
  - down_proj

datasets:
  - path: {{ dataset_path }}
    type: chat_template
{% if data_files %}
    data_files: {{ data_files }}
{% endif %}

# Training
num_epochs: {{ num_epochs | default(2) }}
learning_rate: {{ learning_rate | default(0.0001) }}
warmup_steps: {{ warmup_steps | default(100) }}
micro_batch_size: {{ micro_batch_size | default(1) }}
eval_batch_size: 1
gradient_accumulation_steps: {{ gradient_accumulation_steps | default(16) }}
gradient_checkpointing: true
lr_scheduler: {{ lr_scheduler | default("cosine") }}
weight_decay: {{ weight_decay | default(0.01) }}
max_grad_norm: {{ max_grad_norm | default(0.3) }}
optim: {{ optim | default("adamw_8bit") }}

# Eval
val_set_size: {{ val_set_size | default(0.0012) }}
eval_steps: {{ eval_steps | default(200) }}
save_steps: {{ save_steps | default(200) }}
save_total_limit: {{ save_total_limit | default(5) }}
early_stopping_patience: {{ early_stopping_patience | default(25) }}

# Optimizations
liger_kernel: {{ liger_kernel | default("true") }}
flash_attention: {{ flash_attention | default("false") }}
cut_cross_entropy: {{ cut_cross_entropy | default("true") }}

output_dir: {{ output_dir | default("/workspace/outputs") }}
strict: false