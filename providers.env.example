# hKask Inference Provider Configuration
# ──────────────────────────────────────────────────────────────────
#
# ⚠️  IMPORTANT: When you run `kask keystore load --path providers.env --shred`,
#     this file will be PERMANENTLY DELETED after keys are loaded into your
#     OS keychain. This keeps your keys safe — no plaintext on disk.
#
#     BEFORE running setup:
#     • Save a backup of this file somewhere secure (password manager,
#       encrypted USB, your local machine — not this server).
#     • You will NOT be able to recover keys from this file afterward.
#
#     The system will ask for explicit confirmation before deleting.
# ──────────────────────────────────────────────────────────────────
#
# Copy this file to providers.env, fill in your API keys, then run:
#
#   kask keystore load --path providers.env --shred
#
# This loads keys into your OS keychain and (with --shred) securely
# deletes the plaintext file after you confirm.
#
# You can also load without shredding:
#   kask keystore load --path providers.env
# (Keys go to keychain; you delete the file yourself when ready.)
# ──────────────────────────────────────────────────────────────────

# ── Required: at least one provider API key ──────────────────────

# DeepInfra (recommended — wide model catalog, per-token pricing)
# https://deepinfra.com/
DI_API_KEY=
# Alias: DEEPINFRA_API_KEY (either works)
# DEEPINFRA_API_KEY=

# Together AI (cloud — inference + fine-tuning)
# https://together.ai/
TOGETHER_API_KEY=

# fal.ai (optional — specialized vision/OCR models)
# https://fal.ai/
# FA_API_KEY=
# Alias: FAL_KEY, HKASK_FAL_API_KEY (any works)
# FAL_KEY=
# HKASK_FAL_API_KEY=
# ═══════════════════════════════════════════════════════════════════
# OAuth Providers — User Sign-In (at least one required)
#
# Create OAuth apps before filling these in.
# See: docs/guides/admin-install-guide.md
# ═══════════════════════════════════════════════════════════════════

# GitHub OAuth
# 1. Go to github.com/settings/developers → New OAuth App
# 2. Homepage URL: https://hkask.your-domain.com
# 3. Callback URL: https://hkask.your-domain.com/auth/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Google OAuth (optional)
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth client ID → Web application
# 3. Authorized redirect URIs: https://hkask.your-domain.com/auth/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=


# Hugging Face (optional — inference + model access)
# https://huggingface.co/
# HF_TOKEN=

# ── Provider Base URLs (override defaults) ─────────────────────────

# DeepInfra base URL (default: https://api.deepinfra.com/v1)
# DI_BASE_URL=

# fal.ai base URL (default: https://fal.run)
# FA_BASE_URL=

# Together base URL (default: https://api.together.xyz/v1)
# TG_BASE_URL=

# ── Training Cloud Providers (optional) ────────────────────────────

# Baseten — serverless GPU inference + fine-tuning
# https://baseten.co/
# BASETEN_API_KEY=
# BASETEN_PROJECT_ID=
# BASETEN_GPU="H100"
# BASETEN_GPU_COUNT=1

# RunPod — GPU cloud for training + inference
# https://runpod.io/
# RUNPOD_API_KEY=
# RUNPOD_TEMPLATE_ID=
# RUNPOD_GPU_TYPE_ID="NVIDIA H100"
# RUNPOD_MIN_MEMORY_GB=80
# RUNPOD_MIN_VCPU_COUNT=16
# RUNPOD_CONTAINER_DISK_GB=100

# ── Default provider for unprefixed model names ──────────────────
# Accepted values: DI, TG, FA
# When set, models without a prefix (e.g., "deepseek-v4-pro") route
# to this provider automatically.
HKASK_DEFAULT_PROVIDER=DI

# ── Default models (no prefix needed — provider adds it) ─────────

# Generation model (chat, composition, reasoning)
HKASK_DEFAULT_MODEL=deepseek-v4-pro

# Embedding model (vector search, semantic memory)
HKASK_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Classifier model (section type detection, triple extraction)
# HKASK_CLASSIFIER_MODEL=meta-llama/Llama-3.1-8B-Instruct

# OCR model (document text extraction — vision-capable required)
# HKASK_OCR_MODEL=FA/nemotron-parse

# ── MCP Server API Keys ──────────────────────────────────────────

# EOD Historical Data (EODHD) — Global company financial data (70+ exchanges)
# https://eodhd.com/
HKASK_EODHD_API_KEY=

# ── Model Override ─────────────────────────────────────────────────

# Override the model used for a specific inference call
# (used internally by the inference router; set per-request)
# INFERENCE_MODEL=
