{# Doc-Knowledge: Extract Markdown #}
{# Extract text and image references from markdown content #}

{% if not content %}
  {{ raise_error("doc_knowledge.invalid_input", "content is required") }}
{% endif %}

{% set label = label | default("input") %}

{# Parse markdown into pages #}
{% set pages = namespace(value=[]) %}
{% set image_refs = namespace(value=[]) %}

{# Simple markdown parsing - extract headings and images #}
{% for line in content.split('\n') %}
  {% if line.startswith('#') %}
    {% set pages.value = pages.value + [{'type': 'heading', 'text': line}] %}
  {% elif line.startswith('![') %}
    {% set image_refs.value = image_refs.value + [line] %}
  {% else %}
    {% set pages.value = pages.value + [{'type': 'text', 'text': line}] %}
  {% endif %}
{% endfor %}

{# Build full text #}
{% set full_text = pages.value | map(attribute='text') | join('\n') %}

{# Result #}
result:
  label: {{ label }}
  full_text_length: {{ full_text | length }}
  page_count: {{ pages.value | length }}
  image_ref_count: {{ image_refs.value | length }}
  image_refs: {{ image_refs.value }}

{# CNS span emission #}
span:
  namespace: cns.tool.doc_knowledge_extract_markdown
  phase: observe
  observation:
    label: {{ label }}
    content_length: {{ content | length }}
    outcome: extracted
