{# Doc-Knowledge: Extract HTML #}
{# Extract text from HTML content #}

{% if not content %}
  {{ raise_error("doc_knowledge.invalid_input", "content is required") }}
{% endif %}

{% set label = label | default("input") %}

{# Simple HTML text extraction - strip tags #}
{% set text_content = namespace(value="") %}
{% set title = namespace(value="") %}

{# Extract title #}
{% if '<title>' in content %}
  {% set start = content.index('<title>') + 7 %}
  {% set end = content.index('</title>', start) %}
  {% set title.value = content[start:end] %}
{% endif %}

{# Extract body text - simple tag stripping #}
{% set text_content.value = content | replace('<[^>]*>', '') | replace('\n', ' ') | trim %}

{# Result #}
result:
  label: {{ label }}
  title: {{ title.value }}
  full_text_length: {{ text_content.value | length }}
  full_text_preview: {{ text_content.value[:200] }}

{# CNS span emission #}
span:
  namespace: cns.tool.doc_knowledge_extract_html
  phase: observe
  observation:
    label: {{ label }}
    content_length: {{ content | length }}
    outcome: extracted
