{# Doc-Knowledge: Detect Format #}
{# Detect document format from path or content #}

{% if not path %}
  {{ raise_error("doc_knowledge.invalid_input", "path is required") }}
{% endif %}

{# Detect from file extension #}
{% set extension = path.split('.')[-1].lower() %}

{% if extension in ["md", "markdown"] %}
  {% set content_type = "Markdown" %}
  {% set mime = "text/markdown" %}
{% elif extension in ["html", "htm"] %}
  {% set content_type = "Html" %}
  {% set mime = "text/html" %}
{% elif extension == "pdf" %}
  {% set content_type = "Pdf" %}
  {% set mime = "application/pdf" %}
{% elif extension in ["docx", "doc"] %}
  {% set content_type = "Word" %}
  {% set mime = "application/vnd.openxmlformats-officedocument.wordprocessingml.document" %}
{% elif extension in ["xlsx", "xls"] %}
  {% set content_type = "Excel" %}
  {% set mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" %}
{% else %}
  {{ raise_error("doc_knowledge.unsupported_format", "Unsupported format: " + extension) }}
{% endif %}

{# Result #}
result:
  path: {{ path }}
  extension: {{ extension }}
  content_type: {{ content_type }}
  mime: {{ mime }}
  supported: true

{# CNS span emission #}
span:
  namespace: cns.tool.doc_knowledge_detect_format
  phase: observe
  observation:
    path: {{ path }}
    content_type: {{ content_type }}
    outcome: detected
