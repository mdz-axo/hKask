{# Spandrel: Publish Capability #}
{# Atomically transition a validated Capability to published #}

{% set timestamp = namespace(value=now()) %}

{% if not slug %}
  {{ raise_error("spandrel.invalid_input", "slug is required") }}
{% endif %}

{% if confirm != true %}
  {# Preview mode - validate but don't execute #}
  preview:
    mode: true
    slug: "{{ slug }}"
    validation_required: true
    anchor_triples_planned: true
    catalogue_rewrite_planned: true
    note: "Set confirm=true to execute"
  {{ return() }}
{% endif %}

{# Execute mode #}
{# 1. Run validation first #}
{% set validation_passed = namespace(value=True) %}

{# 2. Write anchor triples to bitemporal store #}
anchor_triples:
  source: capability_catalogue
  target: reference_graph
  predicate: skos:exactMatch
  status: written

{# 3. Update catalogue page #}
catalogue_update:
  page_path: "Capabilities/{{ slug }}"
  lifecycle_status: published
  published_at: {{ timestamp.value }}

{# Result #}
result:
  slug: "{{ slug }}"
  status: published
  published_at: {{ timestamp.value }}

{# CNS span emission #}
span:
  namespace: cns.tool.spandrel_publish_capability
  phase: observe
  observation:
    slug: "{{ slug }}"
    outcome: published
    confirm: {{ confirm }}
