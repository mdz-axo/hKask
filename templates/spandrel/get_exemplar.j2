{# Spandrel: Get Exemplar #}
{# Read an Exemplar page #}

{% if not slug %}
  {{ raise_error("spandrel.invalid_input", "slug is required") }}
{% endif %}

{# Build response #}
exemplar:
  slug: "{{ slug }}"
  page_path: "Exemplars/{{ slug }}"
  include_legal_name: {{ include_private_fields | default(false) }}
  status: retrieved

{# CNS span emission #}
span:
  namespace: cns.tool.spandrel_get_exemplar
  phase: observe
  observation:
    slug: "{{ slug }}"
    outcome: retrieved
    privileged_read: {{ include_private_fields | default(false) }}
