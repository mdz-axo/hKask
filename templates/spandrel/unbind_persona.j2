{# Spandrel: Unbind Persona #}
{# Close an EmbodimentBinding by writing unbound_at #}

{% set timestamp = namespace(value=now()) %}

{% if not binding_id %}
  {{ raise_error("spandrel.invalid_input", "binding_id is required") }}
{% endif %}

{% set unbound_at = at | default(timestamp.value) %}

{# Close binding #}
binding_update:
  binding_id: {{ binding_id }}
  unbound_at: {{ unbound_at }}
  status: closed

{# Result #}
result:
  binding_id: {{ binding_id }}
  unbound_at: {{ unbound_at }}
  status: unbound
  was_already_unbound: false

{# CNS span emission #}
span:
  namespace: cns.tool.spandrel_unbind_persona
  phase: observe
  observation:
    binding_id: {{ binding_id }}
    outcome: unbound
