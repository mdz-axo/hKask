# =============================================================================
# Company Researcher — Pipeline Environment
# =============================================================================
# Source this file before running any pipeline step:
#   source corpus/env/pipeline.env
#
# All tunable parameters live here. Scripts reference these via ${VAR:-default}.
# =============================================================================

# ── Model & Training Provider ───────────────────────────────────────────────
export HKASK_BASE_MODEL="unsloth/Qwen3.6-27B"
export HKASK_TRAINING_PROVIDER="runpod"
export HKASK_TRAINING_FRAMEWORK="unsloth"


# ── Model Loading (BF16 LoRA only — QLoRA not recommended for Qwen3.5/3.6) ──
export HKASK_LOAD_IN_4BIT="false"
export HKASK_LOAD_IN_16BIT="true"    # BF16 LoRA — recommended for Qwen3.5/3.6
export HKASK_FULL_FINETUNING="false" # 224GB needed; LoRA uses 56GB
# ── LoRA Configuration (from docs/reference/qwen36-training-hyperparameters.md) ──
export HKASK_LORA_RANK=64
export HKASK_LORA_ALPHA=64
export HKASK_LORA_DROPOUT=0
export HKASK_LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export HKASK_GRADIENT_CHECKPOINTING="unsloth"

# ── Training Hyperparameters ────────────────────────────────────────────────
export HKASK_LEARNING_RATE="2.0e-4"
export HKASK_EPOCHS=3
export HKASK_BATCH_SIZE=1
export HKASK_GRADIENT_ACCUMULATION_STEPS=4
export HKASK_MAX_SEQ_LENGTH=4096
# warmup_steps replaces warmup_ratio (deprecated in transformers 5.2+)
export HKASK_WARMUP_STEPS=672           # 5% of ~13,437 expected steps
export HKASK_LR_SCHEDULER="cosine"
export HKASK_OPTIMIZER="adamw_8bit"
export HKASK_WEIGHT_DECAY="0.01"
export HKASK_MAX_GRAD_NORM="0.3"
export HKASK_PRECISION="bf16"

# ── Evaluation & Checkpointing ──────────────────────────────────────────────
export HKASK_EVAL_STEPS=200
export HKASK_SAVE_STEPS=400
export HKASK_EARLY_STOPPING_PATIENCE=5
export HKASK_SAVE_TOTAL_LIMIT=3

# ── Environment (OOM prevention) ────────────────────────────────────────────
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
export HF_DEACTIVATE_ASYNC_LOAD="1"

# ── Data Mix (75/25 reasoning/chat to preserve Qwen3 thinking) ──────────────
export HKASK_REASONING_RATIO="0.75"
export HKASK_REASONING_DATASET="corpus/qa_pairs/train_chat.jsonl"
export HKASK_CHAT_DATASET="mlabonne/FineTome-100k"

# ── RunPod Infrastructure ───────────────────────────────────────────────────
# Note: the Rust training host reads RUNPOD_GPU_TYPE_ID (full RunPod GPU type
# display name, e.g. "NVIDIA A100-SXM4-80GB"), not RUNPOD_GPU_TYPE.
export RUNPOD_GPU_TYPE_ID="NVIDIA A100-SXM4-80GB"
export RUNPOD_GPU_COUNT=1
export RUNPOD_CONTAINER_DISK_GB=60
export RUNPOD_VOLUME_GB=200
export RUNPOD_DOCKER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
export RUNPOD_POD_INACTIVITY_TIMEOUT=14400
export RUNPOD_AUTO_TERMINATE="true"



# ── QA Generation ───────────────────────────────────────────────────────────
export QA_PROMPTS_PER_CHUNK=3
export MIN_INSTRUCTION_LENGTH=30
export MIN_OUTPUT_LENGTH=50
export MIN_SALIENCE="0.05"
export MIN_CONCEPTS=2
export QA_GENERATION_CONCURRENCY=10
export QA_GENERATION_WORKERS=3

# ── QA Selection ────────────────────────────────────────────────────────────
export TARGET_QAS_PER_LEVEL=1000
export TRAIN_SPLIT_RATIO="0.85"
export RANDOM_SEED=42

# ── Ingestion ───────────────────────────────────────────────────────────────
export DEDUP_THRESHOLD="0.92"

# ── Bloom Taxonomy (even 20% distribution) ──────────────────────────────────
export BLOOM_TYPE_DISTRIBUTION="20,20,20,20,20"

# ── Corpus Paths ────────────────────────────────────────────────────────────
export CORPUS_SOURCE_DIR="/home/mdz-axolotl/Clones/Library/Researcher"
export CORPUS_EXTRACTED_DIR="corpus/extracted/researcher"
export CORPUS_CHUNKS_JSONL="corpus/chunks/chunks.jsonl"
export CORPUS_TAGGED_JSONL="corpus/chunks/tagged_chunks.jsonl"
export CORPUS_PROMPTS_JSONL="corpus/qa_pairs/prompts_bloom.jsonl"
export CORPUS_MEMORY_DB="corpus/memory/corpus_memory.db"
export CORPUS_PASSPHRASE="hkask-default-passphrase-2024"
export CORPUS_REPLICA_CONFIG="corpus/replica/john-brooks.yaml"

# ── Output Paths ────────────────────────────────────────────────────────────
export OUTPUT_TRAIN_ALPACA="corpus/qa_pairs/train.jsonl"
export OUTPUT_VAL_ALPACA="corpus/qa_pairs/val.jsonl"
export OUTPUT_TRAIN_CHAT="corpus/qa_pairs/train_chat.jsonl"
export OUTPUT_VAL_CHAT="corpus/qa_pairs/val_chat.jsonl"
export OUTPUT_TEST_CHAT="corpus/qa_pairs/test_chat.jsonl"

# ── Qwen3.6 Thinking Mode ────────────────────────────────────────────────
# Qwen3.6 thinks by default. For Company Researcher (direct investment
# answers), use non-thinking instruct mode.
export QWEN_ENABLE_THINKING="false"
export QWEN_PRESERVE_THINKING="false"

# ── System Prompt (embedded in Qwen3.6 chat template) ───────────────────────
export SYSTEM_PROMPT="You are a Business and Economics Researcher. You analyze the gap between what organizations, markets, and systems are capable of and what they actually achieve. Your analysis draws on economic theory (transaction costs, agency, information asymmetry), systems thinking (feedback loops, emergence, path dependence), computing principles (information theory, algorithmic efficiency), scientific method (empirical evidence, falsifiability), and institutional analysis (culture, governance, historical context). Your core question: What is the economic significance of unrealized potential? Identify the capability-performance gap — the space between what a system COULD achieve given its resources and what it ACTUALLY achieves. Explain why the gap exists and how it might be closed. Be precise, cite sources, and acknowledge the limits of your analysis."

echo "Pipeline environment loaded."
echo "  Model:    $HKASK_BASE_MODEL"
echo "  Provider: $HKASK_TRAINING_PROVIDER ($HKASK_TRAINING_FRAMEWORK)"
echo "  LoRA:     r=$HKASK_LORA_RANK α=$HKASK_LORA_ALPHA"
echo "  QAs:      ${TARGET_QAS_PER_LEVEL}/level × 5 = $((TARGET_QAS_PER_LEVEL * 5)) total"

# ── Qwen3.6 Thinking Mode (instruct/non-thinking for Company Researcher) ──
export QWEN_ENABLE_THINKING="false"          # Non-thinking for direct answers
export QWEN_PRESERVE_THINKING="false"        # Don't retain thinking traces

# ── Unsloth-Specific Training Configuration ─────────────────────────────────
# Chat template: Qwen3.6 uses <|im_start|>role\n...<|im_end|> format.
# Unsloth doesn't have a dedicated "qwen-3.6" template yet. Use "chatml"
# which matches Qwen's token format exactly.
export UNSLOTH_CHAT_TEMPLATE="chatml"

# Dataset format: "messages" (ChatML/OpenAI style) or "conversations" (ShareGPT)
# Our train_chat.jsonl uses messages format — correct for Unsloth.
export UNSLOTH_DATASET_FORMAT="messages"

# Multi-turn conversation merging: merges N single-turn QAs into conversations.
# Set 0 for Company Researcher (single-turn Q&A is appropriate).
export UNSLOTH_CONVERSATION_EXTENSION=0

# ── Qwen3.6-Specific Idiosyncrasies ─────────────────────────────────────────
# Qwen3.6 has 256K native context (extendable to 1M via YaRN).
# Training at 4096 seq_len — auto-reduced to P95×1.2 if over-provisioned.
export QWEN_MAX_CONTEXT=262144

# Non-thinking (instruct) generation params per Qwen3.6 README
export QWEN_TEMPERATURE="0.7"
export QWEN_TOP_P="0.8"
export QWEN_TOP_K="20"
export QWEN_PRESENCE_PENALTY="1.5"
export QWEN_MIN_P="0.0"

# ── RunPod Pod Configuration ───────────────────────────────────────────────
# GPU selection: A100-80GB for 27B BF16 LoRA (56GB VRAM needed).
# H100 is ~2x faster but costs more. A100 SXM preferred over PCIe.
export RUNPOD_GPU="NVIDIA A100-SXM4-80GB"

# Docker image with Unsloth pre-installed. Custom image recommended
# to avoid pip install overhead on each pod start.
export RUNPOD_DOCKER="runpod/pytorch:2.6.0-py3.11-cuda12.8.1-devel-ubuntu22.04"

# Volume mount path for model weights + HF cache + outputs
export RUNPOD_VOLUME_PATH="/workspace"

# Pod template: use on-demand (not spot) for training stability
export RUNPOD_POD_TYPE="on-demand"
export RUNPOD_BID_PRICE=""   # Empty = on-demand pricing

# Auto-destroy on training completion (saves cost)
export RUNPOD_AUTO_DESTROY="true"
export RUNPOD_DESTROY_GRACE_SECS=60

# ── Checkpointing ───────────────────────────────────────────────────────────
# Save to RunPod volume for persistence across pod restarts
export HKASK_CHECKPOINT_DIR="/workspace/checkpoints"
export HKASK_OUTPUT_DIR="/workspace/outputs"
export HKASK_LOGGING_DIR="/workspace/logs"

# ── CRITICAL: Chat Template Configuration ───────────────────────────────────
# Qwen3.6's Jinja2 chat template defaults enable_thinking=TRUE.
# If NOT explicitly set to False during training tokenization, the template
# wraps every assistant response with <think>...</think> tags.
# Since our Company Researcher QAs have NO reasoning_content, this produces
# empty thinking blocks → training corruption.
# FIX: Pass enable_thinking=False when applying chat template during training.
# In Unsloth: tokenizer.apply_chat_template(messages, enable_thinking=False, add_generation_prompt=False)
# In SFTTrainer: TrainingArguments(chat_template_kwargs={"enable_thinking": False})
export QWEN_CHAT_TEMPLATE_KWARGS='{"enable_thinking": false, "add_generation_prompt": false}'

# ── Required Software Versions (from working Qwen3.6 27B fine-tunes) ─────────
# Source: samscrack/Qwen3.6-27B-Opus-CoT-S1-Hermes-S2-SFT (verified working)
# Source: Unsloth issue #5758 — "transformers>=5.2.0 required for Qwen3.5+"
export REQUIRED_TRANSFORMERS="5.2.0"
export REQUIRED_UNSLOTH="2026.4.7"
export REQUIRED_TRL="0.22.2"
export REQUIRED_PEFT="0.19.1"
export REQUIRED_TORCH="2.8.0"
export REQUIRED_DATASETS="4.3.0"  # >=3.4.1,<4.4.0 for Unsloth compatibility

# ── Known Qwen3.6 Training Bugs & Workarounds ──────────────────────────────
# Bug #1: transformers<5.2.0 causes silent failures with Qwen3.5+
#   Fix: pip install --upgrade "transformers>=5.2.0"
# Bug #2: lora_dropout>0 disables Unsloth Triton kernels (2x slower)
#   Fix: lora_dropout=0 (already set)
# Bug #3: QLoRA not recommended for Qwen3.5/3.6 (quantization error)
#   Fix: load_in_16bit=True, load_in_4bit=False (already set)
# Bug #4: enable_thinking defaults True in chat template → empty <think> blocks
#   Fix: chat_template_kwargs={"enable_thinking": false} (already set)
# Bug #5: High CPU/RAM during weight loading without HF_DEACTIVATE_ASYNC_LOAD=1
#   Fix: Already set in env
# Bug #6: Fragmentation OOM without PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
#   Fix: Already set in env
# Bug #7: NVFP4/MTP-GGUF variants are inference-only, NOT trainable
#   Fix: We use unsloth/Qwen3.6-27B (correct BF16 training variant)

# ── Tokenizer-Specific Settings ─────────────────────────────────────────────
# Qwen3.6 uses <|im_start|> and <|im_end|> as BOS/EOS markers.
# add_bos_token is false — the chat template handles this.
# Padding side should be 'right' for training (default).
export TOKENIZER_PADDING_SIDE="right"
export TOKENIZER_TRUNCATION_SIDE="right"

# ── LoRA Merge Warning ─────────────────────────────────────────────────────
# After training, merge LoRA weights into base model for inference.
# Unsloth: model.save_pretrained_merged("output", tokenizer, save_method="merged_16bit")
# DO NOT use save_method="lora" for deployment — requires PEFT at inference time.

# ── Hugging Face Artifact Registry ───────────────────────────────────────────
# Hugging Face is the canonical, private registry for versioned embedding
# snapshots, accepted QA datasets, training manifests, and LoRA adapters.
# The active vector index remains the local encrypted SQLite/sqlite-vec database.
# Leave HKASK_HF_ARTIFACT_OWNER empty to resolve the authenticated HF account.
export HKASK_ARTIFACT_STORE="huggingface"
export HKASK_HF_ARTIFACT_OWNER="${HKASK_HF_ARTIFACT_OWNER:-}"
export HKASK_HF_DATASET_REPO="${HKASK_HF_DATASET_REPO:-hkask-capabilities-researcher-artifacts}"
export HKASK_HF_MODEL_REPO="${HKASK_HF_MODEL_REPO:-hkask-capabilities-researcher-lora}"
export HKASK_HF_PRIVATE="true"
export HKASK_HF_UPLOAD_RAW_SOURCES="false"
export HKASK_EMBEDDING_STORE="local_sqlite"
export HKASK_HF_PUBLISH_EMBEDDING_SNAPSHOTS="true"
export HKASK_HF_PUBLISH_ACCEPTED_QAS="true"
export HKASK_HF_PUBLISH_TRAINING_MANIFESTS="true"
export HKASK_HF_PUBLISH_LORA_ADAPTERS="true"

# ── API Keys & Secrets (set externally, NOT committed) ──────────────────────
# These must be set in the environment before sourcing this file.
# They are NOT stored in this file or emitted in logs.
#   export TG_API_KEY="..."          # Together AI (inference)
#   export RUNPOD_API_KEY="..."      # RunPod GPU cloud
#   export HF_TOKEN="..."            # Hugging Face write/read token for Curator
#   export HF_RUNPOD_TOKEN="..."     # Hugging Face read token injected into RunPod
#   export CONTAINER_REGISTRY="..."  # Docker registry

# ── Inference Model Override ────────────────────────────────────────────────
# Default provider-prefixed model for docproc QA generation. A request-level `model`
# takes precedence; an empty value falls back to HKASK_DEFAULT_MODEL.
# Example (only if the configured provider exposes this model):
# export HKASK_QA_MODEL="OR/openai/gpt-5.6-terra"
export HKASK_QA_MODEL="${HKASK_QA_MODEL:-}"

# ── RunPod Template ─────────────────────────────────────────────────────────
# RunPod serverless template ID for LoRA training.
export RUNPOD_TEMPLATE_ID="${RUNPOD_TEMPLATE_ID:-}"

# ── Embedding Model ─────────────────────────────────────────────────────────
# Qwen3-Embedding-0.6B (1024-dim). Override for higher-fidelity embeddings.
export HKASK_EMBEDDING_MODEL="${HKASK_EMBEDDING_MODEL:-DI/Qwen/Qwen3-Embedding-0.6B}"

# ── ContentGuard (Security) ─────────────────────────────────────────────────
# The MCP docproc path uses ContentGuard for input/output safety scanning.
# The corpus-ingest direct path bypasses ContentGuard for speed.
# For investment literature (public domain, non-toxic), this is acceptable.
# For other domains, prefer the MCP path or enable guard in corpus-ingest.
export HKASK_ENABLE_CONTENT_GUARD="${HKASK_ENABLE_CONTENT_GUARD:-false}"

# ── RunPod OCR Endpoint (OLMOCR-2 via runsync) ───────────────────────────
# Synchronous OCR endpoint for scanned PDF processing.
export RUNPOD_OCR_ENDPOINT="https://api.runpod.ai/v2/hsldzov6932wf5/runsync"
export RUNPOD_OCR_STREAM="https://api.runpod.ai/v2/hsldzov6932wf5/stream"
export HKASK_OCR_MODEL="RP/kask-ocr"
