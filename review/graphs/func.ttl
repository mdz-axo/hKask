# Functional RDF layer — the user's mental model of hKask.
#
# Every concept here corresponds to a term defined in:
#   - AGENTS.md (project glossary)
#   - docs/architecture/PRINCIPLES.md
#   - docs/architecture/hKask-architecture-master.md
#   - docs/architecture/DDMVSS.md
#   - docs/architecture/domain-and-capability.md
#
# Realization: where the concept is implemented (crate/server/port/mcp_tool).
# Observable: the CNS span prefix or storage query that surfaces it.
# Decomposes_into: sub-concepts (depth ≤ 4; tighter than 7-level attenuation
#                  cap, because the review graph is a map, not the runtime).
# Open_question: refs into docs/OPEN_QUESTIONS.md.
#
# This file is hand-authored and authoritative for the review.
# It is the *one* source of truth for what hKask *means*. The tech.ttl
# file is the source of truth for where the meaning *lives*. The join
# in joined.ttl asserts that every meaning has at least one home.

@prefix concept: <https://hkask.dev/graph/concept#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# Class definitions
concept:Capability a rdfs:Class .
concept:Seam a rdfs:Class .
concept:Concept a rdfs:Class .
concept:OpenQuestion a rdfs:Class .

# --- Core identity & identity-bearing types ---
concept:webid a concept:Concept ; rdfs:label "WebID" .
concept:ocap a concept:Concept ; rdfs:label "OCAP (Object Capability)" .
concept:delegation_token a concept:Concept ; rdfs:label "DelegationToken" .
concept:ocap_boundary a concept:Concept ; rdfs:label "OcapBoundary" .
concept:attenuation a concept:Concept ; rdfs:label "Attenuation" .
concept:revocation a concept:Concept ; rdfs:label "Revocation" .
concept:sealer a concept:Concept ; rdfs:label "Sealer/Unsealer" .
concept:membrane a concept:Concept ; rdfs:label "Membrane" .
concept:brand a concept:Concept ; rdfs:label "Brand (unforgeable origin)" .
concept:revocable_forwarder a concept:Concept ; rdfs:label "Revocable Forwarder" .

# --- Storage & temporal model ---
concept:bitemporal_triple a concept:Concept ; rdfs:label "Bitemporal Triple" .
concept:valid_time a concept:Concept ; rdfs:label "valid_time" .
concept:transaction_time a concept:Concept ; rdfs:label "transaction_time" .
concept:visibility a concept:Concept ; rdfs:label "Visibility" .
concept:perspective a concept:Concept ; rdfs:label "Perspective" .
concept:snapshot a concept:Concept ; rdfs:label "Snapshot" .
concept:triple a concept:Concept ; rdfs:label "Triple" .

# --- Memory model ---
concept:episodic_memory a concept:Concept ; rdfs:label "Episodic Memory" .
concept:semantic_memory a concept:Concept ; rdfs:label "Semantic Memory" .
concept:memory_consolidation a concept:Concept ; rdfs:label "Memory Consolidation (episodic → semantic)" .
concept:memory_loop a concept:Concept ; rdfs:label "Memory Loop" .
concept:encodable a concept:Concept ; rdfs:label "Encodable (encoder) + Budget" .

# --- Cybernetic Nervous System ---
concept:cns a concept:Concept ; rdfs:label "CNS (Cybernetic Nervous System)" .
concept:variety a concept:Concept ; rdfs:label "Variety (Ashby)" .
concept:algedonic_alert a concept:Concept ; rdfs:label "Algedonic Alert" .
concept:backpressure a concept:Concept ; rdfs:label "Backpressure" .
concept:cybernetics_loop a concept:Concept ; rdfs:label "Cybernetics Loop" .
concept:communication_loop a concept:Concept ; rdfs:label "Communication Loop" .
concept:curation_loop a concept:Concept ; rdfs:label "Curation Loop" .
concept:override_cooldown a concept:Concept ; rdfs:label "Override Cooldown (120s)" .
concept:gas_budget a concept:Concept ; rdfs:label "Gas Budget" .
concept:governed_tool a concept:Concept ; rdfs:label "Governed Tool" .
concept:nu_event a concept:Concept ; rdfs:label "NuEvent" .
concept:span_category a concept:Concept ; rdfs:label "SpanCategory (decay lambda)" .
concept:decay a concept:Concept ; rdfs:label "Decay (half-life per category)" .
concept:spec_drift a concept:Concept ; rdfs:label "SpecDriftAlert" .

# --- Spec / Goal / DDMVSS ---
concept:spec a concept:Concept ; rdfs:label "Spec" .
concept:goal a concept:Concept ; rdfs:label "Goal" .
concept:criterion a concept:Concept ; rdfs:label "Criterion" .
concept:artifact a concept:Concept ; rdfs:label "Artifact" .
concept:sub_goal a concept:Concept ; rdfs:label "SubGoal (depth)" .
concept:ddmvss a concept:Concept ; rdfs:label "DDMVSS" .
concept:spec_curator a concept:Concept ; rdfs:label "SpecCurator" .
concept:merge_revise_discard a concept:Concept ; rdfs:label "Merge/Revise/Defer/Discard" .

# --- HHH / Persona ---
concept:hhh_pipeline a concept:Concept ; rdfs:label "HHH Pipeline (Render→Validate→Persona→Output)" .
concept:persona_constraint a concept:Concept ; rdfs:label "Persona Constraint" .

# --- Inference & Templates ---
concept:inference a concept:Concept ; rdfs:label "Inference (governed)" .
concept:prompt a concept:Concept ; rdfs:label "Prompt (depth/domain/structure)" .
concept:template a concept:Concept ; rdfs:label "Template" .
concept:registry a concept:Concept ; rdfs:label "Unified Registry (template_type discriminator)" .
concept:port a concept:Concept ; rdfs:label "Port (capability interface)" .

# --- Agent topology ---
concept:agent_pod a concept:Concept ; rdfs:label "AgentPod" .
concept:pod_lifecycle a concept:Concept ; rdfs:label "PodLifecycle (Populated→Registered→Activated→Deactivated)" .
concept:bot a concept:Concept ; rdfs:label "Bot (process execution, A2A)" .
concept:replicant a concept:Concept ; rdfs:label "Replicant (human assistance, H2A)" .
concept:curator a concept:Concept ; rdfs:label "Curator (system persona)" .
concept:ensemble a concept:Concept ; rdfs:label "Ensemble (multi-agent chat)" .

# --- Security primitives ---
concept:keystore a concept:Concept ; rdfs:label "Keystore (master key + HKDF-SHA256)" .
concept:hkdf a concept:Concept ; rdfs:label "HKDF-SHA256 derivation" .
concept:argon2id a concept:Concept ; rdfs:label "Argon2id" .
concept:ocap_secret a concept:Concept ; rdfs:label "OCAP signing key (per-WebID)" .
concept:russell_bridge a concept:Concept ; rdfs:label "Russell ACP Bridge" .

# --- MCP topology ---
concept:mcp a concept:Concept ; rdfs:label "MCP (Model Context Protocol)" .
concept:mcp_tool a concept:Concept ; rdfs:label "MCP Tool" .
concept:capability_gate a concept:Concept ; rdfs:label "Capability Gate (per-tool)" .

# --- Composition / relations ---
concept:attenuation
    concept:decomposes_into concept:revocation .
concept:ocap
    concept:decomposes_into concept:attenuation , concept:revocation , concept:brand .
concept:bitemporal_triple
    concept:decomposes_into concept:valid_time , concept:transaction_time , concept:visibility , concept:perspective .
concept:memory_consolidation
    concept:decomposes_into concept:episodic_memory , concept:semantic_memory .
concept:cns
    concept:decomposes_into concept:variety , concept:algedonic_alert , concept:backpressure ,
                            concept:cybernetics_loop , concept:communication_loop , concept:curation_loop ,
                            concept:governed_tool , concept:gas_budget .
concept:agent_pod
    concept:decomposes_into concept:pod_lifecycle , concept:ocap_boundary , concept:webid .
concept:goal
    concept:decomposes_into concept:criterion , concept:artifact , concept:sub_goal .
concept:hhh_pipeline
    concept:decomposes_into concept:persona_constraint .
concept:keystore
    concept:decomposes_into concept:hkdf , concept:argon2id , concept:ocap_secret .
concept:mcp
    concept:decomposes_into concept:mcp_tool , concept:capability_gate .
concept:nu_event
    concept:decomposes_into concept:span_category , concept:decay .

# --- Open questions (cross-cutting) ---
concept:ocap_secret_derivation a concept:OpenQuestion ;
    rdfs:label "OCAP secret: per-WebID HKDF vs. per-pod random?" .
concept:mcp_membrane a concept:OpenQuestion ;
    rdfs:label "MCP gateway: membrane or passthrough?" .
concept:spec_brand a concept:OpenQuestion ;
    rdfs:label "SpecId: brand or plain ID?" .
concept:override_cooldown_scope a concept:OpenQuestion ;
    rdfs:label "Override cooldown: per-issuer or global?" .
concept:lambda_for_category_visibility a concept:OpenQuestion ;
    rdfs:label "lambda_for_category: should be public?" .
concept:attenuation_depth_constant a concept:OpenQuestion ;
    rdfs:label "7-level attenuation cap: hard constant or configurable?" .
concept:goal_token_resurrection a concept:OpenQuestion ;
    rdfs:label "GoalCapabilityToken removal: any resurrection path?" .

# --- Open-question links from existing OQ doc ---
concept:ocap_secret_derivation
    concept:realized_by <docs/OPEN_QUESTIONS.md#F1> .
concept:russell_bridge
    concept:realized_by <docs/OPEN_QUESTIONS.md#F2> .
concept:agent_pod
    concept:realized_by <docs/OPEN_QUESTIONS.md#F3> .
concept:keystore
    concept:realized_by <docs/OPEN_QUESTIONS.md#F4> .
concept:goal
    concept:realized_by <docs/OPEN_QUESTIONS.md#F6> .

# --- Observability surface (CNS span namespaces) ---
concept:variety              concept:observable_via <cns.variety> .
concept:algedonic_alert      concept:observable_via <cns.algedonic> .
concept:backpressure         concept:observable_via <cns.cybernetics.backpressure> .
concept:cybernetics_loop     concept:observable_via <cns.cybernetics> .
concept:communication_loop   concept:observable_via <cns.cybernetics> .
concept:curation_loop        concept:observable_via <cns.curation> .
concept:spec_drift           concept:observable_via <cns.spec.drift> .
concept:agent_pod            concept:observable_via <cns.agent_pod> .
concept:pod_lifecycle        concept:observable_via <cns.agent_pod.activated> , <cns.agent_pod.deactivated> , <cns.agent_pod.registered> .
concept:inference            concept:observable_via <cns.inference> .
concept:prompt               concept:observable_via <cns.inference.prompt_depth> , <cns.inference.prompt_domain> , <cns.inference.prompt_structure> .
concept:persona_constraint   concept:observable_via <cns.hhh.persona> .
concept:governed_tool        concept:observable_via <cns.tool> .
concept:gas_budget           concept:observable_via <cns.cybernetics> .
concept:memory_consolidation concept:observable_via <cns.memory> .
concept:episodic_memory      concept:observable_via <cns.memory.episodic> .
concept:health               concept:observable_via <cns.health> .
