%% ERD #2 — OCAPBoundary ↔ OcapCapability ↔ DelegationToken
%% Source: crates/hkask-types/src/curation.rs:102, capability/mod.rs:245
%% Realization: concept:ocap → tech:hkask_types
%%
%% Cardinality notes:
%%   * OcapCapability has two variants: Token (typed, brand-checked) and
%%     String (legacy). The legacy form exists for backward compatibility
%%     and is a finding candidate (C6 / P6 — prefer deletion over compat).
%%   * DelegationToken attenuation: monotonically increasing per
%%     attenuation() call. A new token may not amplify the parent's
%%     max_attenuation. SYSTEM_MAX_RECURSION = 7 is a hard constant.
%%   * Revocation is centralized; no token can be re-issued under a
%%     previous attenuation. The MCP-OCAP server is the only writer
%%     of the revocation log.
%%   * attenuation is the only way to weaken a capability (Miller).
%%   * revocation is the only way to invalidate (Miller).

erDiagram
    OCAP_BOUNDARY ||--|| OCAP_CAPABILITY : "guards"
    OCAP_CAPABILITY ||--o{ DELEGATION_TOKEN : "mints / verifies"
    DELEGATION_TOKEN }o--|| WEBID : "issuer"
    DELEGATION_TOKEN }o--|| WEBID : "subject"
    DELEGATION_TOKEN }o--o{ REVOCATION_LOG : "checked against"
    DELEGATION_TOKEN ||--o{ DELEGATION_TOKEN : "attenuation(parent)"

    OCAP_BOUNDARY {
        OcapCapability capability "Token | String (legacy)"
        bool enforced
    }
    OCAP_CAPABILITY {
        string action "parse_capability: resource:action[:attenuation]"
        string resource "memory | ocap | ..."
    }
    DELEGATION_TOKEN {
        u8 attenuation_level "<= parent.attenuation_level + 1"
        u8 max_attenuation "<= 7 = SYSTEM_MAX_RECURSION"
        string issuer_webid
        string subject_webid
        datetime issued_at
        datetime expires_at
    }
    REVOCATION_LOG {
        string token_id
        datetime revoked_at
        string reason
    }
    WEBID {
        string uri
    }
