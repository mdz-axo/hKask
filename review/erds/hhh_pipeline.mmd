%% Class diagram #7 — HHH Pipeline
%% Source: crates/hkask-agents/src/{hhh_gate.rs, prompt_analysis.rs},
%%         crates/hkask-cli/src/repl/mod.rs
%% Realization: concept:hhh_pipeline → tech:hkask_agents
%%
%% Architecture notes:
%%   * 4 stages, in order: Render → Validate → Persona → Output.
%%   * Stage 4 (Persona) is the only stage with mutable filter state
%%     (loaded from bot_status() at init and /agent switch).
%%   * Each stage emits a tracing::span! in the cns.hhh.* namespace.
%%   * Persona constraint violations are STRIPPED, not raised. The
%%     stripped content is the output. The original is logged.
%%   * The pipeline is invoked once per prompt; per the v6 handoff,
%%     prompt depth/domain/structure analysis is performed in stage 2
%%     and emits cns.inference.prompt_depth/domain/structure.

classDiagram
    class HHHPipeline {
        +render(Prompt) RenderedPrompt
        +validate(RenderedPrompt) ValidatedPrompt
        +apply_persona(ValidatedPrompt) FilteredPrompt
        +output(FilteredPrompt) Output
    }
    class RenderStage {
        +template: Template
        +encode(Prompt) RenderedPrompt
    }
    class ValidateStage {
        +analyze_depth(Prompt) cns.inference.prompt_depth
        +analyze_domain(Prompt) cns.inference.prompt_domain
        +analyze_structure(Prompt) cns.inference.prompt_structure
        +check(RenderedPrompt) ValidatedPrompt
    }
    class PersonaFilter {
        -PersonaConstraints active
        +load(BotStatus)
        +strip_violations(ValidatedPrompt) FilteredPrompt
    }
    class OutputStage {
        +emit(FilteredPrompt) Output
    }
    class PersonaConstraints {
        +Vec~Rule~ rules
        +loaded_from "bot_status() / /agent"
    }

    HHHPipeline "1" *-- "1" RenderStage
    HHHPipeline "1" *-- "1" ValidateStage
    HHHPipeline "1" *-- "1" PersonaFilter
    HHHPipeline "1" *-- "1" OutputStage
    PersonaFilter "1" --> "1" PersonaConstraints : "uses"
