%% ERD #1 — AgentPod ↔ MemoryStoragePort
%% Source: crates/hkask-agents/src/pod/{mod.rs, types.rs, context.rs}
%% Realization: concept:agent_pod → tech:hkask_agents
%%
%% Cardinality notes (do not edit without updating the source-of-truth tests):
%%   * Populated is the initial state, set at construction.
%%   * Registered requires an ACP-runtime token mint.
%%   * Activated is what enables A2A / MCP access.
%%   * Deactivated is terminal; capabilities are revoked.
%%   * record_lifecycle_event() persists an episodic triple on every
%%     transition (OPEN_QUESTIONS F3); persistence failure is non-fatal
%%     (tracing::warn) but observable via the cns.agent_pod.* span.

erDiagram
    AGENT_POD ||--o{ EPISODIC_TRIPLE : "lifecycle_state ∈ {Populated, Registered, Activated, Deactivated}"
    AGENT_POD ||--|| OCAP_BOUNDARY : "enforced"
    AGENT_POD }o--|| WEBID : "owner"
    AGENT_POD ||--|| MEMORY_STORAGE_PORT : "record_lifecycle_event"
    OCAP_BOUNDARY ||--o{ DELEGATION_TOKEN : "attenuation_depth <= 7"

    AGENT_POD {
        string id "POD_ID"
        string state "PodLifecycleState"
        string webid "WebID"
    }
    EPISODIC_TRIPLE {
        string entity "pod:{id}"
        string attribute "lifecycle_state"
        string value "state"
        datetime valid_from
        datetime valid_to
        string visibility "Private"
    }
    OCAP_BOUNDARY {
        string capability "OcapCapability = Token | String"
        bool enforced "true"
    }
    DELEGATION_TOKEN {
        u8 attenuation_level "<= 7"
        u8 max_attenuation "SYSTEM_MAX_RECURSION = 7"
        string issuer "WebID"
        string subject "WebID"
    }
    MEMORY_STORAGE_PORT {
        string store "bitemporal triple + nu_event"
    }
    WEBID {
        string uri "hkask:webid:<...>"
    }
