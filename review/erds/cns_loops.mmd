%% Class diagram #6 — CNS loop wiring
%% Source: crates/hkask-cns/src/{cybernetics_loop.rs, set_points.rs,
%%                              dampener.rs, algedonic.rs, energy.rs}
%% Realization: concept:cns → tech:hkask_cns
%%
%% Architecture notes:
%%   * Three loops share one Arc<AtomicU64> queue-depth counter:
%%       Communication (writer)  ↔  Cybernetics (reader)  ↔  Curation (consumer)
%%     Lock-free, Relaxed ordering. Backpressure when depth exceeds
%%     DEFAULT_COMMUNICATION_BACKPRESSURE_THRESHOLD = QueueDepth(100.0)
%%     (set_points.rs:36 → hkask-types/src/cns.rs:63).
%%   * Override cooldown = 120s (dampener.rs:58). After any override
%%     passes dedup, ALL subsequent overrides within cooldown are
%%     suppressed. Cooldown is *global* (per Dampener instance, not
%%     per issuer) — see L5 finding override_cooldown_scope in FUTURE.md.
%%   * Algedonic alert thresholds (algedonic.rs:35,40):
%%       R-bar > 0.3  →  Warning  to Curator
%%       R-bar > 0.8  →  Critical to Human
%%   * SpecDriftAlert is a LoopPayload variant that flows through
%%     Communication to Curation's inbox. Curation's SpecCurator
%%     emits it when spec drift exceeds tolerance.

classDiagram
    class CommunicationLoop {
        +Arc~AtomicU64~ depth
        +push(LoopPayload)
        +drain_to_consumer() Vec~LoopPayload~
    }
    class CyberneticsLoop {
        -Arc~AtomicU64~ depth
        +run_cycle() RegulationDecision
        +emit_backpressure()
    }
    class CurationLoop {
        +inbox: Vec~LoopPayload~
        +process(SpecDriftAlert)
    }
    class Dampener {
        -Duration override_cooldown "120s"
        -Instant last_override
        +should_suppress() bool
    }
    class AlgedonicAlert {
        +f64 r_bar
        +Severity severity
    }
    class SetPoints {
        +QueueDepth communication_backpressure_threshold "100.0"
        +u32 max_iterations "100"
    }
    class QueueDepth {
        +f64 value
        +DEFAULT_BACKPRESSURE "100.0"
    }

    CommunicationLoop "1" --> "1" QueueDepth : "writes"
    CyberneticsLoop "1" --> "1" QueueDepth : "reads"
    CurationLoop ..> CommunicationLoop : "drains"
    CyberneticsLoop ..> Dampener : "suppress override?"
    CyberneticsLoop ..> AlgedonicAlert : "emits when r_bar > 0.3 / > 0.8"
    CurationLoop ..> AlgedonicAlert : "consumes Warning"
    CyberneticsLoop ..> SetPoints : "configured by"
