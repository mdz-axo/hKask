# Conduit Matrix homeserver configuration — rendered by envsubst at container start.
# Each pod runs its own Conduit sidecar for per-pod Matrix identity.

[global]
server_name = "${CONDUIT_SERVER_NAME:-localhost}"
address = "0.0.0.0"
port = 8008

[global.database]
backend = "sqlite"
path = "/data/conduit.db"

[global.registration]
enabled = false
