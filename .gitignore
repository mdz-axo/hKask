# Build artifacts
/target/
**/target/
**/target/debug/
*.rs.bk

# Fuzz corpus artifacts — runtime-generated by bolero/honggfuzz
**/__fuzz__/

# Mutation testing (cargo-mutants) output
mutants.out/
mutants.out.old/

# Rust
# Cargo.lock is tracked for reproducible binary builds

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Documentation archive — gitignored, kept on disk for personal reference
# Retired documents recoverable via: git log --diff-filter=D -- <path>
# See DOCUMENTATION_STANDARDS.md §3 for lifecycle policy
docs/archive/

# Style corpus download cache — populated by `kask embed-corpus run`
# Raw source texts cached to avoid re-downloading
registry/styles/**/.cache/*.txt
registry/styles/**/corpus-sources/

# Generated QA training corpus — regenerated by the qa-generation skill
# Large JSONL files (1–55 MB) that change every run; tracking them forces
# Zed's background git add to re-hash giant blobs (~2s each), which gets
# killed mid-write and orphans .git/index.lock. Also trips GitHub's 50 MB
# large-file warning. Keep on disk, never commit.
corpus/qa_pairs/

# General cache directory — transient downloaded content that may contain
# strings matching secret patterns (e.g., YouTube transcripts with URL params)
.cache/

# Agent runtime databases — local memory stores generated by `kask`
# These contain per-agent semantic/episodic memory and should never be committed
*.db
*.db.salt

# Agent runtime data — per-agent state generated by `kask`
# Contains local memory, identity, and session artifacts; never commit
agents/

# UserPod runtime data — per-pod state generated by `kask` (identity, dbs,
# threads). Databases are also covered by *.db above, but the directory
# itself (pod.webid, pod.kind, pod.name, threads/*.json) is runtime state.
**/userpods/

# Runtime data directory — databases, logs, and other generated artifacts
data/

# Personal format-shifted output (Kindle zips, etc.) — never commit
output/

# Python virtual environment (training tools) — not part of the Rust workspace
.venv-training/

# Distillation data — canonical copies live on HuggingFace
#   HF: Axolotl-Partners/qwen36-distill-opus-dsv4
distill_data/
raw_data/

# Ad-hoc artifacts (removed — data lives on HF, scripts in scripts/)
deploy/unsloth-training/
tmp_qa/

# Corrupt .git backups (never commit)
.git.corrupt-backup-*

# Embedding pipeline log — runtime output from `kask embed-corpus run`
corpus/embed_output.log
corpus/replica_build.log

# Smoke test corpus — local generated artifacts (dbs, chunks, tags)
corpus/smoke/
