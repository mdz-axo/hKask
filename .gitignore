# Build artifacts
/target/
**/target/
**/target/debug/
*.rs.bk

# Fuzz corpus artifacts — runtime-generated by bolero/honggfuzz
**/__fuzz__/

# Mutation testing (cargo-mutants) output
mutants.out/
mutants.out.old/

# Rust
# Cargo.lock is tracked for reproducible binary builds

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Documentation archive — gitignored, kept on disk for personal reference
# Retired documents recoverable via: git log --diff-filter=D -- <path>
# See DOCUMENTATION_STANDARDS.md §3 for lifecycle policy
docs/archive/

# Style corpus download cache — populated by `kask embed-corpus run`
# Raw source texts cached to avoid re-downloading
registry/styles/**/.cache/*.txt
registry/styles/**/corpus-sources/

# General cache directory — transient downloaded content that may contain
# strings matching secret patterns (e.g., YouTube transcripts with URL params)
.cache/

# Agent runtime databases — local memory stores generated by `kask`
# These contain per-agent semantic/episodic memory and should never be committed
*.db
*.db.salt

# Runtime data directory — databases, logs, and other generated artifacts
data/

# Personal format-shifted output (Kindle zips, etc.) — never commit
output/
