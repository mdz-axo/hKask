# ── DDMVSS Category Nodes ──────────────────────────────────────

:Domain         a :DDMVSSCategory .
:Capability     a :DDMVSSCategory .
:Interface      a :DDMVSSCategory .
:Composition    a :DDMVSSCategory .
:Trust          a :DDMVSSCategory .
:Observability  a :DDMVSSCategory .
:Persistence    a :DDMVSSCategory .
:Lifecycle      a :DDMVSSCategory .
:Curation       a :DDMVSSCategory .

