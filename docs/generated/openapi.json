{
  "openapi": "3.1.0",
  "info": {
    "title": "hKask API",
    "description": "A Minimal Viable Container for Agents - HTTP API",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.23.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "hKask API server"
    }
  ],
  "paths": {},
  "components": {
    "schemas": {
      "ArchiveEntry": {
        "type": "object",
        "description": "Archive entry response",
        "required": [
          "name",
          "path",
          "content",
          "template_type"
        ],
        "properties": {
          "content": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "template_type": {
            "type": "string"
          }
        }
      },
      "ArchiveRequest": {
        "type": "object",
        "description": "Archive repository request",
        "required": [
          "owner",
          "repo",
          "branch",
          "path"
        ],
        "properties": {
          "branch": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "repo": {
            "type": "string"
          }
        }
      },
      "ArchiveResponse": {
        "type": "object",
        "description": "Archive response",
        "required": [
          "crate_name",
          "git_sha",
          "templates"
        ],
        "properties": {
          "crate_name": {
            "type": "string"
          },
          "git_sha": {
            "type": "string"
          },
          "templates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArchiveEntry"
            }
          }
        }
      },
      "BotStatusReportResponse": {
        "type": "object",
        "description": "Bot status report response",
        "required": [
          "bot_name",
          "status",
          "issues"
        ],
        "properties": {
          "bot_name": {
            "type": "string"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_report": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ChatRequest": {
        "type": "object",
        "description": "Chat request sent to the Curator or a specified agent.\n\nThe `model` field allows switching the LLM at request time. When omitted,\nthe server default (qwen3:8b) is used. Use `GET /api/models` to discover\navailable models, and `GET /api/models/search?q=...` for fuzzy matching.",
        "required": [
          "input"
        ],
        "properties": {
          "input": {
            "type": "string",
            "description": "User input message"
          },
          "model": {
            "type": [
              "string",
              "null"
            ],
            "description": "Model override for inference (e.g., \"qwen3:8b\"). If unset, uses the server default."
          },
          "template_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional template ID to contextualize the prompt"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "description": "Chat response from the Curator or agent.\n\nThe `model` field echoes which LLM was used, confirming model switching.",
        "required": [
          "output",
          "template_id",
          "model"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model identifier used for inference"
          },
          "output": {
            "type": "string",
            "description": "Generated response text"
          },
          "template_id": {
            "type": "string",
            "description": "Template ID that was applied (or \"auto-select\")"
          }
        }
      },
      "CnsHealthResponse": {
        "type": "object",
        "description": "CNS health response",
        "required": [
          "overall_deficit",
          "critical_count",
          "warning_count",
          "healthy"
        ],
        "properties": {
          "critical_count": {
            "type": "integer",
            "minimum": 0
          },
          "healthy": {
            "type": "boolean"
          },
          "overall_deficit": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "warning_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "CnsVarietyResponse": {
        "type": "object",
        "description": "CNS variety response",
        "required": [
          "domains",
          "total_deficit",
          "counters"
        ],
        "properties": {
          "counters": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/VarietyCounterResponse"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "total_deficit": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "CreateGoalRequest": {
        "type": "object",
        "description": "Request to create a goal.",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "Goal text."
          },
          "visibility": {
            "type": [
              "string",
              "null"
            ],
            "description": "Visibility: private | shared | public. Defaults to private."
          }
        }
      },
      "CreatePodRequest": {
        "type": "object",
        "description": "Create pod request",
        "required": [
          "template",
          "persona_yaml"
        ],
        "properties": {
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "persona_yaml": {
            "type": "string"
          },
          "template": {
            "type": "string"
          }
        }
      },
      "CreatePodResponse": {
        "type": "object",
        "description": "Create pod response",
        "required": [
          "pod_id"
        ],
        "properties": {
          "pod_id": {
            "type": "string"
          }
        }
      },
      "DismissEscalationRequest": {
        "type": "object",
        "description": "Dismiss escalation request",
        "required": [
          "dismissed_by"
        ],
        "properties": {
          "dismissed_by": {
            "type": "string"
          }
        }
      },
      "DismissEscalationResponse": {
        "type": "object",
        "description": "Dismiss escalation response",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "EscalationEntryResponse": {
        "type": "object",
        "description": "Escalation entry response",
        "required": [
          "id",
          "template_id",
          "bot_id",
          "output",
          "confidence",
          "retry_count",
          "error_context",
          "created_at",
          "status"
        ],
        "properties": {
          "bot_id": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "double"
          },
          "created_at": {
            "type": "string"
          },
          "error_context": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "resolved_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "resolved_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "retry_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "status": {
            "type": "string"
          },
          "template_id": {
            "type": "string"
          }
        }
      },
      "EscalationStatsResponse": {
        "type": "object",
        "description": "Escalation stats response",
        "required": [
          "total",
          "pending",
          "resolved",
          "dismissed"
        ],
        "properties": {
          "dismissed": {
            "type": "integer",
            "format": "int64"
          },
          "pending": {
            "type": "integer",
            "format": "int64"
          },
          "resolved": {
            "type": "integer",
            "format": "int64"
          },
          "total": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "GoalListResponse": {
        "type": "object",
        "description": "A list of goals.",
        "required": [
          "goals"
        ],
        "properties": {
          "goals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoalResponse"
            }
          }
        }
      },
      "GoalResponse": {
        "type": "object",
        "description": "A goal as returned over the API.",
        "required": [
          "id",
          "text",
          "state",
          "visibility"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "visibility": {
            "type": "string"
          }
        }
      },
      "GrantCapabilityRequest": {
        "type": "object",
        "description": "Capability request",
        "required": [
          "capability"
        ],
        "properties": {
          "capability": {
            "type": "string"
          }
        }
      },
      "ListEscalationsResponse": {
        "type": "object",
        "description": "List escalations response",
        "required": [
          "escalations"
        ],
        "properties": {
          "escalations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EscalationEntryResponse"
            }
          }
        }
      },
      "ListPodsResponse": {
        "type": "object",
        "description": "List pods response",
        "required": [
          "pods"
        ],
        "properties": {
          "pods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PodStatusResponse"
            }
          }
        }
      },
      "MetacognitionStatusResponse": {
        "type": "object",
        "description": "Metacognition status response",
        "required": [
          "escalation_stats",
          "bot_reports"
        ],
        "properties": {
          "bot_reports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BotStatusReportResponse"
            }
          },
          "escalation_stats": {
            "$ref": "#/components/schemas/EscalationStatsResponse"
          }
        }
      },
      "ModelEntry": {
        "type": "object",
        "description": "A model available through Okapi.\n\nIncludes metadata from Okapi's `/api/tags` endpoint: model family,\nparameter count, quantization level, and disk size.",
        "required": [
          "name"
        ],
        "properties": {
          "family": {
            "type": [
              "string",
              "null"
            ],
            "description": "Model family (e.g., \"llama\", \"qwen2\")"
          },
          "name": {
            "type": "string",
            "description": "Model identifier (e.g., \"qwen3:8b\", \"llama3.1:70b\")"
          },
          "parameter_size": {
            "type": [
              "string",
              "null"
            ],
            "description": "Parameter count (e.g., \"8B\", \"70B\")"
          },
          "quantization_level": {
            "type": [
              "string",
              "null"
            ],
            "description": "Quantization level (e.g., \"Q4_0\", \"Q5_K_M\")"
          },
          "size_gb": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Model size in gigabytes"
          }
        }
      },
      "ModelListResponse": {
        "type": "object",
        "description": "Response containing available Okapi models.\n\nReturned by `GET /api/models` and `GET /api/models/search`.\nModel names from this response can be used as the `model` field\nin `POST /api/chat` requests.",
        "required": [
          "models",
          "count"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "description": "Total number of models in the list",
            "minimum": 0
          },
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelEntry"
            },
            "description": "List of available models"
          }
        }
      },
      "ModelSearchQuery": {
        "type": "object",
        "description": "Query parameters for fuzzy model search.\n\nThe `q` parameter performs case-insensitive substring matching\nagainst model names. For example, `q=llama` matches \"llama3.1:8b\",\n\"llama3.1:70b\", etc.",
        "required": [
          "q"
        ],
        "properties": {
          "q": {
            "type": "string",
            "description": "Fuzzy search query — matches model name (case-insensitive substring)"
          }
        }
      },
      "ParticipantEntryRequest": {
        "type": "object",
        "description": "Participant entry for standing session start",
        "required": [
          "agent",
          "type",
          "role",
          "description"
        ],
        "properties": {
          "agent": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Template domains this participant owns (e.g., `[\"cns\", \"storage\"]`).\nConverted to capability specs (`\"tool:<domain>:execute\"`) internally."
          },
          "role": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "ParticipantStatusResponse": {
        "type": "object",
        "description": "Participant status in standing session response",
        "required": [
          "name",
          "webid",
          "role",
          "description"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "webid": {
            "type": "string"
          }
        }
      },
      "PodStatusResponse": {
        "type": "object",
        "description": "Pod status response",
        "required": [
          "pod_id",
          "state",
          "webid",
          "agent_type",
          "template",
          "created_at"
        ],
        "properties": {
          "agent_type": {
            "type": "string"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "pod_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "webid": {
            "type": "string"
          }
        }
      },
      "ResolveEscalationRequest": {
        "type": "object",
        "description": "Resolve escalation request",
        "required": [
          "resolved_by"
        ],
        "properties": {
          "resolved_by": {
            "type": "string"
          }
        }
      },
      "ResolveEscalationResponse": {
        "type": "object",
        "description": "Resolve escalation response",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ResolveShaResponse": {
        "type": "object",
        "description": "SHA resolve response",
        "required": [
          "sha"
        ],
        "properties": {
          "sha": {
            "type": "string"
          }
        }
      },
      "SetGoalStateRequest": {
        "type": "object",
        "description": "Request to transition a goal's state.",
        "required": [
          "state"
        ],
        "properties": {
          "state": {
            "type": "string",
            "description": "Target state: pending | active | completed | blocked | abandoned."
          }
        }
      },
      "StandingStartRequest": {
        "type": "object",
        "description": "Standing session start request",
        "required": [
          "session_id",
          "name",
          "description",
          "initial_context",
          "participants"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "initial_context": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "participants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ParticipantEntryRequest"
            }
          },
          "session_id": {
            "type": "string"
          }
        }
      },
      "StandingStartResponse": {
        "type": "object",
        "description": "Standing session start response",
        "required": [
          "session_id",
          "description",
          "participant_count",
          "message"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "participant_count": {
            "type": "integer",
            "minimum": 0
          },
          "session_id": {
            "type": "string"
          }
        }
      },
      "StandingStatusResponse": {
        "type": "object",
        "description": "Standing session status response",
        "required": [
          "session_id",
          "description",
          "participant_count",
          "message_count",
          "participants"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "message_count": {
            "type": "integer",
            "minimum": 0
          },
          "participant_count": {
            "type": "integer",
            "minimum": 0
          },
          "participants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ParticipantStatusResponse"
            }
          },
          "session_id": {
            "type": "string"
          }
        }
      },
      "TemplateResponse": {
        "type": "object",
        "description": "Template response",
        "required": [
          "id",
          "template_type",
          "name",
          "description",
          "source_path",
          "lexicon_terms"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "lexicon_terms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "source_path": {
            "type": "string"
          },
          "template_type": {
            "type": "string"
          }
        }
      },
      "VarietyCounterResponse": {
        "type": "object",
        "description": "CNS variety counter response",
        "required": [
          "variety",
          "total",
          "entropy"
        ],
        "properties": {
          "entropy": {
            "type": "number",
            "format": "double"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "variety": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "templates",
      "description": "Template management"
    },
    {
      "name": "bots",
      "description": "Bot capability management"
    },
    {
      "name": "pods",
      "description": "Agent pod lifecycle management"
    },
    {
      "name": "mcp",
      "description": "MCP servers and tools"
    },
    {
      "name": "cns",
      "description": "CNS monitoring"
    },
    {
      "name": "chat",
      "description": "Curator chat interface"
    },
    {
      "name": "models",
      "description": "Okapi model catalog"
    },
    {
      "name": "curator",
      "description": "Curator escalation and metacognition"
    },
    {
      "name": "ensemble",
      "description": "Ensemble multi-agent coordination"
    },
    {
      "name": "git",
      "description": "Git archival and resolution"
    },
    {
      "name": "acp",
      "description": "ACP agent registration and management"
    },
    {
      "name": "goals",
      "description": "Goal coordination substrate (OCAP-gated)"
    }
  ]
}
