@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix hkask:   <https://hkask.mdz-axolotl.dev/ontology/> .
@prefix code:    <https://hkask.mdz-axolotl.dev/code/> .
@prefix reg:     <https://hkask.mdz-axolotl.dev/registry/> .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ONTOLOGY DEFINITIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

hkask:Crate a rdfs:Class ;
    rdfs:label "Crate" ;
    rdfs:comment "A Rust crate in the hKask workspace" .

hkask:Module a rdfs:Class ;
    rdfs:label "Module" ;
    rdfs:comment "A module within a crate" .

hkask:Struct a rdfs:Class ;
    rdfs:label "Struct" ;
    rdfs:comment "A Rust struct type" .

hkask:Enum a rdfs:Class ;
    rdfs:label "Enum" ;
    rdfs:comment "A Rust enum type" .

hkask:Trait a rdfs:Class ;
    rdfs:label "Trait" ;
    rdfs:comment "A Rust trait definition" .

hkask:Field a rdfs:Class ;
    rdfs:label "Field" ;
    rdfs:comment "A field of a struct" .

hkask:Variant a rdfs:Class ;
    rdfs:label "Variant" ;
    rdfs:comment "An enum variant" .

hkask:Method a rdfs:Class ;
    rdfs:label "Method" ;
    rdfs:comment "A method on a struct, enum, or trait" .

hkask:Function a rdfs:Class ;
    rdfs:label "Function" ;
    rdfs:comment "A free function" .

hkask:Constant a rdfs:Class ;
    rdfs:label "Constant" ;
    rdfs:comment "A named constant" .

hkask:TypeAlias a rdfs:Class ;
    rdfs:label "TypeAlias" ;
    rdfs:comment "A type alias" .

hkask:McpServer a rdfs:Class ;
    rdfs:label "McpServer" ;
    rdfs:comment "An MCP server crate" .

hkask:McpTool a rdfs:Class ;
    rdfs:label "McpTool" ;
    rdfs:comment "A tool exposed by an MCP server" .

hkask:BotDefinition a rdfs:Class ;
    rdfs:label "BotDefinition" ;
    rdfs:comment "A bot or replicant definition in the registry" .

hkask:Manifest a rdfs:Class ;
    rdfs:label "Manifest" ;
    rdfs:comment "A process manifest in the registry" .

hkask:Template a rdfs:Class ;
    rdfs:label "Template" ;
    rdfs:comment "A Jinja2 template file" .

hkask:ApiRoute a rdfs:Class ;
    rdfs:label "ApiRoute" ;
    rdfs:comment "An HTTP API endpoint" .

# ─── Relationship Properties ───

hkask:contains a rdf:Property ;
    rdfs:label "contains" ;
    rdfs:comment "Parent-child containment (crate→module, module→item)" .

hkask:dependsOn a rdf:Property ;
    rdfs:label "dependsOn" ;
    rdfs:comment "A depends on B (crate dependency or module import)" .

hkask:hasField a rdf:Property ;
    rdfs:label "hasField" ;
    rdfs:comment "A struct has this field" .

hkask:hasVariant a rdf:Property ;
    rdfs:label "hasVariant" ;
    rdfs:comment "An enum has this variant" .

hkask:hasMethod a rdf:Property ;
    rdfs:label "hasMethod" ;
    rdfs:comment "A type or trait has this method" .

hkask:implements a rdf:Property ;
    rdfs:label "implements" ;
    rdfs:comment "A type implements a trait" .

hkask:exposesTool a rdf:Property ;
    rdfs:label "exposesTool" ;
    rdfs:comment "An MCP server exposes this tool" .

hkask:usesType a rdf:Property ;
    rdfs:label "usesType" ;
    rdfs:comment "Uses a type from another module/crate" .

hkask:fieldType a rdf:Property ;
    rdfs:label "fieldType" ;
    rdfs:comment "The type of a field" .

hkask:visibility a rdf:Property ;
    rdfs:label "visibility" ;
    rdfs:comment "Visibility of an entity (pub/priv)" .

hkask:version a rdf:Property ;
    rdfs:label "version" ;
    rdfs:comment "Version string" .

hkask:description a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "Human-readable description" .

hkask:purpose a rdf:Property ;
    rdfs:label "purpose" ;
    rdfs:comment "Purpose of an entity" .

hkask:derives a rdf:Property ;
    rdfs:label "derives" ;
    rdfs:comment "Derive macros applied" .

hkask:functionRole a rdf:Property ;
    rdfs:label "functionRole" ;
    rdfs:comment "hLexicon functional role (WordAct, FlowDef, KnowAct)" .

hkask:agentKind a rdf:Property ;
    rdfs:label "agentKind" ;
    rdfs:comment "Whether agent is Bot or Replicant" .

hkask:httpMethod a rdf:Property ;
    rdfs:label "httpMethod" ;
    rdfs:comment "HTTP method for an API route" .

hkask:httpPath a rdf:Property ;
    rdfs:label "httpPath" ;
    rdfs:comment "HTTP path for an API route" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WORKSPACE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:workspace a hkask:Crate ;
    hkask:version "0.21.0" ;
    hkask:description "hKask — Planck's Constant of Agent Systems" ;
    hkask:contains code:hkask-types, code:hkask-storage, code:hkask-memory, code:hkask-cns,
                   code:hkask-templates, code:hkask-agents, code:hkask-ensemble, code:hkask-keystore,
                   code:hkask-mcp, code:hkask-cli, code:hkask-api, code:hkask-testing,
                   code:hkask-mcp-inference, code:hkask-mcp-condenser, code:hkask-mcp-web,
                   code:hkask-mcp-ocap, code:hkask-mcp-keystore, code:hkask-mcp-cns,
                   code:hkask-mcp-git, code:hkask-mcp-registry, code:hkask-mcp-gml,
                   code:hkask-mcp-spec, code:hkask-mcp-github, code:hkask-mcp-fmp,
                   code:hkask-mcp-telnyx, code:hkask-mcp-fal, code:hkask-mcp-rss-reader .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-types — Core ID types, ν-event, hLexicon
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-types a hkask:Crate ;
    hkask:description "Core ID types, ν-event, hLexicon, capability, sovereignty, spec definitions" ;
    hkask:version "0.21.0" ;
    hkask:dependsOn code:ext-serde, code:ext-serde_json, code:ext-uuid, code:ext-chrono,
                    code:ext-thiserror, code:ext-sha2, code:ext-hmac, code:ext-ed25519-dalek,
                    code:ext-blake3, code:ext-hex, code:ext-subtle, code:ext-base64 ;
    hkask:contains code:types-id, code:types-event, code:types-visibility, code:types-lexicon,
                   code:types-identity, code:types-curation, code:types-cns, code:types-agent-def,
                   code:types-template, code:types-goal, code:types-goal-capability, code:types-spec,
                   code:types-capability, code:types-secret, code:types-sovereignty,
                   code:types-audit, code:types-error, code:types-text .

# ── ID Types ──

code:types-id a hkask:Module ;
    hkask:contains code:WebID, code:TemplateID, code:BotID, code:ManifestID,
                    code:TripleID, code:EventID, code:SessionID, code:GoalID, code:UserID .

code:WebID a hkask:Struct ;
    hkask:description "UUID-based identity for agents, users, and entities in the OCAP system" ;
    hkask:hasField [ hkask:fieldType "Uuid" ] .

code:TemplateID a hkask:Struct ; hkask:description "UUID-based template identifier" .
code:BotID a hkask:Struct ; hkask:description "UUID-based bot identifier" ; hkask:implements code:WebID .
code:GoalID a hkask:Struct ; hkask:description "UUID-based goal identifier" .
code:UserID a hkask:Struct ; hkask:description "UUID-based user identifier" .

# ── Event (ν-event) ──

code:types-event a hkask:Module ;
    hkask:contains code:NuEvent, code:Span, code:Phase, code:NuEventSink, code:NuEventSinkError .

code:NuEvent a hkask:Struct ; hkask:description "CNS ν-event — the fundamental observability event" ;
    hkask:hasField [ hkask:fieldType "EventID" ], [ hkask:fieldType "DateTime<Utc>" ],
                    [ hkask:fieldType "WebID" ], [ hkask:fieldType "Span" ],
                    [ hkask:fieldType "Phase" ], [ hkask:fieldType "Value" ],
                    [ hkask:fieldType "Option<Value>" ], [ hkask:fieldType "Option<Value>" ],
                    [ hkask:fieldType "u8" ], [ hkask:fieldType "Option<EventID>" ], [ hkask:fieldType "String" ] .

code:Span a hkask:Enum ; hkask:description "CNS span categories for observability" ;
    hkask:hasVariant code:Span-Prompt, code:Span-Tool, code:Span-AgentPod, code:Span-Connector,
                     code:Span-Pipeline, code:Span-Energy, code:Span-Review, code:Span-Sovereignty,
                     code:Span-Goal, code:Span-Spec .

code:Phase a hkask:Enum ; hkask:hasVariant code:Phase-Observe, code:Phase-Regulate, code:Phase-Outcome .

code:NuEventSink a hkask:Trait ;
    hkask:hasMethod [ hkask:description "persist(&self, event: &NuEvent) -> Result<(), NuEventSinkError>" ] .

# ── Visibility & OCAP ──

code:types-visibility a hkask:Module ;
    hkask:contains code:Visibility, code:CapabilitySignature, code:Capability, code:Delegation,
                    code:AccessEvaluator, code:AccessDecision .

code:Visibility a hkask:Enum ; hkask:description "Access visibility level" ;
    hkask:hasVariant code:Visibility-Private, code:Visibility-Public, code:Visibility-Shared .

code:AccessEvaluator a hkask:Struct ; hkask:description "Evaluates access requests using OCAP capabilities" .

# ── Capability ──

code:types-capability a hkask:Module ;
    hkask:contains code:CapabilityToken, code:CapabilityResource, code:CapabilityAction,
                    code:Caveat, code:CaveatContext, code:CapabilityTokenBuilder,
                    code:CapabilityChecker, code:BotCapabilities .

code:CapabilityToken a hkask:Struct ; hkask:description "OCAP capability token with HMAC-SHA256 signature and attenuation" ;
    hkask:hasField [ hkask:fieldType "String" ], [ hkask:fieldType "CapabilityResource" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "CapabilityAction" ],
                    [ hkask:fieldType "WebID" ], [ hkask:fieldType "WebID" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "Option<i64>" ],
                    [ hkask:fieldType "u8" ], [ hkask:fieldType "u8" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "Vec<Caveat>" ] .

code:CapabilityResource a hkask:Enum ;
    hkask:hasVariant code:CapRes-Tool, code:CapRes-Template, code:CapRes-Manifest,
                     code:CapRes-Registry, code:CapRes-Cascade, code:CapRes-Spec .

code:CapabilityAction a hkask:Enum ;
    hkask:hasVariant code:CapAct-Read, code:CapAct-Write, code:CapAct-Execute,
                     code:CapAct-Render, code:CapAct-Compose, code:CapAct-Attenuate, code:CapAct-Validate .

code:CapabilityChecker a hkask:Struct ; hkask:description "Verifies capability tokens using HMAC secret" .

# ── CNS Types ──

code:types-cns a hkask:Module ;
    hkask:contains code:VarietyCounter, code:AlgedonicAlert, code:CnsEvent, code:KillZoneState,
                    code:TokenBucket, code:RetryConfig, code:CnsSpan, code:HealthStatus .

code:VarietyCounter a hkask:Struct ; hkask:description "Ashby's Law variety counter (newtype over u64)" .
code:AlgedonicAlert a hkask:Struct ; hkask:description "Algedonic alert when variety deficit > threshold" .
code:CnsSpan a hkask:Enum ; hkask:description "CNS span namespace identifiers" ;
    hkask:hasVariant code:CnsSpan-Tool, code:CnsSpan-Prompt, code:CnsSpan-AgentPod,
                     code:CnsSpan-Connector, code:CnsSpan-Template, code:CnsSpan-Curation,
                     code:CnsSpan-Variety, code:CnsSpan-KillZone, code:CnsSpan-Sovereignty,
                     code:CnsSpan-Goal, code:CnsSpan-Spec .

code:HealthStatus a hkask:Enum ;
    hkask:hasVariant code:HealthStatus-Healthy, code:HealthStatus-Degraded, code:HealthStatus-Unhealthy .

# ── Agent Definitions ──

code:types-agent-def a hkask:Module ;
    hkask:contains code:AgentDefinition, code:AgentKind, code:Charter, code:RegisteredAgent,
                    code:PersonaConstraints, code:ReadinessProbe, code:ReportingConfig,
                    code:Right, code:Responsibility, code:AgentStandingSessionConfig .

code:AgentDefinition a hkask:Struct ; hkask:description "Full agent definition (bot or replicant)" ;
    hkask:hasField [ hkask:fieldType "String" ], [ hkask:fieldType "AgentKind" ],
                    [ hkask:fieldType "bool" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "Option<Charter>" ], [ hkask:fieldType "Vec<String>" ],
                    [ hkask:fieldType "Vec<Right>" ], [ hkask:fieldType "Vec<Responsibility>" ],
                    [ hkask:fieldType "Option<ReportingConfig>" ], [ hkask:fieldType "Option<AgentStandingSessionConfig>" ],
                    [ hkask:fieldType "Option<PersonaConstraints>" ], [ hkask:fieldType "Vec<String>" ],
                    [ hkask:fieldType "Option<ReadinessProbe>" ], [ hkask:fieldType "Option<String>" ] .

code:AgentKind a hkask:Enum ; hkask:hasVariant code:AgentKind-Bot, code:AgentKind-Replicant .

code:Right a hkask:Enum ;
    hkask:hasVariant code:Right-Read, code:Right-Write, code:Right-Execute, code:Right-Coordinate, code:Right-EscalateTo .

code:Responsibility a hkask:Enum ;
    hkask:hasVariant code:Resp-Monitor, code:Resp-Synthesize, code:Resp-Perform,
                     code:Resp-Calibrate, code:Resp-Escalate, code:Resp-Maintain,
                     code:Resp-Emit, code:Resp-Orchestrate, code:Resp-Record, code:Resp-Produce .

# ── Goal System ──

code:types-goal a hkask:Module ;
    hkask:contains code:Goal, code:GoalState, code:GoalCriterion, code:GoalArtifact,
                    code:GoalVerification, code:GoalVerdict .

code:Goal a hkask:Struct ; hkask:description "OCAP-gated goal with sub-goal hierarchy" ;
    hkask:hasField [ hkask:fieldType "GoalID" ], [ hkask:fieldType "WebID" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "GoalState" ],
                    [ hkask:fieldType "Visibility" ], [ hkask:fieldType "DateTime<Utc>" ],
                    [ hkask:fieldType "Option<DateTime<Utc>>" ], [ hkask:fieldType "Option<GoalID>" ],
                    [ hkask:fieldType "u8" ] .

code:GoalState a hkask:Enum ;
    hkask:hasVariant code:GoalState-Pending, code:GoalState-Active, code:GoalState-Completed,
                     code:GoalState-Blocked, code:GoalState-Abandoned .

# ── Capability Tokens for Goals ──

code:types-goal-capability a hkask:Module ;
    hkask:contains code:GoalCapabilityToken, code:GoalOp, code:GoalAccess .

code:GoalCapabilityToken a hkask:Struct ; hkask:description "OCAP token gating goal operations" .
code:GoalOp a hkask:Enum ;
    hkask:hasVariant code:GoalOp-Create, code:GoalOp-Read, code:GoalOp-Update,
                     code:GoalOp-Verify, code:GoalOp-Complete, code:GoalOp-CreateSubgoal, code:GoalOp-AddArtifact .

# ── Spec System ──

code:types-spec a hkask:Module ;
    hkask:contains code:Spec, code:SpecId, code:SpecCategory, code:DomainAnchor, code:GoalSpec,
                    code:Criterion, code:SpecCurationRecord, code:SpecError,
                    code:CompletenessCheck, code:CollectionCoherence, code:SpecStore,
                    code:SpecCurator, code:SpecObserver, code:SpecSigner .

code:Spec a hkask:Struct ; hkask:description "DDMVSS specification with goals and OCAP boundaries" ;
    hkask:hasField [ hkask:fieldType "SpecId" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "SpecCategory" ], [ hkask:fieldType "DomainAnchor" ],
                    [ hkask:fieldType "Vec<GoalSpec>" ], [ hkask:fieldType "Option<WebID>" ],
                    [ hkask:fieldType "DateTime<Utc>" ] .

code:SpecCategory a hkask:Enum ;
    hkask:hasVariant code:SpecCat-Domain, code:SpecCat-Capability, code:SpecCat-Interface,
                     code:SpecCat-Composition, code:SpecCat-Trust, code:SpecCat-Observability,
                     code:SpecCat-Persistence, code:SpecCat-Lifecycle, code:SpecCat-Curation .

code:CompletenessCheck a hkask:Trait ;
    hkask:hasMethod [ hkask:description "is_complete(&self) -> bool" ],
                     [ hkask:description "coherence(&self) -> f64" ] .

code:SpecStore a hkask:Trait ;
    hkask:hasMethod [ hkask:description "load(&self, id: SpecId) -> Result<Spec, SpecError>" ],
                     [ hkask:description "save(&self, spec: &Spec) -> Result<(), SpecError>" ],
                     [ hkask:description "delete(&self, id: SpecId) -> Result<(), SpecError>" ] .

# ── Sovereignty ──

code:types-sovereignty a hkask:Module ;
    hkask:contains code:DataSovereigntyBoundary, code:DataCategory, code:AcquisitionResistance,
                    code:KillZoneDetector, code:UserSovereigntyState .

code:DataSovereigntyBoundary a hkask:Struct ; hkask:description "Maps data categories to sovereignty levels" ;
    hkask:hasField [ hkask:fieldType "SovereigntyId" ], [ hkask:fieldType "HashSet<DataCategory>" ],
                    [ hkask:fieldType "HashSet<DataCategory>" ], [ hkask:fieldType "HashSet<DataCategory>" ],
                    [ hkask:fieldType "AcquisitionResistance" ] .

code:DataCategory a hkask:Enum ;
    hkask:hasVariant code:DataCat-EpisodicMemory, code:DataCat-SemanticMemory,
                     code:DataCat-PersonalContext, code:DataCat-CapabilityTokens,
                     code:DataCat-OcapBoundaries, code:DataCat-TemplateInvocations,
                     code:DataCat-HLexiconTerms, code:DataCat-TemplateRegistry .

code:AcquisitionResistance a hkask:Enum ;
    hkask:hasVariant code:AcqRes-None, code:AcqRes-Low, code:AcqRes-Medium,
                     code:AcqRes-High, code:AcqRes-Maximum .

# ── Identity ──

code:types-identity a hkask:Module ;
    hkask:contains code:HumanUser, code:ReplicantIdentity, code:UserSession,
                    code:RegistrationRequest, code:RegistrationError .

code:HumanUser a hkask:Struct ; hkask:description "Encrypted human user identity" ;
    hkask:hasField [ hkask:fieldType "UserID" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "Option<String>" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "i64" ], [ hkask:fieldType "Option<i64>" ] .

# ── Secret Management ──

code:types-secret a hkask:Module ;
    hkask:contains code:SecretRef .
code:SecretRef a hkask:Enum ; hkask:description "Reference to a secret (env var, keychain, derived, generated)" ;
    hkask:hasVariant code:SecretRef-Env, code:SecretRef-Keychain, code:SecretRef-Derived, code:SecretRef-Generated .

# ── Template Types ──

code:types-template a hkask:Module ;
    hkask:contains code:TemplateInvocation, code:TemplateOutcome, code:HighTempTemplateType,
                    code:LLMParameters, code:TemperatureRange .

code:TemplateInvocation a hkask:Struct ; hkask:description "Record of a template render+invoke cycle" .
code:TemplateOutcome a hkask:Enum ;
    hkask:hasVariant code:TplOut-Success, code:TplOut-Failure, code:TplOut-Merged, code:TplOut-Discarded .

# ── Audit ──

code:types-audit a hkask:Module ;
    hkask:contains code:AuditEntry, code:AuditContext, code:AuditOutcome, code:AuditLogPort .

code:AuditOutcome a hkask:Enum ;
    hkask:hasVariant code:AuditOut-Success, code:AuditOut-Failure, code:AuditOut-Denied, code:AuditOut-Error .

code:AuditLogPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "log(&self, entry: AuditEntry)" ],
                     [ hkask:description "query_recent(&self, limit: usize) -> Vec<AuditEntry>" ],
                     [ hkask:description "query_by_actor(&self, actor: &WebID, limit: usize) -> Vec<AuditEntry>" ] .

# ── Error Types ──

code:types-error a hkask:Module ;
    hkask:contains code:McpErrorKind, code:GitArchivalError, code:AuthorizationError, code:HkaskError .

code:McpErrorKind a hkask:Enum ; hkask:description "Standard MCP error categories" ;
    hkask:hasVariant code:McpErr-Internal, code:McpErr-Unavailable, code:McpErr-Timeout,
                     code:McpErr-NotFound, code:McpErr-InvalidArgument, code:McpErr-PermissionDenied,
                     code:McpErr-RateLimited, code:McpErr-FailedPrecondition, code:McpErr-AlreadyExists,
                     code:McpErr-DataLoss, code:McpErr-Cancelled .

# ── Curation ──

code:types-curation a hkask:Module ;
    hkask:contains code:CurationDecision, code:OCAPBoundary, code:CurationRecord,
                    code:CuratorState, code:CuratorId, code:AuthorityLevel .

code:CurationDecision a hkask:Enum ;
    hkask:hasVariant code:CurDec-Merge, code:CurDec-Discard, code:CurDec-Revise, code:CurDec-Defer .

code:AuthorityLevel a hkask:Enum ;
    hkask:hasVariant code:AuthLvl-Explicit, code:AuthLvl-Implicit, code:AuthLvl-Denied .

# ── hLexicon ──

code:types-lexicon a hkask:Module ;
    hkask:contains code:HLexicon, code:LexiconTerm, code:TemplateType, code:Domain .

code:TemplateType a hkask:Enum ;
    hkask:hasVariant code:TplType-Prompt, code:TplType-Process, code:TplType-Cognition .

code:Domain a hkask:Enum ;
    hkask:hasVariant code:Domain-WordAct, code:Domain-FlowDef, code:Domain-KnowAct .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-storage — SQLite + SQLCipher + sqlite-vec
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-storage a hkask:Crate ;
    hkask:description "SQLite + SQLCipher persistence layer with bitemporal triples, embeddings, blobs, goals" ;
    hkask:dependsOn code:hkask-types, code:hkask-keystore, code:ext-rusqlite, code:ext-sqlite-vec,
                    code:ext-blake3, code:ext-serde, code:ext-uuid, code:ext-chrono, code:ext-thiserror ;
    hkask:contains code:storage-database, code:storage-triples, code:storage-embeddings,
                   code:storage-blobs, code:storage-goals, code:storage-user-store,
                   code:storage-agent-registry, code:storage-audit-log, code:storage-nu-event-store,
                   code:storage-metacognition, code:storage-sovereignty, code:storage-spec-store,
                   code:storage-standing-session, code:storage-git-cas, code:storage-goal-judge .

code:Database a hkask:Struct ; hkask:description "SQLCipher database connection with salt" ;
    hkask:hasField [ hkask:fieldType "Arc<Mutex<Connection>>" ], [ hkask:fieldType "[u8; 16]" ] .

code:TripleStore a hkask:Struct ; hkask:description "Bitemporal triple store for semantic/episodic memory" ;
    hkask:hasField [ hkask:fieldType "Arc<Mutex<Connection>>" ] .

code:Triple a hkask:Struct ; hkask:description "Bitemporal triple: entity-attribute-value with perspective and confidence" ;
    hkask:hasField [ hkask:fieldType "TripleID" ], [ hkask:fieldType "String" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "Value" ], [ hkask:fieldType "DateTime<Utc>" ],
                    [ hkask:fieldType "Option<DateTime<Utc>>" ], [ hkask:fieldType "f64" ],
                    [ hkask:fieldType "Option<WebID>" ], [ hkask:fieldType "Visibility" ],
                    [ hkask:fieldType "WebID" ] .

code:EmbeddingStore a hkask:Struct ; hkask:description "Vector embedding store with KNN search via sqlite-vec" ;
    hkask:hasField [ hkask:fieldType "Arc<Mutex<Connection>>" ] .

code:GoalRepositoryPort a hkask:Trait ;
    hkask:description "OCAP-gated goal repository trait" ;
    hkask:hasMethod [ hkask:description "create_goal(&self, token, webid, text, visibility) -> Result<Goal>" ],
                     [ hkask:description "get_goal(&self, token, goal_id) -> Result<Option<Goal>>" ],
                     [ hkask:description "update_goal_state(&self, token, goal_id, state) -> Result<()>" ],
                     [ hkask:description "create_subgoal(&self, token, parent_id, webid, text, visibility) -> Result<Goal>" ],
                     [ hkask:description "delete_goal(&self, token, goal_id) -> Result<()>" ] .

code:BlobStore a hkask:Struct ; hkask:description "BLAKE3-hashed blob storage" .
code:UserStore a hkask:Struct ; hkask:description "Encrypted user identity storage with Argon2id passphrase hashing" .
code:AgentRegistryStore a hkask:Struct ; hkask:description "Agent registry persistence" .
code:AuditLogStore a hkask:Struct ; hkask:description "Audit log persistence" .
code:NuEventStore a hkask:Struct ; hkask:description "CNS ν-event persistence" .
code:SovereigntyBoundaryStore a hkask:Struct ; hkask:description "User sovereignty boundary persistence" .
code:SqliteSpecStore a hkask:Struct ; hkask:description "Spec storage and curation" .
code:StandingSessionStore a hkask:Struct ; hkask:description "Standing ensemble session persistence" .
code:MetacognitionStore a hkask:Struct ; hkask:description "Metacognition snapshot persistence" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-memory — Semantic/episodic pipelines
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-memory a hkask:Crate ;
    hkask:description "Semantic and episodic memory pipelines with Bayesian confidence" ;
    hkask:dependsOn code:hkask-types, code:hkask-storage, code:ext-serde, code:ext-chrono, code:ext-thiserror ;
    hkask:contains code:memory-episodic, code:memory-semantic, code:memory-bayesian,
                   code:memory-recall-dedup, code:memory-goal-memory .

code:EpisodicMemory a hkask:Struct ; hkask:description "Episodic memory store (perspective-gated triples)" ;
    hkask:hasField [ hkask:fieldType "TripleStore" ] .

code:SemanticMemory a hkask:Struct ; hkask:description "Semantic memory store (triple + embedding)" ;
    hkask:hasField [ hkask:fieldType "TripleStore" ], [ hkask:fieldType "EmbeddingStore" ] .

code:BayesianOps a hkask:Struct ; hkask:description "Bayesian confidence operations (combine, retract, decay, join)" .

code:GoalMemory a hkask:Struct ; hkask:description "Goal episodic + semantic memory" ;
    hkask:hasField [ hkask:fieldType "WebID" ], [ hkask:fieldType "Arc<RwLock<HashMap<String, GoalSemanticMemory>>>" ],
                    [ hkask:fieldType "Arc<RwLock<HashMap<String, GoalEpisodicMemory>>>" ] .

code:GoalMemoryPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "store_semantic(&self, memory) -> Result<(), MemoryError>" ],
                     [ hkask:description "store_episodic(&self, memory) -> Result<(), MemoryError>" ],
                     [ hkask:description "recall_semantic(&self, goal_id) -> Result<GoalSemanticMemory, MemoryError>" ],
                     [ hkask:description "recall_episodic(&self, goal_id) -> Result<GoalEpisodicMemory, MemoryError>" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-cns — Cybernetic Nervous System (observability)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-cns a hkask:Crate ;
    hkask:description "Cybernetic Nervous System — observability via cns.* spans, variety counters, algedonic alerts" ;
    hkask:dependsOn code:hkask-types, code:ext-serde, code:ext-serde_json, code:ext-thiserror,
                    code:ext-tracing, code:ext-chrono, code:ext-tokio, code:ext-uuid ;
    hkask:contains code:cns-algedonic, code:cns-algedonic-escalation, code:cns-bot-metrics,
                   code:cns-energy, code:cns-goal-variety, code:cns-rate-limit,
                   code:cns-review-queue, code:cns-runtime, code:cns-spans,
                   code:cns-variety, code:cns-observers .

code:CnsRuntime a hkask:Struct ; hkask:description "CNS runtime manager wrapping algedonic + variety state" ;
    hkask:hasField [ hkask:fieldType "Arc<RwLock<CnsState>>" ] .

code:SpanEmitter a hkask:Struct ; hkask:description "Emits CNS ν-events via NuEventSink" ;
    hkask:hasField [ hkask:fieldType "WebID" ], [ hkask:fieldType "Option<Box<dyn NuEventSink>>" ] .

code:AlgedonicManager a hkask:Struct ; hkask:description "Manages algedonic alerts when variety deficit > threshold" ;
    hkask:hasField [ hkask:fieldType "u64" ], [ hkask:fieldType "Vec<RuntimeAlert>" ],
                    [ hkask:fieldType "Option<Box<EscalationCallback>>" ] .

code:VarietyMonitor a hkask:Struct ; hkask:description "Ashby's Law variety counter per domain" ;
    hkask:hasField [ hkask:fieldType "HashMap<String, VarietyTracker>" ] .

code:RateLimiter a hkask:Struct ; hkask:description "Generic token-bucket rate limiter" ;
    hkask:hasField [ hkask:fieldType "Mutex<HashMap<K, CnsTokenBucket>>" ], [ hkask:fieldType "RateLimitConfig" ] .

code:CnsEmit a hkask:Trait ;
    hkask:hasMethod [ hkask:description "emit_event(&self, span, phase, observation, confidence)" ],
                     [ hkask:description "emit(&self, span, outcome, confidence)" ] .

code:EnergyBudget a hkask:Struct ; hkask:description "Energy budget with token cost model and carbon accounting" ;
    hkask:hasField [ hkask:fieldType "u64" ], [ hkask:fieldType "u64" ], [ hkask:fieldType "f64" ],
                    [ hkask:fieldType "f64" ], [ hkask:fieldType "bool" ] .

code:BotMetricsCollector a hkask:Struct ; hkask:description "Per-bot evaluation metrics aggregator for Curator metacognition" .

code:CompositionObserver a hkask:Struct ; hkask:description "Composition translation pattern observer feeding into algedonic alerts" .

code:SovereigntyObserver a hkask:Struct ; hkask:description "Sovereignty violation observer for acquisition and kill-zone detection" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-templates — Registry, hLexicon, cascade, rendering
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-templates a hkask:Crate ;
    hkask:description "Template registry, Jinja2 rendering, cascade engine, CSP executor, inference port" ;
    hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-cns, code:hkask-keystore,
                    code:hkask-memory, code:ext-minijinja, code:ext-serde, code:ext-serde_json,
                    code:ext-serde_yaml, code:ext-reqwest, code:ext-thiserror, code:ext-tokio ;
    hkask:contains code:tpl-registry, code:tpl-engine, code:tpl-renderer, code:tpl-cascade,
                   code:tpl-ports, code:tpl-manifest, code:tpl-csp, code:tpl-context-assembly,
                   code:tpl-curator-pipeline, code:tpl-dependency, code:tpl-security,
                   code:tpl-inference-port, code:tpl-okapi-config, code:tpl-prompt-cache,
                   code:tpl-resilience, code:tpl-contracts, code:tpl-contract-validator,
                   code:tpl-capability-validator, code:tpl-audit, code:tpl-provenance,
                   code:tpl-russell-mapper, code:tpl-skill-translation, code:tpl-error,
                   code:tpl-adapters, code:tpl-rate-limiter, code:tpl-config .

code:TemplateEngine a hkask:Struct ; hkask:description "Jinja2 template rendering engine with registry" ;
    hkask:hasField [ hkask:fieldType "Arc<Mutex<Environment<'static>>>" ], [ hkask:fieldType "Arc<Mutex<TemplateRegistry>>" ] .

code:Registry a hkask:Struct ; hkask:description "In-memory template registry" ;
    hkask:hasField [ hkask:fieldType "HashMap<String, TemplateEntry>" ], [ hkask:fieldType "bool" ] .

code:SqliteRegistry a hkask:Struct ; hkask:description "SQLite-backed template registry with provenance" ;
    hkask:hasField [ hkask:fieldType "Connection" ], [ hkask:fieldType "HashMap<String, RegistryEntry>" ],
                    [ hkask:fieldType "ProvenanceManager" ] .

code:CascadeEngine a hkask:Struct ; hkask:description "Template cascade engine with depth limiting and energy budgets" ;
    hkask:hasField [ hkask:fieldType "CascadeConfig" ], [ hkask:fieldType "SpanEmitter" ] .

code:OkapiInference a hkask:Struct ; hkask:description "Okapi LLM inference client with rate limiting and circuit breaker" ;
    hkask:hasField [ hkask:fieldType "String" ], [ hkask:fieldType "OkapiConfig" ],
                    [ hkask:fieldType "OkapiRetryConfig" ], [ hkask:fieldType "Arc<reqwest::Client>" ],
                    [ hkask:fieldType "Option<Arc<RateLimiter>>" ], [ hkask:fieldType "Option<WebID>" ],
                    [ hkask:fieldType "SpanEmitter" ], [ hkask:fieldType "Option<Arc<CircuitBreaker>>" ] .

code:TemplateRendererImpl a hkask:Struct ; hkask:description "Jinja2 template renderer implementation" ;
    hkask:hasField [ hkask:fieldType "Arc<RwLock<Environment<'static>>>" ] .

code:ManifestExecutorImpl a hkask:Struct ; hkask:description "Process manifest executor with CSP isolation" ;
    hkask:hasField [ hkask:fieldType "R" ], [ hkask:fieldType "I" ], [ hkask:fieldType "M" ],
                    [ hkask:fieldType "C" ], [ hkask:fieldType "Option<Box<dyn MemoryPort>>" ],
                    [ hkask:fieldType "Option<Box<NoopCsp>>" ], [ hkask:fieldType "u8" ],
                    [ hkask:fieldType "SelectorConfig" ], [ hkask:fieldType "InferenceConfig" ],
                    [ hkask:fieldType "usize" ], [ hkask:fieldType "u64" ] .

# ── Key Traits ──

code:ManifestExecutor a hkask:Trait ;
    hkask:hasMethod [ hkask:description "load(&self, path) -> Result<ProcessManifest>" ],
                     [ hkask:description "execute(&self, manifest, input) -> Result<Value>" ] .

code:TemplateRenderer a hkask:Trait ;
    hkask:hasMethod [ hkask:description "load(&self, path) -> Result<CompositionTemplate>" ],
                     [ hkask:description "render(&self, template, bindings) -> Result<String>" ] .

code:RegistryIndex a hkask:Trait ;
    hkask:hasMethod [ hkask:description "list(&self, domain_hint) -> Vec<RegistryEntry>" ],
                     [ hkask:description "get(&self, id) -> Result<RegistryEntry>" ] .

code:SyncInferencePort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "call(&self, model_tier, prompt, config) -> Result<Value>" ],
                     [ hkask:description "call_default(&self, model_tier, prompt) -> Result<Value>" ] .

code:McpPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "discover_tools(&self) -> Vec<String>" ],
                     [ hkask:description "invoke(&self, tool_name, input) -> Result<Value>" ],
                     [ hkask:description "get_tool_info(&self, tool_name) -> Option<ToolInfo>" ] .

code:InferencePort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "generate(&self, prompt, parameters) -> Result<InferenceResult, InferenceError>" ],
                     [ hkask:description "generate_with_model(&self, prompt, parameters, model) -> Result<InferenceResult, InferenceError>" ] .

code:MemoryPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "query_semantic(&self, entity) -> Result<Vec<MemoryFragment>>" ],
                     [ hkask:description "query_episodic(&self, entity, perspective) -> Result<Vec<MemoryFragment>>" ],
                     [ hkask:description "get_session_history(&self, session_id, max_messages) -> Result<Vec<String>>" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-agents — Pods, ACP, bot/replicant
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-agents a hkask:Crate ;
    hkask:description "Agent pods, ACP runtime, bot/replicant types, curator metacognition" ;
    hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-keystore, code:hkask-storage,
                    code:hkask-templates, code:ext-tokio, code:ext-serde, code:ext-serde_yaml,
                    code:ext-thiserror, code:ext-uuid, code:ext-reqwest ;
    hkask:contains code:agents-acp, code:agents-bot, code:agents-replicant, code:agents-consent,
                   code:agents-curator, code:agents-ocap, code:agents-pod, code:agents-ports,
                   code:agents-adapters, code:agents-security, code:agents-sovereignty,
                   code:agents-registry-loader, code:agents-revocation-store, code:agents-error .

code:AgentPod a hkask:Struct ; hkask:description "Isolated agent execution pod with capability token and persona" ;
    hkask:hasField [ hkask:fieldType "PodID" ], [ hkask:fieldType "WebID" ],
                    [ hkask:fieldType "AgentType" ], [ hkask:fieldType "AgentPersona" ],
                    [ hkask:fieldType "TemplateCrate" ], [ hkask:fieldType "CapabilityToken" ],
                    [ hkask:fieldType "PodLifecycleState" ], [ hkask:fieldType "i64" ],
                    [ hkask:fieldType "u8" ], [ hkask:fieldType "Keychain" ],
                    [ hkask:fieldType "SovereigntyChecker" ] .

code:AcpRuntime a hkask:Struct ; hkask:description "Agent Capability Platform runtime — registration, dispatch, A2A messaging" ;
    hkask:hasField [ hkask:fieldType "Arc<RwLock<HashMap<WebID, AcpAgent>>>" ],
                    [ hkask:fieldType "Arc<RwLock<HashMap<String, A2AMessage>>>" ],
                    [ hkask:fieldType "Arc<RwLock<HashMap<WebID, Vec<CapabilityToken>>>>" ],
                    [ hkask:fieldType "Arc<Zeroizing<Vec<u8>>>" ],
                    [ hkask:fieldType "RateLimiter" ], [ hkask:fieldType "Arc<AuditLog>" ],
                    [ hkask:fieldType "Arc<RootAuthority>" ] .

code:PodManager a hkask:Struct ; hkask:description "Pod lifecycle manager with builder pattern" ;
    hkask:hasField [ hkask:fieldType "Arc<RwLock<HashMap<PodID, AgentPod>>>" ],
                    [ hkask:fieldType "Keychain" ], [ hkask:fieldType "Arc<dyn GitCASPort>" ],
                    [ hkask:fieldType "Arc<dyn AcpPort>" ], [ hkask:fieldType "Arc<dyn CnsEmit>" ],
                    [ hkask:fieldType "Arc<dyn MCPRuntimePort>" ], [ hkask:fieldType "Arc<dyn MemoryStoragePort>" ] .

code:MetacognitionLoop a hkask:Struct ; hkask:description "Curator metacognition loop evaluating bot health and variety" ;
    hkask:hasField [ hkask:fieldType "Arc<dyn CnsQueryPort>" ],
                    [ hkask:fieldType "tokio::sync::Mutex<Arc<EscalationQueue>>" ],
                    [ hkask:fieldType "MetacognitionConfig" ] .

code:SovereigntyChecker a hkask:Struct ; hkask:description "Enforces user sovereignty boundaries" ;
    hkask:hasField [ hkask:fieldType "UserSovereigntyState" ], [ hkask:fieldType "SpanEmitter" ],
                    [ hkask:fieldType "WebID" ] .

# ── Key Port Traits ──

code:AcpPort a hkask:Trait ;
    hkask:description "Agent Capability Platform port — registration, messaging, capability management" ;
    hkask:hasMethod [ hkask:description "register_agent(&self, webid, agent_type, capabilities) -> Result<CapabilityToken, AcpError>" ],
                     [ hkask:description "send_message(&self, msg) -> Result<String, AcpError>" ],
                     [ hkask:description "get_capabilities(&self, webid) -> Vec<CapabilityToken>" ] .

code:CnsQueryPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "health(&self) -> HealthStatus" ],
                     [ hkask:description "variety(&self) -> Vec<(String, u64)>" ],
                     [ hkask:description "alerts(&self) -> Vec<AlertInfo>" ] .

code:GitCASPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "load_template_crate(&self, crate_name) -> Result<TemplateCrate, GitError>" ] .

code:MCPRuntimePort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "invoke_tool(&self, tool_name, input, token) -> Result<Value, McpError>" ] .

code:SovereigntyPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "check(&self, data_category, operation, requester) -> SovereigntyCheckResult" ],
                     [ hkask:description "can_access(&self, data_category, requester) -> bool" ] .

code:OCAPPort a hkask:Trait ;
    hkask:hasMethod [ hkask:description "verify_signature(&self, token) -> bool" ],
                     [ hkask:description "verify_attenuation_chain(&self, token) -> OCAPResult" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-ensemble — Multi-agent chat
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-ensemble a hkask:Crate ;
    hkask:description "Multi-agent chat, deliberation, improv, standing sessions" ;
    hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-cns, code:hkask-templates,
                    code:hkask-keystore, code:ext-serde, code:ext-thiserror, code:ext-tokio, code:ext-reqwest ;
    hkask:contains code:ens-chat, code:ens-dedup, code:ens-dedup, code:ens-deliberation,
                   code:ens-improv, code:ens-confidence-router, code:ens-ocap-enforcement,
                   code:ens-okapi-integration, code:ens-standing-session, code:ens-webid-registry,
                   code:ens-cns-integration, code:ens-cns-spans, code:ens-ports,
                   code:ens-resilience, code:ens-adapters, code:ens-multi-okapi .

code:EnsembleChat a hkask:Struct ; hkask:description "Multi-agent chat session with OCAP enforcement" ;
    hkask:hasField [ hkask:fieldType "WebID" ], [ hkask:fieldType "HashMap<WebID, ChatParticipant>" ],
                    [ hkask:fieldType "Vec<ChatMessage>" ], [ hkask:fieldType "SpanEmitter" ],
                    [ hkask:fieldType "SovereigntyChecker" ], [ hkask:fieldType "Option<Arc<dyn RegistryIndex>>" ],
                    [ hkask:fieldType "ImprovSessionConfig" ] .

code:DeliberationCoordinator a hkask:Struct ; hkask:description "Multi-agent deliberation coordinator" ;
    hkask:hasField [ hkask:fieldType "HashMap<String, DeliberationSession>" ], [ hkask:fieldType "WebID" ] .

code:StandingSession a hkask:Struct ; hkask:description "Standing ensemble session with persistence" ;
    hkask:hasField [ hkask:fieldType "String" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "EnsembleChat" ], [ hkask:fieldType "HashMap<WebID, String>" ],
                    [ hkask:fieldType "Option<Arc<dyn StandingSessionPort>>" ] .

code:OcapEnforcer a hkask:Struct ; hkask:description "OCAP enforcement for Okapi operations" ;
    hkask:hasField [ hkask:fieldType "Arc<dyn CapabilityQueryPort>" ],
                    [ hkask:fieldType "Option<Arc<dyn SecurityMetricPort>>" ] .

code:InferenceClient a hkask:Trait ;
    hkask:hasMethod [ hkask:description "generate(&self, request) -> Result<GenerateResponse, Self::Error>" ],
                     [ hkask:description "chat(&self, messages, model) -> Result<Value, Self::Error>" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-keystore — OS keychain, AES-256-GCM, HKDF
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-keystore a hkask:Crate ;
    hkask:description "OS keychain integration, AES-256-GCM encryption, HKDF-SHA256 master key derivation" ;
    hkask:dependsOn code:hkask-types, code:ext-keyring, code:ext-aes-gcm, code:ext-argon2,
                    code:ext-hmac, code:ext-sha2, code:ext-zeroize, code:ext-hex, code:ext-rand ;
    hkask:contains code:ks-encryption, code:ks-keychain, code:ks-master-key, code:ks-error .

code:EncryptionService a hkask:Struct ; hkask:description "AES-256-GCM encryption service with Argon2id key derivation" ;
    hkask:hasField [ hkask:fieldType "Aes256Gcm" ] .

code:Keychain a hkask:Struct ; hkask:description "OS keychain integration for secret storage" ;
    hkask:hasField [ hkask:fieldType "String" ] .

code:KeyRing a hkask:Struct ; hkask:description "In-memory key ring with zeroize-on-drop" ;
    hkask:hasField [ hkask:fieldType "[u8; 32]" ] ;
    hkask:derives "Debug, Clone, Zeroize, ZeroizeOnDrop" .

code:InternalSecrets a hkask:Struct ; hkask:description "All internally-derived secrets from HKDF-SHA256 master key" ;
    hkask:hasField [ hkask:fieldType "String" ], [ hkask:fieldType "String" ],
                    [ hkask:fieldType "String" ], [ hkask:fieldType "String" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-mcp — MCP runtime, dispatch, security
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-mcp a hkask:Crate ;
    hkask:description "MCP protocol runtime, capability-based dispatch, security gateway, server scaffolding" ;
    hkask:dependsOn code:hkask-types, code:hkask-templates, code:hkask-agents, code:hkask-cns,
                    code:hkask-keystore, code:ext-rmcp, code:ext-tokio, code:ext-serde, code:ext-thiserror ;
    hkask:contains code:mcp-runtime, code:mcp-dispatch, code:mcp-security, code:mcp-server,
                   code:mcp-supervisor, code:mcp-transport, code:mcp-adapter-container,
                   code:mcp-archival-service .

code:McpRuntime a hkask:Struct ; hkask:description "MCP server registry and tool dispatch" ;
    hkask:hasField [ hkask:fieldType "Arc<RwLock<HashMap<String, McpServer>>>" ],
                    [ hkask:fieldType "Arc<RwLock<HashMap<String, String>>>" ] .

code:McpDispatcher a hkask:Struct ; hkask:description "Capability-based MCP tool dispatcher with rate limiting" ;
    hkask:hasField [ hkask:fieldType "McpRuntime" ], [ hkask:fieldType "Arc<CapabilityChecker>" ],
                    [ hkask:fieldType "RateLimiter" ], [ hkask:fieldType "Arc<RwLock<HashMap<WebID, BotCapabilities>>>" ],
                    [ hkask:fieldType "Option<Arc<dyn CnsEmit>>" ] .

code:SecurityGateway a hkask:Struct ; hkask:description "OCAP security gateway with rate limiting and audit" ;
    hkask:hasField [ hkask:fieldType "Arc<CapabilityChecker>" ], [ hkask:fieldType "RateLimiter" ],
                    [ hkask:fieldType "SecurityPolicy" ], [ hkask:fieldType "Arc<RwLock<Vec<AuditEntry>>>" ] .

code:ServerContext a hkask:Struct ; hkask:description "MCP server execution context with credentials and rate limiter" ;
    hkask:hasField [ hkask:fieldType "HashMap<String, String>" ], [ hkask:fieldType "RateLimiter" ],
                    [ hkask:fieldType "AdapterContainer" ], [ hkask:fieldType "WebID" ] .

code:McpTransport a hkask:Trait ;
    hkask:hasMethod [ hkask:description "call(&self, server_id, tool_name, arguments) -> Result<Value, String>" ],
                     [ hkask:description "is_connected(&self) -> bool" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-cli — CLI commands
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-cli a hkask:Crate ;
    hkask:description "CLI binary (kask) — 16 subcommands, interactive REPL, bootstrap orchestrator" ;
    hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-templates, code:hkask-storage,
                    code:hkask-mcp, code:hkask-cns, code:hkask-api, code:hkask-ensemble,
                    code:hkask-keystore, code:ext-clap, code:ext-rustyline ;
    hkask:contains code:cli-cli, code:cli-commands, code:cli-bootstrap, code:cli-russell-mapper,
                   code:cli-errors, code:cli-git-archival, code:cli-repl .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-api — HTTP API (utoipa)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-api a hkask:Crate ;
    hkask:description "HTTP API with OpenAPI docs (utoipa), 30+ endpoints" ;
    hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-templates, code:hkask-mcp,
                    code:hkask-cns, code:hkask-ensemble, code:hkask-keystore, code:ext-axum,
                    code:ext-utoipa ;
    hkask:contains code:api-routes, code:api-services .

code:ApiState a hkask:Struct ; hkask:description "Shared application state for all API routes" ;
    hkask:hasField [ hkask:fieldType "Arc<Mutex<SqliteRegistry>>" ], [ hkask:fieldType "Arc<McpRuntime>" ],
                    [ hkask:fieldType "Arc<PodManager>" ], [ hkask:fieldType "Arc<CapabilityChecker>" ],
                    [ hkask:fieldType "WebID" ], [ hkask:fieldType "Arc<SpanEmitter>" ],
                    [ hkask:fieldType "Arc<RateLimiter>" ], [ hkask:fieldType "Option<Arc<OkapiHttpClient>>" ] .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRATE: hkask-testing — Test fixtures and mocks
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-testing a hkask:Crate ;
    hkask:description "Test fixtures, mocks, and harnesses for integration testing" ;
    hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-memory, code:hkask-cns,
                    code:hkask-templates, code:hkask-agents, code:hkask-ensemble ;
    hkask:contains code:test-ports, code:test-harnesses .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MCP SERVERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:hkask-mcp-inference a hkask:McpServer ;
    hkask:description "Okapi-backed LLM inference with failover and rate limiting" ;
    hkask:dependsOn code:hkask-types, code:hkask-templates, code:hkask-mcp ;
    hkask:exposesTool code:tool-inference-generate, code:tool-inference-metrics, code:tool-inference-models .

code:tool-inference-generate a hkask:McpTool ; hkask:description "Generate text via Okapi LLM with failover + rate limiting" .
code:tool-inference-metrics a hkask:McpTool ; hkask:description "Get current inference metrics" .
code:tool-inference-models a hkask:McpTool ; hkask:description "List available model tiers and configurations" .

code:hkask-mcp-condenser a hkask:McpServer ;
    hkask:description "Context condensation — compress tool outputs, manage profiles, classify categories" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-condenser-ping, code:tool-condenser-compress, code:tool-condenser-set-profile,
                      code:tool-condenser-stats, code:tool-condenser-classify .

code:tool-condenser-ping a hkask:McpTool ; hkask:description "Liveness and profile info" .
code:tool-condenser-compress a hkask:McpTool ; hkask:description "Compress tool output using context-aware algorithms" .
code:tool-condenser-set-profile a hkask:McpTool ; hkask:description "Set compression profile (heavy/normal/soft/light)" .
code:tool-condenser-stats a hkask:McpTool ; hkask:description "Cumulative compression statistics" .
code:tool-condenser-classify a hkask:McpTool ; hkask:description "Classify tool name to context category" .

code:hkask-mcp-web a hkask:McpServer ;
    hkask:description "Web search and scrape with multi-provider fusion (Brave, Exa, Firecrawl, Tavily, SerAPI, Browserbase)" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-web-ping, code:tool-web-search, code:tool-web-find-similar,
                      code:tool-web-extract, code:tool-web-browse .

code:tool-web-search a hkask:McpTool ; hkask:description "Search the web with RRF fusion across providers" .
code:tool-web-extract a hkask:McpTool ; hkask:description "Extract content from a URL into markdown or structured JSON" .
code:tool-web-browse a hkask:McpTool ; hkask:description "Interactive browsing of JS-heavy pages via headless browser" .

code:hkask-mcp-ocap a hkask:McpServer ;
    hkask:description "OCAP delegation and capability management" ;
    hkask:dependsOn code:hkask-types, code:hkask-mcp ;
    hkask:exposesTool code:tool-ocap-delegate, code:tool-ocap-verify, code:tool-ocap-revoke,
                      code:tool-ocap-enumerate, code:tool-ocap-list-tokens .

code:tool-ocap-delegate a hkask:McpTool ; hkask:description "Create a delegated capability token with HMAC signature" .
code:tool-ocap-verify a hkask:McpTool ; hkask:description "Verify a capability token with cryptographic HMAC verification" .
code:tool-ocap-revoke a hkask:McpTool ; hkask:description "Revoke a capability token" .

code:hkask-mcp-keystore a hkask:McpServer ;
    hkask:description "OS keychain integration and encryption key management" ;
    hkask:dependsOn code:hkask-types, code:hkask-keystore, code:hkask-mcp ;
    hkask:exposesTool code:tool-keystore-set, code:tool-keystore-get, code:tool-keystore-rotate,
                      code:tool-keystore-delete, code:tool-keystore-list, code:tool-keystore-prompt .

code:hkask-mcp-cns a hkask:McpServer ;
    hkask:description "CNS monitoring, variety counters, and algedonic alerts" ;
    hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-mcp ;
    hkask:exposesTool code:tool-cns-emit, code:tool-cns-variety, code:tool-cns-alert,
                      code:tool-cns-calibrate, code:tool-cns-list-alerts, code:tool-cns-health .

code:hkask-mcp-git a hkask:McpServer ;
    hkask:description "Git CAS operations, versioning, and artifact management" ;
    hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-mcp ;
    hkask:exposesTool code:tool-git-resolve, code:tool-git-snapshot, code:tool-git-clone,
                      code:tool-git-fork, code:tool-git-diff, code:tool-git-list .

code:hkask-mcp-registry a hkask:McpServer ;
    hkask:description "Template registry index, discovery, and validation" ;
    hkask:dependsOn code:hkask-types, code:hkask-templates, code:hkask-storage, code:hkask-mcp ;
    hkask:exposesTool code:tool-registry-index, code:tool-registry-discover, code:tool-registry-validate,
                      code:tool-registry-reload, code:tool-registry-compose, code:tool-registry-get .

code:hkask-mcp-gml a hkask:McpServer ;
    hkask:description "GML (Allosteric Thinking) — MWC computations and capability enforcement" ;
    hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-mcp ;
    hkask:exposesTool code:tool-gml-compute-equilibrium, code:tool-gml-bind-effector,
                      code:tool-gml-create-capability, code:tool-gml-verify-capability,
                      code:tool-gml-compute-hill, code:tool-gml-assess-cooperativity .

code:hkask-mcp-spec a hkask:McpServer ;
    hkask:description "Specification authoring, curation, and validation" ;
    hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-mcp ;
    hkask:exposesTool code:tool-spec-goal-capture, code:tool-spec-goal-decompose,
                      code:tool-spec-require-bind, code:tool-spec-curate-evaluate,
                      code:tool-spec-curate-reconcile, code:tool-spec-curate-cultivate,
                      code:tool-spec-graph-query, code:tool-spec-graph-validate .

code:hkask-mcp-github a hkask:McpServer ;
    hkask:description "GitHub repository, issue, and PR operations" ;
    hkask:dependsOn code:hkask-types, code:hkask-mcp ;
    hkask:exposesTool code:tool-github-get-repo, code:tool-github-list-issues, code:tool-github-get-issue,
                      code:tool-github-create-issue, code:tool-github-add-comment,
                      code:tool-github-list-prs, code:tool-github-get-pr, code:tool-github-search-repos .

code:hkask-mcp-fmp a hkask:McpServer ;
    hkask:description "Financial Modeling Prep REST API for fundamental analysis" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-fmp-ping, code:tool-fmp-company-profile, code:tool-fmp-quote,
                      code:tool-fmp-income-statement, code:tool-fmp-balance-sheet,
                      code:tool-fmp-cash-flow, code:tool-fmp-key-metrics, code:tool-fmp-historical-price,
                      code:tool-fmp-search, code:tool-fmp-analyst-estimates, code:tool-fmp-dcf .

code:hkask-mcp-telnyx a hkask:McpServer ;
    hkask:description "Telnyx unified communications (SMS, voice, WhatsApp, Voice AI)" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-telnyx-ping, code:tool-telnyx-list-numbers, code:tool-telnyx-buy-number,
                      code:tool-telnyx-send-sms, code:tool-telnyx-make-call,
                      code:tool-telnyx-send-whatsapp, code:tool-telnyx-tts, code:tool-telnyx-list-voices .

code:hkask-mcp-fal a hkask:McpServer ;
    hkask:description "Fal.ai media generation (image, video, audio, 3D)" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-fal-ping, code:tool-fal-generate-image, code:tool-fal-generate-image-fast,
                      code:tool-fal-image-to-image, code:tool-fal-upscale, code:tool-fal-generate-video,
                      code:tool-fal-generate-music, code:tool-fal-whisper, code:tool-fal-caption,
                      code:tool-fal-generate-3d .

code:hkask-mcp-rss-reader a hkask:McpServer ;
    hkask:description "RSS/Atom feed reader with Google Reader API compatibility" ;
    hkask:dependsOn code:hkask-mcp, code:hkask-types ;
    hkask:exposesTool code:tool-rss-subscribe, code:tool-rss-unsubscribe, code:tool-rss-list-subscriptions,
                      code:tool-rss-fetch, code:tool-rss-get-entries, code:tool-rss-mark-all-read,
                      code:tool-rss-get-unread-count, code:tool-rss-search, code:tool-rss-export-opml,
                      code:tool-rss-import-opml, code:tool-rss-discover-feeds, code:tool-rss-edit-tag .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REGISTRY — Bot & Replicant Definitions
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

reg:Curator a hkask:BotDefinition ;
    hkask:agentKind "Replicant" ;
    hkask:description "System persona — metacognition, coordination, escalation to human admin" ;
    hkask:functionRole "KnowAct" ;
    hkask:contains reg:curator-charter ;
    hkask:dependsOn code:hkask-mcp-cns, code:hkask-mcp-registry, code:hkask-mcp-inference .

reg:cns-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "CNS observability bot — emit spans, variety counters, algedonic alerts" ;
    hkask:functionRole "FlowDef" .

reg:ensemble-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "Multi-agent chat orchestration (H2A sessions)" ;
    hkask:functionRole "FlowDef" .

reg:git-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "Git CAS operations — SHA versioning, provenance tracking" ;
    hkask:functionRole "FlowDef" .

reg:inference-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "LLM inference dispatch — model selection, speed/quality/cost balancing" ;
    hkask:functionRole "FlowDef" .

reg:kata-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "Toyota Kata practice routines for capability development" ;
    hkask:functionRole "KnowAct" .

reg:mcp-dispatch-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "MCP tool routing with OCAP capability verification and rate limiting" ;
    hkask:functionRole "FlowDef" .

reg:memory-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "Semantic/episodic memory — remember, recall, query, Bayesian confidence" ;
    hkask:functionRole "KnowAct" .

reg:registry-dispatch-bot a hkask:BotDefinition ;
    hkask:agentKind "Bot" ;
    hkask:description "Template selection, dispatch, and registry indexing" ;
    hkask:functionRole "FlowDef" .

reg:spec-curator-bot a hkask:BotDefinition ;
    hkask:agentKind "Replicant" ;
    hkask:description "Specification curation — goal capture, decompose, evaluate, reconcile" ;
    hkask:functionRole "KnowAct" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REGISTRY — Process Manifests
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

reg:manifest-dispatch a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Core template dispatch pipeline — select → populate → execute" .
reg:manifest-curator-metacognition a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "Curator metacognition — gather state → select operation → execute → emit" .
reg:manifest-improvement-kata a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "Improvement Kata — 4-step practice cycle" .
reg:manifest-coaching-kata a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "Coaching Kata — 5-question coaching cycle" .
reg:manifest-starter-kata a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "Starter Kata — practice routines for capability development" .
reg:manifest-memory-ops a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Memory operations with Bayesian confidence and visibility gating" .
reg:manifest-goal-lifecycle a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Goal creation → activation → judge → complete lifecycle" .
reg:manifest-composition a hkask:Manifest ; hkask:functionRole "WordAct" ;
    hkask:description "Answer composition from template output" .
reg:manifest-cascade-composition a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Template cascade composition engine" .
reg:manifest-superforecasting-pipeline a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "8-stage superforecasting pipeline" .
reg:manifest-web-quick a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Quick web search with source verification" .
reg:manifest-web-deep-research a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Deep web research with source verification" .
reg:manifest-reasoning-cycle a hkask:Manifest ; hkask:functionRole "KnowAct" ;
    hkask:description "ReAct loop with self-critique and cybernetic feedback" .
reg:manifest-spec-compose a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Specification composition pipeline" .
reg:manifest-ensemble-orchestration a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "Multi-agent ensemble coordination" .
reg:manifest-bootstrap-sequence a hkask:Manifest ; hkask:functionRole "FlowDef" ;
    hkask:description "System bootstrap — Infrastructure → Security → MCP → Bots → Curator → CNS Active" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REGISTRY — Templates
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

reg:tpl-goal-create a hkask:Template ; hkask:functionRole "WordAct" ;
    hkask:description "Extract structured goal from user intent" .
reg:tpl-goal-judge a hkask:Template ; hkask:functionRole "KnowAct" ;
    hkask:description "Verify goal completion via semantic evaluation" .
reg:tpl-prompt-execute a hkask:Template ; hkask:functionRole "WordAct" ;
    hkask:description "Execute rendered prompt" .
reg:tpl-prompt-render a hkask:Template ; hkask:functionRole "FlowDef" ;
    hkask:description "Render Jinja2 template with bindings" .
reg:tpl-prompt-selector a hkask:Template ; hkask:functionRole "KnowAct" ;
    hkask:description "Select best-fit template from registry" .
reg:tpl-cognition-calibrate a hkask:Template ; hkask:functionRole "KnowAct" ;
    hkask:description "Calibration plan from drift analysis" .
reg:tpl-cognition-detect a hkask:Template ; hkask:functionRole "KnowAct" ;
    hkask:description "Cognitive drift detection" .
reg:tpl-process-dispatch a hkask:Template ; hkask:functionRole "FlowDef" ;
    hkask:description "Tool dispatch via MCP" .
reg:tpl-process-recall a hkask:Template ; hkask:functionRole "FlowDef" ;
    hkask:description "Memory recall process" .
reg:tpl-spec-capture a hkask:Template ; hkask:functionRole "KnowAct" ;
    hkask:description "Capture user intent as binding requirement" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API ROUTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:api-templates-list a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/templates" .
code:api-templates-get a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/templates/:id" .
code:api-templates-register a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/templates" .
code:api-templates-search a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/templates/search/:term" .
code:api-bots-capabilities a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/bots/:id/capabilities" .
code:api-bots-grant a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/bots/:id/grant" .
code:api-mcp-servers a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/mcp/servers" .
code:api-mcp-tools a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/mcp/tools" .
code:api-cns-health a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/cns/health" .
code:api-cns-alerts a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/cns/alerts" .
code:api-cns-variety a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/cns/variety" .
code:api-pods-list a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/pods" .
code:api-pods-create a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/pods" .
code:api-pods-activate a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/pods/:id/activate" .
code:api-pods-deactivate a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/pods/:id/deactivate" .
code:api-pods-status a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/pods/:id/status" .
code:api-chat a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/chat" .
code:api-sovereignty-status a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/sovereignty/status" .
code:api-sovereignty-grant a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/sovereignty/consent/grant" .
code:api-sovereignty-revoke a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/sovereignty/consent/revoke" .
code:api-sovereignty-killzone a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/sovereignty/killzone" .
code:api-llm-infer a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/llm/infer" .
code:api-acp-register a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/v1/acp/register" .
code:api-ensemble-chat-create a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/ensemble/chat" .
code:api-ensemble-chat-register a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/ensemble/chat/:session/register" .
code:api-ensemble-chat-send a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/ensemble/chat/:session/send" .
code:api-specs-list a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/specs" .
code:api-specs-capture a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/specs/capture" .
code:api-specs-validate a hkask:ApiRoute ; hkask:httpMethod "POST" ; hkask:httpPath "/api/specs/validate" .
code:api-specs-cultivate a hkask:ApiRoute ; hkask:httpMethod "GET" ; hkask:httpPath "/api/specs/cultivate" .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CROSS-CRATE DEPENDENCY GRAPH
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Core types (no internal deps)
code:hkask-types hkask:dependsOn code:ext-serde, code:ext-uuid, code:ext-chrono .

# Storage layer
code:hkask-storage hkask:dependsOn code:hkask-types, code:hkask-keystore .

# Memory pipelines
code:hkask-memory hkask:dependsOn code:hkask-types, code:hkask-storage .

# CNS observability
code:hkask-cns hkask:dependsOn code:hkask-types .

# Keystore
code:hkask-keystore hkask:dependsOn code:hkask-types .

# Template engine
code:hkask-templates hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-cns,
                     code:hkask-keystore, code:hkask-memory .

# Agent system
code:hkask-agents hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-keystore,
                  code:hkask-storage, code:hkask-templates .

# Ensemble (multi-agent)
code:hkask-ensemble hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-cns,
                    code:hkask-templates, code:hkask-keystore .

# MCP runtime
code:hkask-mcp hkask:dependsOn code:hkask-types, code:hkask-templates, code:hkask-agents,
               code:hkask-cns, code:hkask-keystore .

# CLI
code:hkask-cli hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-templates,
               code:hkask-storage, code:hkask-mcp, code:hkask-cns, code:hkask-api,
               code:hkask-ensemble, code:hkask-keystore .

# API
code:hkask-api hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-templates,
               code:hkask-mcp, code:hkask-cns, code:hkask-ensemble, code:hkask-keystore .

# Testing
code:hkask-testing hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-memory,
                    code:hkask-cns, code:hkask-templates, code:hkask-agents, code:hkask-ensemble .

# MCP servers depend on hkask-mcp + hkask-types (+ crate-specific deps)
code:hkask-mcp-ocap hkask:dependsOn code:hkask-types, code:hkask-mcp .
code:hkask-mcp-keystore hkask:dependsOn code:hkask-types, code:hkask-keystore, code:hkask-mcp .
code:hkask-mcp-cns hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-mcp .
code:hkask-mcp-git hkask:dependsOn code:hkask-types, code:hkask-agents, code:hkask-mcp .
code:hkask-mcp-registry hkask:dependsOn code:hkask-types, code:hkask-templates, code:hkask-storage, code:hkask-mcp .
code:hkask-mcp-spec hkask:dependsOn code:hkask-types, code:hkask-storage, code:hkask-mcp .
code:hkask-mcp-gml hkask:dependsOn code:hkask-types, code:hkask-cns, code:hkask-mcp .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ARCHITECTURAL PATTERNS (as RDF annotations)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

hkask:OCAPPattern a rdfs:Class ;
    rdfs:label "OCAP Pattern" ;
    rdfs:comment "Object-Capability security pattern — CapabilityToken with HMAC-SHA256, attenuation chains (max depth 7), caveats, and CapabilityTokenBuilder" .

hkask:PortTrait a rdfs:Class ;
    rdfs:label "Port Trait" ;
    rdfs:comment "Hexagonal architecture port trait — defines interface boundary" .

hkask:CNSObservability a rdfs:Class ;
    rdfs:label "CNS Observability" ;
    rdfs:comment "Cybernetic Nervous System observability via spans, variety counters, algedonic alerts" .

hkask:BayesianConfidence a rdfs:Class ;
    rdfs:label "Bayesian Confidence" ;
    rdfs:comment "Bayesian confidence model for memory triple combination and decay" .

hkask:SovereigntyModel a rdfs:Class ;
    rdfs:label "Sovereignty Model" ;
    rdfs:comment "DataSovereigntyBoundary with DataCategory → DataSovereignty mapping, KillZoneDetector for VC acquisition monitoring" .

hkask:DDMVSSSpec a rdfs:Class ;
    rdfs:label "DDMVSS Spec" ;
    rdfs:comment "Spec → GoalSpec → Criterion hierarchy with max depth 7, CompletenessCheck and CollectionCoherence traits" .

hkask:EnergyBudgetModel a rdfs:Class ;
    rdfs:label "Energy Budget Model" ;
    rdfs:comment "Token-cost energy model with carbon accounting (GHG-Protocol-Scope-2)" .

hkask:MatroshkaLimit a rdfs:Class ;
    rdfs:label "Matroshka Limit" ;
    rdfs:comment "Max cascade/template nesting depth of 7 (Miller's Law)" .

# ── Pattern instances ──

code:CapabilityToken hkask:implements hkask:OCAPPattern .
code:GoalCapabilityToken hkask:implements hkask:OCAPPattern .
code:AcpRuntime hkask:implements hkask:OCAPPattern .
code:SecurityGateway hkask:implements hkask:OCAPPattern .
code:OcapEnforcer hkask:implements hkask:OCAPPattern .

code:GoalRepositoryPort hkask:implements hkask:PortTrait .
code:NuEventSink hkask:implements hkask:PortTrait .
code:AcpPort hkask:implements hkask:PortTrait .
code:CnsQueryPort hkask:implements hkask:PortTrait .
code:GitCASPort hkask:implements hkask:PortTrait .
code:MCPRuntimePort hkask:implements hkask:PortTrait .
code:MemoryStoragePort hkask:implements hkask:PortTrait .
code:MetacognitionPort hkask:implements hkask:PortTrait .
code:OCAPPort hkask:implements hkask:PortTrait .
code:SovereigntyPort hkask:implements hkask:PortTrait .
code:StandingSessionPort hkask:implements hkask:PortTrait .
code:InferencePort hkask:implements hkask:PortTrait .
code:McpPort hkask:implements hkask:PortTrait .
code:ManifestExecutor hkask:implements hkask:PortTrait .
code:TemplateRenderer hkask:implements hkask:PortTrait .
code:RegistryIndex hkask:implements hkask:PortTrait .
code:GoalMemoryPort hkask:implements hkask:PortTrait .
code:AuditLogPort hkask:implements hkask:PortTrait .
code:SpecStore hkask:implements hkask:PortTrait .
code:SpecCurator hkask:implements hkask:PortTrait .
code:SpecObserver hkask:implements hkask:PortTrait .
code:McpTransport hkask:implements hkask:PortTrait .

code:CnsRuntime hkask:implements hkask:CNSObservability .
code:SpanEmitter hkask:implements hkask:CNSObservability .
code:AlgedonicManager hkask:implements hkask:CNSObservability .
code:VarietyMonitor hkask:implements hkask:CNSObservability .

code:BayesianOps hkask:implements hkask:BayesianConfidence .
code:EpisodicMemory hkask:implements hkask:BayesianConfidence .
code:SemanticMemory hkask:implements hkask:BayesianConfidence .

code:DataSovereigntyBoundary hkask:implements hkask:SovereigntyModel .
code:KillZoneDetector hkask:implements hkask:SovereigntyModel .
code:SovereigntyChecker hkask:implements hkask:SovereigntyModel .

code:Spec hkask:implements hkask:DDMVSSSpec .
code:GoalSpec hkask:implements hkask:DDMVSSSpec .
code:SpecCurator hkask:implements hkask:DDMVSSSpec .

code:EnergyBudget hkask:implements hkask:EnergyBudgetModel .
code:EnergyAccount hkask:implements hkask:EnergyBudgetModel .
code:EnergyEmitter hkask:implements hkask:EnergyBudgetModel .

code:CascadeEngine hkask:implements hkask:MatroshkaLimit .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EXTERNAL DEPENDENCIES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

