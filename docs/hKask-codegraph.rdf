# VERSION AND METADATA
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

code:workspace hkask:version "0.21.0" ;
    hkask:description "hKask (ℏKask) — Planck's Constant of Agent Systems — v0.21.0" ;
    hkask:purpose "Minimal viable unit of an agent platform: bots + replicants in pods with WebID, ACP, 15 MCP servers, OCAP security, SQLCipher encryption, and CNS observability" .
