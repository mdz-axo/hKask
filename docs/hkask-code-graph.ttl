hkask:HkaskError-Deserialization rdf:type hkask:Variant .
hkask:HkaskError-Io rdf:type hkask:Variant .
hkask:HkaskError-Network rdf:type hkask:Variant .
hkask:HkaskError-Config rdf:type hkask:Variant .
hkask:HkaskError-Validation rdf:type hkask:Variant .
hkask:HkaskError-InvalidInput rdf:type hkask:Variant .
hkask:HkaskError-Other rdf:type hkask:Variant .

