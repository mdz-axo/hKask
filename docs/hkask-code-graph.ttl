hkask:AlgedonicAlert-current rdf:type hkask:Field ; hkask:fieldType xsd:unsignedLong .
hkask:AlgedonicAlert-threshold rdf:type hkask:Field ; hkask:fieldType xsd:unsignedLong .
hkask:AlgedonicAlert-deficit rdf:type hkask:Field ; hkask:fieldType xsd:unsignedLong .
hkask:AlgedonicAlert-escalated rdf:type hkask:Field ; hkask:fieldType xsd:boolean .
hkask:AlgedonicAlert-timestamp rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .
hkask:AlgedonicAlert-span rdf:type hkask:Field ; hkask:fieldType hkask:CnsSpan .

hkask:KillZoneState rdf:type hkask:Struct ;
