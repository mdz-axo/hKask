# =============================================================================
# RELATIONSHIPS — CRATE DEPENDENCY GRAPH
# =============================================================================

# Core dependency chain (layer-by-layer):
# Layer 0: hkask-types (no internal deps)
# Layer 1: hkask-keystore → hkask-types
# Layer 1: hkask-cns → hkask-types
# Layer 2: hkask-storage → hkask-types + hkask-keystore
# Layer 2: hkask-memory → hkask-types + hkask-storage
# Layer 3: hkask-templates → types + storage + cns + keystore + memory
# Layer 4: hkask-agents → types + cns + keystore + storage + templates
# Layer 4: hkask-ensemble → types + agents + cns + templates + keystore
# Layer 5: hkask-mcp → types + templates + agents + cns + keystore
# Layer 5: hkask-api → types + agents + templates + mcp + cns + ensemble + keystore
# Layer 6: hkask-cli → all core crates

# =============================================================================
# RELATIONSHIPS — TYPE REFERENCES (cross-cutting)
# =============================================================================

# NuEvent references other types
hkask:NuEvent-uses hkask:WebID, hkask:Span, hkask:Phase, hkask:EventID .

# TemplateInvocation references
hkask:TemplateInvocation-uses hkask:TemplateID, hkask:BotID, hkask:LLMParameters, hkask:CapabilityToken, hkask:TemplateOutcome .

# AgentDefinition references
hkask:AgentDefinition-uses hkask:AgentKind, hkask:Charter, hkask:Right, hkask:Responsibility, hkask:PersonaConstraints, hkask:ReadinessProbe, hkask:ReportingConfig .

# Curator types cross-reference
hkask:CurationRecord-uses hkask:CuratorId, hkask:TemplateInvocation, hkask:CurationDecision, hkask:OCAPBoundary .
hkask:OCAPBoundary-uses hkask:AuthorityLevel .
hkask:SpecCurationRecord-uses hkask:SpecId, hkask:CurationDecision, hkask:OCAPBoundary .

# Goal cross-references
hkask:Goal-uses hkask:WebID, hkask:GoalState, hkask:Visibility, hkask:GoalID .
hkask:GoalSpec-uses hkask:GoalID, hkask:OCAPBoundary .
hkask:Spec-uses hkask:SpecId, hkask:SpecCategory, hkask:DomainAnchor, hkask:GoalSpec, hkask:WebID .

# Sovereignty references
hkask:DataSovereigntyBoundary-uses hkask:SovereigntyId, hkask:DataCategory, hkask:AcquisitionResistance .
hkask:UserSovereigntyState-uses hkask:DataSovereigntyBoundary, hkask:KillZoneDetector .

# Capability cross-references
hkask:CapabilityToken-uses hkask:CapabilityResource, hkask:CapabilityAction, hkask:Caveat .
hkask:BotCapabilities-uses hkask:BotID, hkask:CapabilityToken .
hkask:Capability-uses hkask:CapabilitySignature, hkask:SignatureAlgorithm .

# API state cross-references
hkask:ApiState-uses hkask:McpRuntime, hkask:PodManager, hkask:WebID, hkask:SpanEmitter, hkask:TokenBucket .

# Error cross-references
hkask:HkaskError-convertsTo hkask:McpErrorKind .

# Storage implements CNS event traits
hkask:NuEventStore-implements hkask:NuEventSink .

# Agent pod cross-references
hkask:AgentPod-uses hkask:PodID, hkask:WebID, hkask:AgentType, hkask:PodLifecycleState .
hkask:PodManager-uses hkask:GitCASPort, hkask:AcpPort, hkask:MCPRuntimePort, hkask:MemoryStoragePort .

# =============================================================================
# RELATIONSHIPS — IMPLEMENTS (trait impls)
# =============================================================================

hkask:NuEventStore-implements rdf:type hkask:Implements ;
    hkask:struct hkask:NuEventStore ;
    hkask:implTrait hkask:NuEventSink .

hkask:Spec-implements-CompletenessCheck rdf:type hkask:Implements ;
    hkask:struct hkask:Spec ;
    hkask:implTrait hkask:CompletenessCheck .

hkask:GoalSpec-implements-CompletenessCheck rdf:type hkask:Implements ;
    hkask:struct hkask:GoalSpec ;
    hkask:implTrait hkask:CompletenessCheck .

