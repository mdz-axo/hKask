hkask:TemperatureRange-min rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:TemperatureRange-max rdf:type hkask:Field ; hkask:fieldType xsd:float .

hkask:LLMParameters rdf:type hkask:Struct ;
