        hkask:LLMParameters-seed .

hkask:LLMParameters-temperature rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:LLMParameters-top_p rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:LLMParameters-top_k rdf:type hkask:Field ; hkask:fieldType xsd:unsignedInt .
hkask:LLMParameters-frequency_penalty rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:LLMParameters-presence_penalty rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:LLMParameters-max_tokens rdf:type hkask:Field ; hkask:fieldType xsd:unsignedInt .
hkask:LLMParameters-seed rdf:type hkask:Field ; hkask:fieldType xsd:unsignedLong ; hkask:isOptional "true" .

hkask:TemplateOutcome rdf:type hkask:Enum ;
