hkask:SpecCategory-Persistence rdf:type hkask:Variant .
hkask:SpecCategory-Lifecycle rdf:type hkask:Variant .
hkask:SpecCategory-Curation rdf:type hkask:Variant .

hkask:DomainAnchor rdf:type hkask:Enum ;
    rdfs:label "DomainAnchor" ;
    hkask:definedIn hkask:mod-spec ;
    hkask:hasVariant hkask:DomainAnchor-Okapi, hkask:DomainAnchor-Russell, hkask:DomainAnchor-Hkask .

hkask:DomainAnchor-Okapi rdf:type hkask:Variant .
hkask:DomainAnchor-Russell rdf:type hkask:Variant .
hkask:DomainAnchor-Hkask rdf:type hkask:Variant .

hkask:GoalSpec rdf:type hkask:Struct ;
    rdfs:label "GoalSpec" ;
    rdfs:comment "Recursive goal decomposition — max depth 7" ;
    hkask:definedIn hkask:mod-spec ;
    hkask:hasField hkask:GoalSpec-id, hkask:GoalSpec-text, hkask:GoalSpec-criteria,
        hkask:GoalSpec-constraints, hkask:GoalSpec-sub_goals, hkask:GoalSpec-depth .

hkask:GoalSpec-id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID .
hkask:GoalSpec-text rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalSpec-criteria rdf:type hkask:Field ; rdfs:comment "Vec<Criterion>" .
hkask:GoalSpec-constraints rdf:type hkask:Field ; rdfs:comment "Vec<OCAPBoundary>" .
hkask:GoalSpec-sub_goals rdf:type hkask:Field ; rdfs:comment "Vec<GoalSpec> — recursive" .
hkask:GoalSpec-depth rdf:type hkask:Field ; hkask:fieldType xsd:unsignedByte .

hkask:Criterion rdf:type hkask:Struct ;
    rdfs:label "Criterion" ;
    hkask:definedIn hkask:mod-spec .

hkask:SpecCurationRecord rdf:type hkask:Struct ;
    rdfs:label "SpecCurationRecord" ;
    rdfs:comment "Curator evaluation of a specification" ;
    hkask:definedIn hkask:mod-spec ;
    hkask:hasField hkask:SpecCurationRecord-spec_id, hkask:SpecCurationRecord-decision,
        hkask:SpecCurationRecord-rationale, hkask:SpecCurationRecord-coherence_score,
        hkask:SpecCurationRecord-ocap_boundary, hkask:SpecCurationRecord-curated_at .

hkask:SpecCurationRecord-spec_id rdf:type hkask:Field ; hkask:fieldType hkask:SpecId .
hkask:SpecCurationRecord-decision rdf:type hkask:Field ; hkask:fieldType hkask:CurationDecision .
hkask:SpecCurationRecord-rationale rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:SpecCurationRecord-coherence_score rdf:type hkask:Field ; hkask:fieldType xsd:double .
hkask:SpecCurationRecord-ocap_boundary rdf:type hkask:Field ; hkask:fieldType hkask:OCAPBoundary .
hkask:SpecCurationRecord-curated_at rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .

hkask:CompletenessCheck rdf:type hkask:Trait ;
    rdfs:label "CompletenessCheck" ;
    rdfs:comment "MVP completeness verification — implemented by GoalSpec and Spec" ;
    hkask:definedIn hkask:mod-spec ;
    hkask:hasMethod hkask:CompletenessCheck-is_complete, hkask:CompletenessCheck-coherence .

hkask:CompletenessCheck-is_complete rdf:type hkask:Method ; hkask:returns xsd:boolean .
hkask:CompletenessCheck-coherence rdf:type hkask:Method ; hkask:returns xsd:double .

hkask:SpecStore rdf:type hkask:Trait ;
    rdfs:label "SpecStore" ;
    rdfs:comment "Specification storage port" ;
    hkask:definedIn hkask:mod-spec .

hkask:SpecSigner rdf:type hkask:Trait ;
    rdfs:label "SpecSigner" ;
    hkask:definedIn hkask:mod-spec .

hkask:SpecObserver rdf:type hkask:Trait ;
    rdfs:label "SpecObserver" ;
    hkask:definedIn hkask:mod-spec .

hkask:SpecCurator rdf:type hkask:Trait ;
    rdfs:label "SpecCurator" ;
    hkask:definedIn hkask:mod-spec .

# =============================================================================
# GOAL TYPES (coordination substrate)
# =============================================================================

hkask:Goal rdf:type hkask:Struct ;
    rdfs:label "Goal" ;
    rdfs:comment "Minimal coordination substrate for multi-agent collaboration — text + criteria + state" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasField hkask:Goal-id, hkask:Goal-webid, hkask:Goal-text, hkask:Goal-state,
        hkask:Goal-visibility, hkask:Goal-created_at, hkask:Goal-completed_at,
        hkask:Goal-parent_goal_id, hkask:Goal-depth .

hkask:Goal-id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID .
hkask:Goal-webid rdf:type hkask:Field ; hkask:fieldType hkask:WebID .
hkask:Goal-text rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Goal-state rdf:type hkask:Field ; hkask:fieldType hkask:GoalState .
hkask:Goal-visibility rdf:type hkask:Field ; hkask:fieldType hkask:Visibility .
hkask:Goal-created_at rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .
hkask:Goal-completed_at rdf:type hkask:Field ; hkask:fieldType hkask:DateTime ; hkask:isOptional "true" .
hkask:Goal-parent_goal_id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID ; hkask:isOptional "true" .
hkask:Goal-depth rdf:type hkask:Field ; hkask:fieldType xsd:unsignedByte .

hkask:GoalState rdf:type hkask:Enum ;
    rdfs:label "GoalState" ;
    rdfs:comment "Simple minimal goal states" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasVariant hkask:GoalState-Pending, hkask:GoalState-Active, hkask:GoalState-Completed,
        hkask:GoalState-Blocked, hkask:GoalState-Abandoned .

hkask:GoalState-Pending rdf:type hkask:Variant .
hkask:GoalState-Active rdf:type hkask:Variant .
hkask:GoalState-Completed rdf:type hkask:Variant ; hkask:isTerminal "true" .
hkask:GoalState-Blocked rdf:type hkask:Variant ; hkask:isTerminal "true" .
hkask:GoalState-Abandoned rdf:type hkask:Variant ; hkask:isTerminal "true" .

hkask:GoalCriterion rdf:type hkask:Struct ;
    rdfs:label "GoalCriterion" ;
    rdfs:comment "Completion condition — LLM-judged" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasField hkask:GoalCriterion-id, hkask:GoalCriterion-goal_id,
        hkask:GoalCriterion-criterion_type, hkask:GoalCriterion-description,
        hkask:GoalCriterion-satisfied .

hkask:GoalCriterion-id rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalCriterion-goal_id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID .
hkask:GoalCriterion-criterion_type rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalCriterion-description rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalCriterion-satisfied rdf:type hkask:Field ; hkask:fieldType xsd:boolean .

hkask:GoalArtifact rdf:type hkask:Struct ;
    rdfs:label "GoalArtifact" ;
    rdfs:comment "Output produced while working toward goal" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasField hkask:GoalArtifact-id, hkask:GoalArtifact-goal_id,
        hkask:GoalArtifact-artifact_ref, hkask:GoalArtifact-artifact_type,
        hkask:GoalArtifact-created_at .

hkask:GoalArtifact-id rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalArtifact-goal_id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID .
hkask:GoalArtifact-artifact_ref rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalArtifact-artifact_type rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalArtifact-created_at rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .

hkask:GoalVerification rdf:type hkask:Struct ;
    rdfs:label "GoalVerification" ;
    rdfs:comment "LLM judge verification result" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasField hkask:GoalVerification-goal_id, hkask:GoalVerification-verdict,
        hkask:GoalVerification-reason, hkask:GoalVerification-confidence .

hkask:GoalVerification-goal_id rdf:type hkask:Field ; hkask:fieldType hkask:GoalID .
hkask:GoalVerification-verdict rdf:type hkask:Field ; hkask:fieldType hkask:GoalVerdict .
hkask:GoalVerification-reason rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:GoalVerification-confidence rdf:type hkask:Field ; hkask:fieldType xsd:float .

hkask:GoalVerdict rdf:type hkask:Enum ;
    rdfs:label "GoalVerdict" ;
    hkask:definedIn hkask:mod-goal ;
    hkask:hasVariant hkask:GoalVerdict-Done, hkask:GoalVerdict-Continue, hkask:GoalVerdict-Blocked .

hkask:GoalVerdict-Done rdf:type hkask:Variant .
hkask:GoalVerdict-Continue rdf:type hkask:Variant .
hkask:GoalVerdict-Blocked rdf:type hkask:Variant .

