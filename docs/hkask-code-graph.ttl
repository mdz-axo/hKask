hkask:Visibility rdf:type hkask:Enum ;
    rdfs:label "Visibility" ;
    rdfs:comment "OCAP-enforced access control level" ;
    hkask:definedIn hkask:mod-visibility ;
    hkask:hasVariant hkask:Visibility-Private, hkask:Visibility-Public, hkask:Visibility-Shared .

hkask:Visibility-Private rdf:type hkask:Variant ; rdfs:comment "Owner only" .
hkask:Visibility-Public rdf:type hkask:Variant ; rdfs:comment "Accessible to all" .
hkask:Visibility-Shared rdf:type hkask:Variant ; rdfs:comment "Requires valid capability" .

hkask:SignatureAlgorithm rdf:type hkask:Enum ;
    rdfs:label "SignatureAlgorithm" ;
    hkask:definedIn hkask:mod-visibility ;
    hkask:hasVariant hkask:SignatureAlgorithm-Ed25519, hkask:SignatureAlgorithm-HmacSha256 .

hkask:SignatureAlgorithm-Ed25519 rdf:type hkask:Variant .
hkask:SignatureAlgorithm-HmacSha256 rdf:type hkask:Variant .

hkask:Capability rdf:type hkask:Struct ;
    rdfs:label "Capability" ;
    rdfs:comment "OCAP capability for delegation — signature required to prevent forgery" ;
    hkask:definedIn hkask:mod-visibility ;
    hkask:hasField hkask:Capability-resource, hkask:Capability-action,
        hkask:Capability-granted_by, hkask:Capability-granted_to,
        hkask:Capability-signature, hkask:Capability-expires_at .

hkask:Capability-resource rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Capability-action rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Capability-granted_by rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Capability-granted_to rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Capability-signature rdf:type hkask:Field ; hkask:fieldType hkask:CapabilitySignature .
hkask:Capability-expires_at rdf:type hkask:Field ; hkask:fieldType xsd:integer ; hkask:isOptional "true" .

hkask:CapabilitySignature rdf:type hkask:Struct ;
    rdfs:label "CapabilitySignature" ;
    rdfs:comment "Cryptographic signature for capability verification" ;
    hkask:definedIn hkask:mod-visibility .

hkask:Delegation rdf:type hkask:Struct ;
    rdfs:label "Delegation" ;
    rdfs:comment "OCAP delegation record with cryptographic verification and chain support" ;
    hkask:definedIn hkask:mod-visibility .

hkask:DelegationStore rdf:type hkask:Struct ;
    rdfs:label "DelegationStore" ;
    rdfs:comment "Delegation store for chain verification" ;
    hkask:definedIn hkask:mod-visibility .

hkask:RevocationList rdf:type hkask:Struct ;
    rdfs:label "RevocationList" ;
    rdfs:comment "Revocation list for capability/delegation revocation" ;
    hkask:definedIn hkask:mod-visibility .

hkask:AccessDecision rdf:type hkask:Struct ;
    rdfs:label "AccessDecision" ;
    rdfs:comment "Access control decision with metadata" ;
    hkask:definedIn hkask:mod-visibility .

hkask:AccessEvaluator rdf:type hkask:Struct ;
    rdfs:label "AccessEvaluator" ;
    rdfs:comment "Access evaluator with separated responsibilities — delegation chain verification" ;
    hkask:definedIn hkask:mod-visibility .

hkask:AccessRequest rdf:type hkask:Struct ;
    rdfs:label "AccessRequest" ;
    rdfs:comment "Parameter object for access evaluation" ;
    hkask:definedIn hkask:mod-visibility .

