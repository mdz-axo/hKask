hkask:TemplateOutcome-Failure rdf:type hkask:Variant .
hkask:TemplateOutcome-Merged rdf:type hkask:Variant .
hkask:TemplateOutcome-Discarded rdf:type hkask:Variant .

hkask:TemplateInvocation rdf:type hkask:Struct ;
    rdfs:label "TemplateInvocation" ;
    rdfs:comment "Record of a single template execution with OCAP capability token" ;
    hkask:definedIn hkask:mod-template ;
