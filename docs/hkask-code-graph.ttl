        hkask:TemplateInvocation-parameters, hkask:TemplateInvocation-input,
        hkask:TemplateInvocation-outputs, hkask:TemplateInvocation-selected_index,
        hkask:TemplateInvocation-outcome, hkask:TemplateInvocation-timestamp,
