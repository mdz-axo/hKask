# =============================================================================
# ID TYPES (core identifiers)
# =============================================================================

hkask:WebID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "WebID" ;
    rdfs:comment "Unique identifier for agents (bots and replicants) — UUID-v4/v5 wrapper" ;
    hkask:definedIn hkask:mod-id ;
    hkask:hasField hkask:WebID-field-0 ;
    hkask:derivesFrom hkask:uuid-Uuid .

hkask:WebID-field-0 rdf:type hkask:Field ;
    rdfs:label "WebID.0" ;
    hkask:fieldType hkask:uuid-Uuid ;
    hkask:visibility hkask:viz-public .

hkask:TemplateID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "TemplateID" ;
    rdfs:comment "Unique identifier for templates" ;
    hkask:definedIn hkask:mod-id ;
    hkask:derivesFrom hkask:uuid-Uuid .

hkask:BotID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "BotID" ;
    rdfs:comment "Unique identifier for bots — convertible to WebID" ;
    hkask:definedIn hkask:mod-id ;
    hkask:derivesFrom hkask:uuid-Uuid ;
    hkask:hasConversionTo hkask:WebID .

hkask:ManifestID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "ManifestID" ;
    hkask:definedIn hkask:mod-id .

hkask:TripleID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "TripleID" ;
    rdfs:comment "Unique identifier for bitemporal triples" ;
    hkask:definedIn hkask:mod-id .

hkask:EventID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "EventID" ;
    rdfs:comment "Unique identifier for ν-events" ;
    hkask:definedIn hkask:mod-id .

hkask:SessionID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "SessionID" ;
    rdfs:comment "Unique identifier for agent sessions" ;
    hkask:definedIn hkask:mod-id .

hkask:GoalID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "GoalID" ;
    rdfs:comment "Unique identifier for goals" ;
    hkask:definedIn hkask:mod-id .

hkask:SpecId rdf:type hkask:Struct, owl:Class ;
    rdfs:label "SpecId" ;
    rdfs:comment "Unique identifier for specifications" ;
    hkask:definedIn hkask:mod-spec .

hkask:SovereigntyId rdf:type hkask:Struct, owl:Class ;
    rdfs:label "SovereigntyId" ;
    hkask:definedIn hkask:mod-sovereignty .

hkask:CuratorId rdf:type hkask:Struct, owl:Class ;
    rdfs:label "CuratorId" ;
    rdfs:comment "The one true Curator — system-wide singleton" ;
    hkask:definedIn hkask:mod-curation .

hkask:UserID rdf:type hkask:Struct, owl:Class ;
    rdfs:label "UserID" ;
    rdfs:comment "Human user ID — shared across all their replicant identities" ;
    hkask:definedIn hkask:mod-identity .

# =============================================================================
# IDENTITY TYPES
# =============================================================================

hkask:HumanUser rdf:type hkask:Struct ;
    rdfs:label "HumanUser" ;
    rdfs:comment "The human behind the system (contact info for recovery)" ;
    hkask:definedIn hkask:mod-identity ;
    hkask:hasField hkask:HumanUser-user_id, hkask:HumanUser-email_enc, hkask:HumanUser-phone_enc,
        hkask:HumanUser-passphrase_hash, hkask:HumanUser-salt, hkask:HumanUser-master_salt,
        hkask:HumanUser-created_at, hkask:HumanUser-last_active .

hkask:HumanUser-user_id rdf:type hkask:Field ; hkask:fieldType hkask:UserID .
hkask:HumanUser-email_enc rdf:type hkask:Field ; hkask:fieldType xsd:base64Binary .
hkask:HumanUser-phone_enc rdf:type hkask:Field ; hkask:fieldType xsd:base64Binary ; hkask:isOptional "true" .
hkask:HumanUser-passphrase_hash rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:HumanUser-salt rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:HumanUser-master_salt rdf:type hkask:Field ; hkask:fieldType xsd:string ; rdfs:comment "For master key derivation (HKDF-SHA256)" .
hkask:HumanUser-created_at rdf:type hkask:Field ; hkask:fieldType xsd:integer .
hkask:HumanUser-last_active rdf:type hkask:Field ; hkask:fieldType xsd:integer ; hkask:isOptional "true" .

hkask:ReplicantIdentity rdf:type hkask:Struct ;
    rdfs:label "ReplicantIdentity" ;
    rdfs:comment "The in-system persona users log in AS" ;
    hkask:definedIn hkask:mod-identity ;
    hkask:hasField hkask:ReplicantIdentity-replicant_name, hkask:ReplicantIdentity-user_id,
        hkask:ReplicantIdentity-replicant_webid, hkask:ReplicantIdentity-first_name_enc,
        hkask:ReplicantIdentity-last_name_enc, hkask:ReplicantIdentity-persona_yaml,
        hkask:ReplicantIdentity-is_primary, hkask:ReplicantIdentity-created_at,
        hkask:ReplicantIdentity-last_login .

hkask:ReplicantIdentity-replicant_name rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:ReplicantIdentity-user_id rdf:type hkask:Field ; hkask:fieldType hkask:UserID .
hkask:ReplicantIdentity-replicant_webid rdf:type hkask:Field ; hkask:fieldType hkask:WebID .
hkask:ReplicantIdentity-first_name_enc rdf:type hkask:Field ; hkask:fieldType xsd:base64Binary .
hkask:ReplicantIdentity-last_name_enc rdf:type hkask:Field ; hkask:fieldType xsd:base64Binary .
hkask:ReplicantIdentity-persona_yaml rdf:type hkask:Field ; hkask:isOptional "true" .
hkask:ReplicantIdentity-is_primary rdf:type hkask:Field ; hkask:fieldType xsd:boolean .
hkask:ReplicantIdentity-created_at rdf:type hkask:Field ; hkask:fieldType xsd:integer .
hkask:ReplicantIdentity-last_login rdf:type hkask:Field ; hkask:isOptional "true" .

hkask:UserSession rdf:type hkask:Struct ;
    rdfs:label "UserSession" ;
    rdfs:comment "Active authenticated session" ;
    hkask:definedIn hkask:mod-identity ;
    hkask:hasField hkask:UserSession-session_id, hkask:UserSession-replicant_name,
        hkask:UserSession-replicant_webid, hkask:UserSession-user_id,
        hkask:UserSession-session_key_salt, hkask:UserSession-expires_at, hkask:UserSession-last_active .

hkask:UserSession-session_id rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:UserSession-replicant_name rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:UserSession-replicant_webid rdf:type hkask:Field ; hkask:fieldType hkask:WebID .
hkask:UserSession-user_id rdf:type hkask:Field ; hkask:fieldType hkask:UserID .
hkask:UserSession-session_key_salt rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:UserSession-expires_at rdf:type hkask:Field ; hkask:fieldType xsd:integer .
hkask:UserSession-last_active rdf:type hkask:Field ; hkask:fieldType xsd:integer .

hkask:RegistrationRequest rdf:type hkask:Struct ;
    rdfs:label "RegistrationRequest" ;
    rdfs:comment "Registration request for new replicant identity" ;
    hkask:definedIn hkask:mod-identity .

# =============================================================================
# EVENT / CNS TYPES
# =============================================================================

hkask:NuEvent rdf:type hkask:Struct ;
    rdfs:label "NuEvent" ;
    rdfs:comment "ν-event — Cybernetic observation event (audit trail)" ;
    hkask:definedIn hkask:mod-event ;
    hkask:hasField hkask:NuEvent-id, hkask:NuEvent-timestamp, hkask:NuEvent-observer_webid,
        hkask:NuEvent-span, hkask:NuEvent-phase, hkask:NuEvent-observation,
        hkask:NuEvent-regulation, hkask:NuEvent-outcome, hkask:NuEvent-recursion_depth,
        hkask:NuEvent-parent_event, hkask:NuEvent-visibility .

hkask:NuEvent-id rdf:type hkask:Field ; hkask:fieldType hkask:EventID .
hkask:NuEvent-timestamp rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .
hkask:NuEvent-observer_webid rdf:type hkask:Field ; hkask:fieldType hkask:WebID .
hkask:NuEvent-span rdf:type hkask:Field ; hkask:fieldType hkask:Span .
hkask:NuEvent-phase rdf:type hkask:Field ; hkask:fieldType hkask:Phase .
hkask:NuEvent-observation rdf:type hkask:Field ; hkask:fieldType hkask:JsonValue .
hkask:NuEvent-regulation rdf:type hkask:Field ; hkask:isOptional "true" .
hkask:NuEvent-outcome rdf:type hkask:Field ; hkask:isOptional "true" .
hkask:NuEvent-recursion_depth rdf:type hkask:Field ; hkask:fieldType xsd:unsignedByte .
hkask:NuEvent-parent_event rdf:type hkask:Field ; hkask:fieldType hkask:EventID ; hkask:isOptional "true" .
hkask:NuEvent-visibility rdf:type hkask:Field ; hkask:fieldType xsd:string .

hkask:Span rdf:type hkask:Enum ;
    rdfs:label "Span" ;
    rdfs:comment "Span namespace for CNS events — cns.* categories" ;
    hkask:definedIn hkask:mod-event ;
    hkask:hasVariant hkask:Span-Prompt, hkask:Span-Tool, hkask:Span-AgentPod,
        hkask:Span-Connector, hkask:Span-Pipeline, hkask:Span-Energy,
        hkask:Span-Review, hkask:Span-Sovereignty, hkask:Span-Goal, hkask:Span-Spec .

hkask:Span-Prompt rdf:type hkask:Variant ; hkask:carriesField "prompt_path"^^xsd:string .
hkask:Span-Tool rdf:type hkask:Variant ; hkask:carriesField "tool_path"^^xsd:string .
hkask:Span-AgentPod rdf:type hkask:Variant .
hkask:Span-Connector rdf:type hkask:Variant .
hkask:Span-Pipeline rdf:type hkask:Variant .
hkask:Span-Energy rdf:type hkask:Variant .
hkask:Span-Review rdf:type hkask:Variant .
hkask:Span-Sovereignty rdf:type hkask:Variant .
hkask:Span-Goal rdf:type hkask:Variant .
hkask:Span-Spec rdf:type hkask:Variant .

hkask:Phase rdf:type hkask:Enum ;
    rdfs:label "Phase" ;
    rdfs:comment "Phase of cybernetic cycle: Observe → Regulate → Outcome" ;
    hkask:definedIn hkask:mod-event ;
    hkask:hasVariant hkask:Phase-Observe, hkask:Phase-Regulate, hkask:Phase-Outcome .

hkask:Phase-Observe rdf:type hkask:Variant .
hkask:Phase-Regulate rdf:type hkask:Variant .
hkask:Phase-Outcome rdf:type hkask:Variant .

hkask:NuEventSink rdf:type hkask:Trait, owl:Class ;
    rdfs:label "NuEventSink" ;
    rdfs:comment "Trait for persisting CNS events; implemented by NuEventStore in hkask-storage" ;
    hkask:definedIn hkask:mod-event ;
    hkask:hasMethod hkask:NuEventSink-persist .

hkask:NuEventSink-persist rdf:type hkask:Method ;
    rdfs:label "persist" ;
    hkask:takesParameter hkask:NuEvent ;
    hkask:returns hkask:Result-unit-NuEventSinkError .

hkask:CnsEvent rdf:type hkask:Struct ;
    rdfs:label "CnsEvent" ;
    rdfs:comment "Cybernetic audit trail event — CNS-level" ;
    hkask:definedIn hkask:mod-cns ;
    hkask:hasField hkask:CnsEvent-id, hkask:CnsEvent-span, hkask:CnsEvent-action,
        hkask:CnsEvent-outcome, hkask:CnsEvent-variety_before, hkask:CnsEvent-variety_after,
        hkask:CnsEvent-alert, hkask:CnsEvent-timestamp .

hkask:CnsEvent-id rdf:type hkask:Field ; hkask:fieldType xsd:unsignedLong .
hkask:CnsEvent-span rdf:type hkask:Field ; hkask:fieldType hkask:CnsSpan .
hkask:CnsEvent-action rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:CnsEvent-outcome rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:CnsEvent-variety_before rdf:type hkask:Field ; hkask:fieldType hkask:VarietyCounter ; hkask:isOptional "true" .
hkask:CnsEvent-variety_after rdf:type hkask:Field ; hkask:fieldType hkask:VarietyCounter ; hkask:isOptional "true" .
hkask:CnsEvent-alert rdf:type hkask:Field ; hkask:fieldType hkask:AlgedonicAlert ; hkask:isOptional "true" .
hkask:CnsEvent-timestamp rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .

hkask:CnsSpan rdf:type hkask:Enum ;
    rdfs:label "CnsSpan" ;
    rdfs:comment "Canonical CNS span namespace" ;
    hkask:definedIn hkask:mod-cns ;
    hkask:hasVariant hkask:CnsSpan-Tool, hkask:CnsSpan-Prompt, hkask:CnsSpan-AgentPod,
        hkask:CnsSpan-Connector, hkask:CnsSpan-Template, hkask:CnsSpan-Curation,
        hkask:CnsSpan-Variety, hkask:CnsSpan-KillZone, hkask:CnsSpan-Sovereignty,
        hkask:CnsSpan-Goal, hkask:CnsSpan-Spec .

hkask:CnsSpan-Tool rdf:type hkask:Variant ; rdfs:comment "cns.tool.* — tool governance/invocation" .
hkask:CnsSpan-Prompt rdf:type hkask:Variant ; rdfs:comment "cns.prompt.* — render/validate/outcome" .
hkask:CnsSpan-AgentPod rdf:type hkask:Variant ; rdfs:comment "cns.agent_pod.* — lifecycle/delegation" .
hkask:CnsSpan-Connector rdf:type hkask:Variant ; rdfs:comment "cns.connector.* — external I/O" .
hkask:CnsSpan-Template rdf:type hkask:Variant ; rdfs:comment "cns.template.* — invocation/registry" .
hkask:CnsSpan-Curation rdf:type hkask:Variant ; rdfs:comment "cns.curation.* — decisions/OCAP boundaries" .
hkask:CnsSpan-Variety rdf:type hkask:Variant ; rdfs:comment "cns.variety.* — monitoring/algedonic alerts" .
hkask:CnsSpan-KillZone rdf:type hkask:Variant ; rdfs:comment "cns.killzone.* — kill zone detection" .
hkask:CnsSpan-Sovereignty rdf:type hkask:Variant ; rdfs:comment "cns.sovereignty.* — user sovereignty" .
hkask:CnsSpan-Goal rdf:type hkask:Variant ; rdfs:comment "cns.goal.* — goal primitive" .
hkask:CnsSpan-Spec rdf:type hkask:Variant ; rdfs:comment "cns.spec.* — specification operations" .

hkask:VarietyCounter rdf:type hkask:Struct ;
    rdfs:label "VarietyCounter" ;
    rdfs:comment "Tracks diversity in system behavior; algedonic alert at deficit >100" ;
    hkask:definedIn hkask:mod-cns .

hkask:AlgedonicAlert rdf:type hkask:Struct ;
    rdfs:label "AlgedonicAlert" ;
    rdfs:comment "Cybernetic alert when variety deficit exceeds threshold — named after Beer's VSM" ;
    hkask:definedIn hkask:mod-cns ;
    hkask:hasField hkask:AlgedonicAlert-id, hkask:AlgedonicAlert-current,
        hkask:AlgedonicAlert-threshold, hkask:AlgedonicAlert-deficit,
        hkask:AlgedonicAlert-escalated, hkask:AlgedonicAlert-timestamp,
        hkask:AlgedonicAlert-span .

