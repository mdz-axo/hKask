hkask:TemplateInvocation-bot_id rdf:type hkask:Field ; hkask:fieldType hkask:BotID .
hkask:TemplateInvocation-temperature rdf:type hkask:Field ; hkask:fieldType xsd:float .
hkask:TemplateInvocation-parameters rdf:type hkask:Field ; hkask:fieldType hkask:LLMParameters .
hkask:TemplateInvocation-input rdf:type hkask:Field ; hkask:fieldType hkask:JsonValue .
hkask:TemplateInvocation-outputs rdf:type hkask:Field ; rdfs:comment "Vec<JsonValue>" .
hkask:TemplateInvocation-selected_index rdf:type hkask:Field ; hkask:isOptional "true" .
hkask:TemplateInvocation-outcome rdf:type hkask:Field ; hkask:fieldType hkask:TemplateOutcome .
hkask:TemplateInvocation-timestamp rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .
hkask:TemplateInvocation-capability_token rdf:type hkask:Field ; hkask:fieldType hkask:CapabilityToken ; hkask:isOptional "true" .

# =============================================================================
# AGENT DEFINITION TYPES
# =============================================================================

hkask:AgentDefinition rdf:type hkask:Struct ;
    rdfs:label "AgentDefinition" ;
    rdfs:comment "Full identity of an agent as defined in registry/bots/*.yaml" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasField hkask:AgentDefinition-name, hkask:AgentDefinition-agent_kind,
        hkask:AgentDefinition-binding_contract, hkask:AgentDefinition-editor,
        hkask:AgentDefinition-charter, hkask:AgentDefinition-capabilities,
        hkask:AgentDefinition-rights, hkask:AgentDefinition-responsibilities,
        hkask:AgentDefinition-reporting, hkask:AgentDefinition-standing_session,
        hkask:AgentDefinition-persona, hkask:AgentDefinition-depends_on,
        hkask:AgentDefinition-readiness_probe, hkask:AgentDefinition-process_manifest .

hkask:AgentDefinition-name rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:AgentDefinition-agent_kind rdf:type hkask:Field ; hkask:fieldType hkask:AgentKind .
hkask:AgentDefinition-binding_contract rdf:type hkask:Field ; hkask:fieldType xsd:boolean .
hkask:AgentDefinition-editor rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:AgentDefinition-charter rdf:type hkask:Field ; hkask:fieldType hkask:Charter ; hkask:isOptional "true" .
hkask:AgentDefinition-capabilities rdf:type hkask:Field ; rdfs:comment "Vec<String>" .
hkask:AgentDefinition-rights rdf:type hkask:Field ; rdfs:comment "Vec<Right>" .
hkask:AgentDefinition-responsibilities rdf:type hkask:Field ; rdfs:comment "Vec<Responsibility>" .
hkask:AgentDefinition-reporting rdf:type hkask:Field ; hkask:fieldType hkask:ReportingConfig ; hkask:isOptional "true" .
hkask:AgentDefinition-standing_session rdf:type hkask:Field ; hkask:fieldType hkask:AgentStandingSessionConfig ; hkask:isOptional "true" .
hkask:AgentDefinition-persona rdf:type hkask:Field ; hkask:fieldType hkask:PersonaConstraints ; hkask:isOptional "true" .
hkask:AgentDefinition-depends_on rdf:type hkask:Field ; rdfs:comment "Vec<String>" .
hkask:AgentDefinition-readiness_probe rdf:type hkask:Field ; hkask:fieldType hkask:ReadinessProbe ; hkask:isOptional "true" .
hkask:AgentDefinition-process_manifest rdf:type hkask:Field ; hkask:isOptional "true" .

hkask:AgentKind rdf:type hkask:Enum ;
    rdfs:label "AgentKind" ;
    rdfs:comment "Bot (machine-to-machine) vs Replicant (human-to-agent)" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasVariant hkask:AgentKind-Bot, hkask:AgentKind-Replicant .

hkask:AgentKind-Bot rdf:type hkask:Variant ; rdfs:comment "Process execution, A2A interaction, public/shared visibility" .
hkask:AgentKind-Replicant rdf:type hkask:Variant ; rdfs:comment "Human assistance, H2A interaction, private episodic memory" .

hkask:Right rdf:type hkask:Enum ;
    rdfs:label "Right" ;
    rdfs:comment "Access right granted to an agent (R9: Structured Data Modeling)" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasVariant hkask:Right-Read, hkask:Right-Write, hkask:Right-Execute,
        hkask:Right-Coordinate, hkask:Right-EscalateTo .

hkask:Right-Read rdf:type hkask:Variant ; hkask:carriesField "resource" .
hkask:Right-Write rdf:type hkask:Variant ; hkask:carriesField "resource" .
hkask:Right-Execute rdf:type hkask:Variant ; hkask:carriesField "action" .
hkask:Right-Coordinate rdf:type hkask:Variant ; hkask:carriesField "scope" .
hkask:Right-EscalateTo rdf:type hkask:Variant ; hkask:carriesField "target" .

hkask:Responsibility rdf:type hkask:Enum ;
    rdfs:label "Responsibility" ;
    rdfs:comment "Responsibility assigned to an agent (R9)" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasVariant hkask:Responsibility-Monitor, hkask:Responsibility-Synthesize,
        hkask:Responsibility-Perform, hkask:Responsibility-Calibrate,
        hkask:Responsibility-Escalate, hkask:Responsibility-Maintain,
        hkask:Responsibility-Emit, hkask:Responsibility-Orchestrate,
        hkask:Responsibility-Record, hkask:Responsibility-Produce .

hkask:Responsibility-Monitor rdf:type hkask:Variant .
hkask:Responsibility-Synthesize rdf:type hkask:Variant .
hkask:Responsibility-Perform rdf:type hkask:Variant .
hkask:Responsibility-Calibrate rdf:type hkask:Variant .
hkask:Responsibility-Escalate rdf:type hkask:Variant .
hkask:Responsibility-Maintain rdf:type hkask:Variant .
hkask:Responsibility-Emit rdf:type hkask:Variant .
hkask:Responsibility-Orchestrate rdf:type hkask:Variant .
hkask:Responsibility-Record rdf:type hkask:Variant .
hkask:Responsibility-Produce rdf:type hkask:Variant .

hkask:Charter rdf:type hkask:Struct ;
    rdfs:label "Charter" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasField hkask:Charter-description, hkask:Charter-archetype, hkask:Charter-visibility .

hkask:Charter-description rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Charter-archetype rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:Charter-visibility rdf:type hkask:Field ; hkask:fieldType xsd:string .

hkask:PersonaConstraints rdf:type hkask:Struct ;
    rdfs:label "PersonaConstraints" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasField hkask:PersonaConstraints-tone, hkask:PersonaConstraints-verbosity,
        hkask:PersonaConstraints-formatting, hkask:PersonaConstraints-forbidden,
        hkask:PersonaConstraints-required .

hkask:PersonaConstraints-tone rdf:type hkask:Field .
hkask:PersonaConstraints-verbosity rdf:type hkask:Field .
hkask:PersonaConstraints-formatting rdf:type hkask:Field .
hkask:PersonaConstraints-forbidden rdf:type hkask:Field ; rdfs:comment "Vec<String>" .
hkask:PersonaConstraints-required rdf:type hkask:Field ; rdfs:comment "Vec<String>" .

hkask:ReadinessProbe rdf:type hkask:Struct ;
    rdfs:label "ReadinessProbe" ;
    hkask:definedIn hkask:mod-agent_def .

hkask:AgentStandingSessionConfig rdf:type hkask:Struct ;
    rdfs:label "AgentStandingSessionConfig" ;
    rdfs:comment "Per-agent standing session configuration" ;
    hkask:definedIn hkask:mod-agent_def .

hkask:ReportingConfig rdf:type hkask:Struct ;
    rdfs:label "ReportingConfig" ;
    rdfs:comment "CNS reporting configuration for agents" ;
    hkask:definedIn hkask:mod-agent_def .

hkask:RegisteredAgent rdf:type hkask:Struct ;
    rdfs:label "RegisteredAgent" ;
    rdfs:comment "Agent with registration metadata — wraps AgentDefinition" ;
    hkask:definedIn hkask:mod-agent_def ;
    hkask:hasField hkask:RegisteredAgent-definition, hkask:RegisteredAgent-token_hash,
        hkask:RegisteredAgent-registered_at, hkask:RegisteredAgent-source_yaml .

hkask:RegisteredAgent-definition rdf:type hkask:Field ; hkask:fieldType hkask:AgentDefinition .
hkask:RegisteredAgent-token_hash rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:RegisteredAgent-registered_at rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:RegisteredAgent-source_yaml rdf:type hkask:Field ; hkask:fieldType xsd:string .

# =============================================================================
# CURATION TYPES
# =============================================================================

hkask:CurationDecision rdf:type hkask:Enum ;
    rdfs:label "CurationDecision" ;
    rdfs:comment "The Curator's evaluation of template outputs" ;
    hkask:definedIn hkask:mod-curation ;
    hkask:hasVariant hkask:CurationDecision-Merge, hkask:CurationDecision-Discard,
        hkask:CurationDecision-Revise, hkask:CurationDecision-Defer .

hkask:CurationDecision-Merge rdf:type hkask:Variant ; rdfs:comment "Merge output into codebase" .
hkask:CurationDecision-Discard rdf:type hkask:Variant ; rdfs:comment "Discard output entirely" .
hkask:CurationDecision-Revise rdf:type hkask:Variant ; rdfs:comment "Request revision from bot" .
hkask:CurationDecision-Defer rdf:type hkask:Variant ; rdfs:comment "Defer decision (needs more information)" .

hkask:AuthorityLevel rdf:type hkask:Enum ;
    rdfs:label "AuthorityLevel" ;
    rdfs:comment "OCAP authority classification" ;
    hkask:definedIn hkask:mod-curation ;
    hkask:hasVariant hkask:AuthorityLevel-Explicit, hkask:AuthorityLevel-Implicit, hkask:AuthorityLevel-Denied .

hkask:AuthorityLevel-Explicit rdf:type hkask:Variant .
hkask:AuthorityLevel-Implicit rdf:type hkask:Variant .
hkask:AuthorityLevel-Denied rdf:type hkask:Variant .

hkask:OCAPBoundary rdf:type hkask:Struct ;
    rdfs:label "OCAPBoundary" ;
    rdfs:comment "Capability boundary for curation decisions — Curator masters normative to create non-normative" ;
    hkask:definedIn hkask:mod-curation ;
    hkask:hasField hkask:OCAPBoundary-capability, hkask:OCAPBoundary-authority, hkask:OCAPBoundary-enforced .

hkask:OCAPBoundary-capability rdf:type hkask:Field ; hkask:fieldType xsd:string .
hkask:OCAPBoundary-authority rdf:type hkask:Field ; hkask:fieldType hkask:AuthorityLevel .
hkask:OCAPBoundary-enforced rdf:type hkask:Field ; hkask:fieldType xsd:boolean .

hkask:CurationRecord rdf:type hkask:Struct ;
    rdfs:label "CurationRecord" ;
    rdfs:comment "Audit trail of Curator decisions" ;
    hkask:definedIn hkask:mod-curation ;
    hkask:hasField hkask:CurationRecord-id, hkask:CurationRecord-curator_id,
        hkask:CurationRecord-invocation, hkask:CurationRecord-decision,
        hkask:CurationRecord-rationale, hkask:CurationRecord-ocap_boundaries,
        hkask:CurationRecord-timestamp .

hkask:CurationRecord-id rdf:type hkask:Field ; hkask:fieldType hkask:TemplateID .
hkask:CurationRecord-curator_id rdf:type hkask:Field ; hkask:fieldType hkask:CuratorId .
hkask:CurationRecord-invocation rdf:type hkask:Field ; hkask:fieldType hkask:TemplateInvocation .
hkask:CurationRecord-decision rdf:type hkask:Field ; hkask:fieldType hkask:CurationDecision .
hkask:CurationRecord-rationale rdf:type hkask:Field ; hkask:isOptional "true" .
hkask:CurationRecord-ocap_boundaries rdf:type hkask:Field ; rdfs:comment "Vec<OCAPBoundary>" .
hkask:CurationRecord-timestamp rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .

hkask:CuratorState rdf:type hkask:Struct ;
    rdfs:label "CuratorState" ;
    rdfs:comment "Current state of The Curator" ;
    hkask:definedIn hkask:mod-curation .

hkask:Ideological rdf:type hkask:Struct ;
    rdfs:label "Ideological" ;
    rdfs:comment "Ideological = ideo (ideas) + logical (having logic). Curator marker." ;
    hkask:definedIn hkask:mod-curation .

# =============================================================================
# SOVEREIGNTY TYPES
# =============================================================================

hkask:DataCategory rdf:type hkask:Enum ;
    rdfs:label "DataCategory" ;
    rdfs:comment "Data category for sovereignty classification" ;
    hkask:definedIn hkask:mod-sovereignty ;
    hkask:hasVariant hkask:DataCategory-EpisodicMemory, hkask:DataCategory-SemanticMemory,
        hkask:DataCategory-PersonalContext, hkask:DataCategory-CapabilityTokens,
        hkask:DataCategory-OcapBoundaries, hkask:DataCategory-TemplateInvocations,
        hkask:DataCategory-HLexiconTerms, hkask:DataCategory-TemplateRegistry,
        hkask:DataCategory-Custom .

hkask:DataCategory-EpisodicMemory rdf:type hkask:Variant ; rdfs:comment "Sovereign: private, personal experiences" .
hkask:DataCategory-SemanticMemory rdf:type hkask:Variant ; rdfs:comment "Shared: knowledge, facts" .
hkask:DataCategory-PersonalContext rdf:type hkask:Variant ; rdfs:comment "Sovereign: user-specific settings" .
hkask:DataCategory-CapabilityTokens rdf:type hkask:Variant ; rdfs:comment "Sovereign: OCAP credentials" .
hkask:DataCategory-OcapBoundaries rdf:type hkask:Variant ; rdfs:comment "Sovereign: access control rules" .
hkask:DataCategory-TemplateInvocations rdf:type hkask:Variant ; rdfs:comment "Shared: prompt/render history" .
hkask:DataCategory-HLexiconTerms rdf:type hkask:Variant ; rdfs:comment "Public: canonical vocabulary" .
hkask:DataCategory-TemplateRegistry rdf:type hkask:Variant ; rdfs:comment "Public: template metadata" .
hkask:DataCategory-Custom rdf:type hkask:Variant .

hkask:AcquisitionResistance rdf:type hkask:Enum ;
    rdfs:label "AcquisitionResistance" ;
    rdfs:comment "Anti-catch-kill resistance levels" ;
    hkask:definedIn hkask:mod-sovereignty ;
    hkask:hasVariant hkask:AcquisitionResistance-None, hkask:AcquisitionResistance-Low,
        hkask:AcquisitionResistance-Medium, hkask:AcquisitionResistance-High,
        hkask:AcquisitionResistance-Maximum .

hkask:AcquisitionResistance-None rdf:type hkask:Variant .
hkask:AcquisitionResistance-Low rdf:type hkask:Variant .
hkask:AcquisitionResistance-Medium rdf:type hkask:Variant .
hkask:AcquisitionResistance-High rdf:type hkask:Variant .
hkask:AcquisitionResistance-Maximum rdf:type hkask:Variant ; rdfs:comment "Default: acquisition impossible without user consent" .

hkask:DataSovereigntyBoundary rdf:type hkask:Struct ;
    rdfs:label "DataSovereigntyBoundary" ;
    rdfs:comment "Defines what data the user controls" ;
    hkask:definedIn hkask:mod-sovereignty ;
    hkask:hasField hkask:DataSovereigntyBoundary-id, hkask:DataSovereigntyBoundary-sovereign_data,
        hkask:DataSovereigntyBoundary-shared_data, hkask:DataSovereigntyBoundary-public_data,
        hkask:DataSovereigntyBoundary-resistance .

hkask:DataSovereigntyBoundary-id rdf:type hkask:Field ; hkask:fieldType hkask:SovereigntyId .
hkask:DataSovereigntyBoundary-sovereign_data rdf:type hkask:Field ; rdfs:comment "HashSet<DataCategory>" .
hkask:DataSovereigntyBoundary-shared_data rdf:type hkask:Field ; rdfs:comment "HashSet<DataCategory>" .
hkask:DataSovereigntyBoundary-public_data rdf:type hkask:Field ; rdfs:comment "HashSet<DataCategory>" .
hkask:DataSovereigntyBoundary-resistance rdf:type hkask:Field ; hkask:fieldType hkask:AcquisitionResistance .

hkask:KillZoneDetector rdf:type hkask:Struct ;
    rdfs:label "KillZoneDetector" ;
    rdfs:comment "Monitors for VC acquisition kill zone patterns" ;
    hkask:definedIn hkask:mod-sovereignty .

hkask:UserSovereigntyState rdf:type hkask:Struct ;
    rdfs:label "UserSovereigntyState" ;
    rdfs:comment "Aggregate view of user's sovereignty" ;
    hkask:definedIn hkask:mod-sovereignty ;
    hkask:hasField hkask:UserSovereigntyState-boundary, hkask:UserSovereigntyState-detector,
        hkask:UserSovereigntyState-explicit_consent, hkask:UserSovereigntyState-last_check .

hkask:UserSovereigntyState-boundary rdf:type hkask:Field ; hkask:fieldType hkask:DataSovereigntyBoundary .
hkask:UserSovereigntyState-detector rdf:type hkask:Field ; hkask:fieldType hkask:KillZoneDetector .
hkask:UserSovereigntyState-explicit_consent rdf:type hkask:Field ; hkask:fieldType xsd:boolean .
hkask:UserSovereigntyState-last_check rdf:type hkask:Field ; hkask:fieldType hkask:DateTime .

