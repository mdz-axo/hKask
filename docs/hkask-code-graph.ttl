hkask:CapabilityToken-max_attenuation rdf:type hkask:Field ; hkask:fieldType xsd:unsignedInt .
hkask:CapabilityToken-context_nonce rdf:type hkask:Field ; hkask:fieldType xsd:string ; hkask:isOptional "true" .
hkask:CapabilityToken-caveats rdf:type hkask:Field ; rdfs:comment "Vec<Caveat>" .

hkask:CapabilityResource rdf:type hkask:Enum ;
