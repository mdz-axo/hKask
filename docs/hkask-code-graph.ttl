# =============================================================================
# EXTERNAL DEPENDENCIES (key framework integrations)
# =============================================================================

hkask:dep-rusqlite rdf:type hkask:ExternalDependency ;
    rdfs:label "rusqlite" ;
    rdfs:comment "SQLite + SQLCipher with bundled OpenSSL" ;
    hkask:usedBy hkask:crate-storage, hkask:crate-agents, hkask:crate-templates, hkask:crate-cli .

hkask:dep-rmcp rdf:type hkask:ExternalDependency ;
    rdfs:label "rmcp" ;
    rdfs:comment "MCP protocol implementation (Rust)" ;
    hkask:usedBy hkask:crate-mcp, hkask:crate-agents .

hkask:dep-axum rdf:type hkask:ExternalDependency ;
    rdfs:label "axum" ;
    rdfs:comment "HTTP web framework" ;
    hkask:usedBy hkask:crate-api .

hkask:dep-utoipa rdf:type hkask:ExternalDependency ;
    rdfs:label "utoipa" ;
    rdfs:comment "OpenAPI documentation generation" ;
    hkask:usedBy hkask:crate-api .

hkask:dep-minijinja rdf:type hkask:ExternalDependency ;
    rdfs:label "minijinja" ;
    rdfs:comment "Jinja2-compatible template engine" ;
    hkask:usedBy hkask:crate-templates .

hkask:dep-sqlite-vec rdf:type hkask:ExternalDependency ;
    rdfs:label "sqlite-vec" ;
    rdfs:comment "Vector similarity search for SQLite" ;
    hkask:usedBy hkask:crate-storage .

