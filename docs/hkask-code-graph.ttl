        hkask:CapabilityResource-Manifest, hkask:CapabilityResource-Registry,
        hkask:CapabilityResource-Cascade, hkask:CapabilityResource-Spec .

hkask:CapabilityResource-Tool rdf:type hkask:Variant .
hkask:CapabilityResource-Template rdf:type hkask:Variant .
hkask:CapabilityResource-Manifest rdf:type hkask:Variant .
hkask:CapabilityResource-Registry rdf:type hkask:Variant .
hkask:CapabilityResource-Cascade rdf:type hkask:Variant .
hkask:CapabilityResource-Spec rdf:type hkask:Variant .

hkask:CapabilityAction rdf:type hkask:Enum ;
    rdfs:label "CapabilityAction" ;
    hkask:definedIn hkask:mod-capability ;
    hkask:hasVariant hkask:CapabilityAction-Read, hkask:CapabilityAction-Write,
        hkask:CapabilityAction-Execute, hkask:CapabilityAction-Render,
        hkask:CapabilityAction-Compose, hkask:CapabilityAction-Attenuate,
        hkask:CapabilityAction-Validate .

hkask:CapabilityAction-Read rdf:type hkask:Variant .
hkask:CapabilityAction-Write rdf:type hkask:Variant .
hkask:CapabilityAction-Execute rdf:type hkask:Variant .
hkask:CapabilityAction-Render rdf:type hkask:Variant .
hkask:CapabilityAction-Compose rdf:type hkask:Variant .
hkask:CapabilityAction-Attenuate rdf:type hkask:Variant .
hkask:CapabilityAction-Validate rdf:type hkask:Variant .

hkask:Caveat rdf:type hkask:Struct ;
    rdfs:label "Caveat" ;
    rdfs:comment "Capability token caveat for attenuation" ;
    hkask:definedIn hkask:mod-capability .

hkask:CaveatContext rdf:type hkask:Struct ;
    rdfs:label "CaveatContext" ;
    rdfs:comment "Context for caveat evaluation" ;
    hkask:definedIn hkask:mod-capability .

hkask:BotCapabilities rdf:type hkask:Struct ;
