@prefix hkask: <http://hkask.io/ontology/code-graph#> .

# =============================================================================
# hKask Code Graph — Comprehensive RDF ledger of the hKask agent platform
# Generated from source analysis of v0.21.0
# =============================================================================

# =============================================================================
# CRATES (12 core + 15 MCP servers)
# =============================================================================

hkask:workspace rdf:type hkask:Workspace ;
    rdfs:label "hKask Workspace" ;
    hkask:version "0.21.0" ;
    hkask:edition "2024" ;
    hkask:binaryName "kask" ;
    hkask:description "ℏKask — Planck's Constant of Agent Systems" .

# --- Core crates ---
hkask:crate-types rdf:type hkask:Crate ;
    rdfs:label "hkask-types" ;
    hkask:crateName "hkask-types" ;
    hkask:description "ID types, ν-event, hLexicon, and visibility types" ;
    hkask:partOf hkask:workspace .

hkask:crate-storage rdf:type hkask:Crate ;
    rdfs:label "hkask-storage" ;
    hkask:crateName "hkask-storage" ;
    hkask:description "SQLite + SQLCipher + sqlite-vec storage" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-keystore ;
    hkask:partOf hkask:workspace .

hkask:crate-memory rdf:type hkask:Crate ;
    rdfs:label "hkask-memory" ;
    hkask:crateName "hkask-memory" ;
    hkask:description "Semantic and episodic memory pipelines" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-storage ;
    hkask:partOf hkask:workspace .

hkask:crate-cns rdf:type hkask:Crate ;
    rdfs:label "hkask-cns" ;
    hkask:crateName "hkask-cns" ;
    hkask:description "Cybernetic Nervous System — observability" ;
    hkask:dependsOn hkask:crate-types ;
    hkask:partOf hkask:workspace .

hkask:crate-templates rdf:type hkask:Crate ;
    rdfs:label "hkask-templates" ;
    hkask:crateName "hkask-templates" ;
    hkask:description "Registry, hLexicon, template cascade" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-storage, hkask:crate-cns, hkask:crate-keystore, hkask:crate-memory ;
    hkask:partOf hkask:workspace .

hkask:crate-agents rdf:type hkask:Crate ;
    rdfs:label "hkask-agents" ;
    hkask:crateName "hkask-agents" ;
    hkask:description "Pods, ACP, bot/replicant" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-cns, hkask:crate-keystore, hkask:crate-storage, hkask:crate-templates ;
    hkask:partOf hkask:workspace .

hkask:crate-ensemble rdf:type hkask:Crate ;
    rdfs:label "hkask-ensemble" ;
    hkask:crateName "hkask-ensemble" ;
    hkask:description "Multi-agent chat coordination" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-agents, hkask:crate-cns, hkask:crate-templates, hkask:crate-keystore ;
    hkask:partOf hkask:workspace .

hkask:crate-keystore rdf:type hkask:Crate ;
    rdfs:label "hkask-keystore" ;
    hkask:crateName "hkask-keystore" ;
    hkask:description "OS keychain, AES-256-GCM, master key derivation (HKDF-SHA256)" ;
    hkask:dependsOn hkask:crate-types ;
    hkask:partOf hkask:workspace .

hkask:crate-mcp rdf:type hkask:Crate ;
    rdfs:label "hkask-mcp" ;
    hkask:crateName "hkask-mcp" ;
    hkask:description "MCP runtime, dispatch" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-templates, hkask:crate-agents, hkask:crate-cns, hkask:crate-keystore ;
    hkask:partOf hkask:workspace .

hkask:crate-cli rdf:type hkask:Crate ;
    rdfs:label "hkask-cli" ;
    hkask:crateName "hkask-cli" ;
    hkask:description "CLI commands" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-agents, hkask:crate-templates, hkask:crate-storage, hkask:crate-mcp, hkask:crate-cns, hkask:crate-api, hkask:crate-ensemble, hkask:crate-keystore ;
    hkask:partOf hkask:workspace ;
    hkask:producesBinary "kask" .

hkask:crate-api rdf:type hkask:Crate ;
    rdfs:label "hkask-api" ;
    hkask:crateName "hkask-api" ;
    hkask:description "HTTP API (utoipa)" ;
    hkask:dependsOn hkask:crate-types, hkask:crate-agents, hkask:crate-templates, hkask:crate-mcp, hkask:crate-cns, hkask:crate-ensemble, hkask:crate-keystore ;
    hkask:partOf hkask:workspace .

