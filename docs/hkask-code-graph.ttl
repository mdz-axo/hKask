# =============================================================================
# ARCHITECTURAL PATTERNS
# =============================================================================

hkask:pattern-hexagonal rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Hexagonal Architecture (Ports & Adapters)" ;
    rdfs:comment "Used extensively in hkask-agents and hkask-templates for port/adapter separation" ;
    hkask:appliedIn hkask:crate-agents, hkask:crate-templates, hkask:crate-ensemble, hkask:crate-mcp .

hkask:pattern-ocap rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Object Capability Security (OCAP)" ;
    rdfs:comment "Core security model: cryptographic capability tokens with attenuation chains" ;
    hkask:appliedIn hkask:crate-types, hkask:crate-agents, hkask:crate-templates, hkask:crate-ensemble .

hkask:pattern-cns rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Cybernetic Nervous System" ;
    rdfs:comment "Observability via cns.* spans, variety counters, algedonic alerts (Ashby's Law)" ;
    hkask:appliedIn hkask:crate-cns, hkask:crate-types, hkask:crate-agents, hkask:crate-templates, hkask:crate-ensemble .

hkask:pattern-template-cascade rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Template Cascade" ;
    rdfs:comment "High-temperature anti-normative generation → Curator evaluation → Merge/Discard/Revise/Defer" ;
    hkask:appliedIn hkask:crate-templates, hkask:crate-agents, hkask:crate-ensemble .

hkask:pattern-ddmvss rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Domain-Driven Minimum Viable Specification Set" ;
    rdfs:comment "9-category specification framework: Domain, Capability, Interface, Composition, Trust, Observability, Persistence, Lifecycle, Curation" ;
    hkask:appliedIn hkask:crate-types .

hkask:pattern-sovereignty rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "User Sovereignty & Acquisition Resistance" ;
    rdfs:comment "Sovereign/Shared/Public data boundaries, kill-zone detection, explicit consent" ;
    hkask:appliedIn hkask:crate-types, hkask:crate-agents, hkask:crate-templates .

hkask:pattern-goal-coordination rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Goal-Based Coordination Substrate" ;
    rdfs:comment "Minimal coordination via shared goals + LLM-judged criteria — max depth 7" ;
    hkask:appliedIn hkask:crate-types, hkask:crate-storage, hkask:crate-cns .

hkask:pattern-three-layer-dry rdf:type hkask:ArchitecturalPattern ;
    rdfs:label "Three-Layer DRY Deduplication" ;
    rdfs:comment "Layer 1: recall dedup (EAV hash), Layer 2: session message dedup, Layer 3: prompt assembly dedup" ;
    hkask:appliedIn hkask:crate-memory, hkask:crate-ensemble, hkask:crate-templates .

