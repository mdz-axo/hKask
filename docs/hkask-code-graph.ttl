hkask:HighTempTemplateType rdf:type hkask:Enum ;
    rdfs:label "HighTempTemplateType" ;
    rdfs:comment "Discriminator for high-temperature anti-normative generation templates" ;
    hkask:definedIn hkask:mod-template ;
    hkask:hasVariant hkask:HighTempTemplateType-CodeGeneration, hkask:HighTempTemplateType-Decision,
        hkask:HighTempTemplateType-Framing, hkask:HighTempTemplateType-Communication,
        hkask:HighTempTemplateType-Reflection .

hkask:HighTempTemplateType-CodeGeneration rdf:type hkask:Variant .
hkask:HighTempTemplateType-Decision rdf:type hkask:Variant .
hkask:HighTempTemplateType-Framing rdf:type hkask:Variant .
hkask:HighTempTemplateType-Communication rdf:type hkask:Variant .
hkask:HighTempTemplateType-Reflection rdf:type hkask:Variant .

hkask:TemperatureRange rdf:type hkask:Struct ;
    rdfs:label "TemperatureRange" ;
    rdfs:comment "Valid temperature bounds for template invocation" ;
