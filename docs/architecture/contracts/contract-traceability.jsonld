{
  "@context": {
    "hkask": "http://hkask.dev/contract-traceability#",
    "hkask-types": "http://hkask.dev/cns-span#",
    "spec": "http://hkask.dev/specification#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "foaf": "http://xmlns.com/foaf/0.1/",

    "Contract": { "@id": "hkask:Contract" },
    "Principle": { "@id": "hkask:Principle" },
    "Test": { "@id": "hkask:Test" },
    "SpecRequirement": { "@id": "hkask:SpecRequirement" },
    "CnsSpanContract": { "@id": "hkask:CnsSpanContract" },
    "Implementation": { "@id": "hkask:Implementation" },
    "ContractProposal": { "@id": "hkask:ContractProposal" },

    "hasGoalPrinciple": { "@id": "hkask:hasGoalPrinciple", "@type": "@id" },
    "hasConstrainingPrinciple": { "@id": "hkask:hasConstrainingPrinciple", "@type": "@id" },
    "hasUserExpectation": { "@id": "hkask:hasUserExpectation" },
    "hasPrecondition": { "@id": "hkask:hasPrecondition" },
    "hasPostcondition": { "@id": "hkask:hasPostcondition" },
    "hasInvariant": { "@id": "hkask:hasInvariant" },
    "anchorsSpecRequirement": { "@id": "hkask:anchorsSpecRequirement", "@type": "@id" },
    "verifiesContract": { "@id": "hkask:verifiesContract", "@type": "@id" },
    "satisfiesContract": { "@id": "hkask:satisfiesContract", "@type": "@id" },
    "monitorsContract": { "@id": "hkask:monitorsContract", "@type": "@id" },
    "proposedBy": { "@id": "hkask:proposedBy", "@type": "@id" },
    "acceptedBy": { "@id": "hkask:acceptedBy", "@type": "@id" },
    "specId": { "@id": "hkask:specId" },
    "principleNumber": { "@id": "hkask:principleNumber" },
    "principleName": { "@id": "hkask:principleName" },
    "role": { "@id": "hkask:role" },
    "cnsSpan": { "@id": "hkask:cnsSpan" },

    "P1": { "@id": "hkask:P1", "@type": "hkask:Principle" },
    "P2": { "@id": "hkask:P2", "@type": "hkask:Principle" },
    "P3": { "@id": "hkask:P3", "@type": "hkask:Principle" },
    "P4": { "@id": "hkask:P4", "@type": "hkask:Principle" },
    "P5": { "@id": "hkask:P5", "@type": "hkask:Principle" },
    "P6": { "@id": "hkask:P6", "@type": "hkask:Principle" },
    "P7": { "@id": "hkask:P7", "@type": "hkask:Principle" },
    "P8": { "@id": "hkask:P8", "@type": "hkask:Principle" },
    "P9": { "@id": "hkask:P9", "@type": "hkask:Principle" },
    "P10": { "@id": "hkask:P10", "@type": "hkask:Principle" },
    "P11": { "@id": "hkask:P11", "@type": "hkask:Principle" },
    "P12": { "@id": "hkask:P12", "@type": "hkask:Principle" }
  },
  "@graph": [
    {
      "@id": "_:contract-model",
      "@type": "rdfs:Class",
      "rdfs:comment": "Every Contract has exactly 1 goal principle, 1 user expectation, 1..11 constraining principles, pre/post/inv conditions, and anchors a spec requirement."
    },
    {
      "@id": "hkask:CnsSpan:ContractViolated",
      "cnsSpan": "cns.contract.violated"
    },
    {
      "@id": "hkask:CnsSpan:ContractCoverage",
      "cnsSpan": "cns.contract.coverage"
    },
    {
      "@id": "hkask:CnsSpan:ContractProposed",
      "cnsSpan": "cns.contract.proposed"
    },
    {
      "@id": "hkask:CnsSpan:ContractAccepted",
      "cnsSpan": "cns.contract.accepted"
    },
    {
      "@id": "hkask:CnsSpan:ContractRejected",
      "cnsSpan": "cns.contract.rejected"
    },
    {
      "@id": "hkask:PrincipleRoleMapping",
      "@type": "rdf:Bag",
      "rdfs:comment": "Magna Carta (P1-P4) outranks Operational (P5-P7) outranks Regulatory (P8-P9) outranks Agent (P10-P12)",
      "rdf:_1": { "@id": "hkask:P1", "principleName": "User Sovereignty", "principleNumber": 1 },
      "rdf:_2": { "@id": "hkask:P2", "principleName": "Affirmative Consent", "principleNumber": 2 },
      "rdf:_3": { "@id": "hkask:P3", "principleName": "Generative Space", "principleNumber": 3 },
      "rdf:_4": { "@id": "hkask:P4", "principleName": "Clear Boundaries", "principleNumber": 4 },
      "rdf:_5": { "@id": "hkask:P5", "principleName": "Essentialism", "principleNumber": 5 },
      "rdf:_6": { "@id": "hkask:P6", "principleName": "Space for Replicants", "principleNumber": 6 },
      "rdf:_7": { "@id": "hkask:P7", "principleName": "Evolutionary Architecture", "principleNumber": 7 },
      "rdf:_8": { "@id": "hkask:P8", "principleName": "Semantic Grounding", "principleNumber": 8 },
      "rdf:_9": { "@id": "hkask:P9", "principleName": "Homeostatic Self-Regulation", "principleNumber": 9 },
      "rdf:_10": { "@id": "hkask:P10", "principleName": "Mimetic Propagation", "principleNumber": 10 },
      "rdf:_11": { "@id": "hkask:P11", "principleName": "Digital Public/Private Sphere", "principleNumber": 11 },
      "rdf:_12": { "@id": "hkask:P12", "principleName": "Replicant Host Mandate", "principleNumber": 12 }
    }
  ]
}
