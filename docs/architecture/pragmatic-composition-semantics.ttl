# hKask Pragmatic Composition — RDF Semantic Graph
# ℏKask v0.21.0 — A Minimal Viable Container for Agents
# Composability is the atomic primitive of agent systems.
# Energy is the universal economic substrate.

@prefix : <https://hkask.org/pragmatic-composition#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix hkask: <https://hkask.org/ontology#> .
@prefix cns: <https://hkask.org/cns#> .
@prefix ocap: <https://hkask.org/ocap#> .

# =============================================================================
# CORE ENTITY TYPES
# =============================================================================

:Skill rdf:type rdfs:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "External capability definition (e.g., Claude Skill) to be translated into hKask registry" ;
    rdfs:subClassOf hkask:ExternalArtifact .

:Template rdf:type rdfs:Class ;
    rdfs:label "Template" ;
    rdfs:comment "Jinja2 template with frontmatter contract in hKask registry" ;
    rdfs:subClassOf hkask:RegistryArtifact .

:Manifest rdf:type rdfs:Class ;
    rdfs:label "Manifest" ;
    rdfs:comment "YAML process definition with step sequence and energy caps" ;
    rdfs:subClassOf hkask:RegistryArtifact .

:Cognition rdf:type rdfs:Class ;
    rdfs:label "Cognition" ;
    rdfs:comment "Reasoning pattern with ReAct loops and cybernetic feedback" ;
    rdfs:subClassOf hkask:MentalProcess .

:Process rdf:type rdfs:Class ;
    rdfs:label "Process" ;
    rdfs:comment "Executable workflow with state transitions" ;
    rdfs:subClassOf hkask:Workflow .

:EnergyCost rdf:type rdfs:Class ;
    rdfs:label "EnergyCost" ;
    rdfs:comment "Token/energy budget tracking for CNS economic analysis" ;
    rdfs:subClassOf hkask:EconomicPrimitive .

# =============================================================================
# SEMANTIC PRIMITIVES FOR PRAGMATIC COMPOSITION
# =============================================================================

# YAML Semantics
:YAMLDeclarativeState rdf:type hkask:SemanticPrimitive ;
    rdfs:label "YAML Declarative State" ;
    rdfs:comment "Configuration and manifests as declarative state specifications" ;
    hkask:technology "serde_yaml" ;
    hkask:useCase "manifests, configuration, registry entries" .

:YAMLProcessManifest rdf:type :Manifest ;
    rdfs:label "YAML Process Manifest" ;
    hkask:defines :StepSequence ;
    hkask:hasProperty :EnergyCap ;
    hkask:hasProperty :Visibility .

# Jinja2 Semantics
:Jinja2Templating rdf:type hkask:SemanticPrimitive ;
    rdfs:label "Jinja2 Templating" ;
    rdfs:comment "Variable substitution and control flow for document composition" ;
    hkask:technology "minijinja" ;
    hkask:useCase "prompt composition, template rendering" .

:Jinja2VariableSubstitution rdf:type hkask:TemplatingOperation ;
    rdfs:label "Variable Substitution" ;
    hkask:input :BindingContext ;
    hkask:output :RenderedDocument .

:Jinja2ControlFlow rdf:type hkask:TemplatingOperation ;
    rdfs:label "Control Flow" ;
    hkask:operations "for, if, else, include" .

# Process Manifests
:StepSequence rdf:type rdfs:Class ;
    rdfs:label "Step Sequence" ;
    rdfs:comment "Ordered sequence of manifest steps with action types" ;
    hkask:stepActions "select, populate, execute" .

:StateTransition rdf:type rdfs:Class ;
    rdfs:label "State Transition" ;
    rdfs:comment "State change between manifest steps" ;
    hkask:from :StepState ;
    hkask:to :StepState .

:ExecutableWorkflow rdf:type :Process ;
    rdfs:label "Executable Workflow" ;
    hkask:composedOf :StepSequence ;
    hkask:tracks :EnergyCost .

# Cognition Manifests
:ReActLoop rdf:type :Cognition ;
    rdfs:label "ReAct Loop" ;
    rdfs:comment "Reason + Act cycling pattern for agent cognition" ;
    hkask:phases "reason, act, observe, reflect" .

:CyberneticFeedback rdf:type :Cognition ;
    rdfs:label "Cybernetic Feedback" ;
    rdfs:comment "CNS monitoring with variety counters and algedonic alerts" ;
    cns:monitors :TemplateOutcome ;
    cns:triggers :AlgedonicAlert .

:ReasoningPattern rdf:type :Cognition ;
    rdfs:label "Reasoning Pattern" ;
    rdfs:comment "Structured cognition template for specific reasoning tasks" ;
    hkask:patternType "KnowAct" .

# Composability Theory
:FunctionComposition rdf:type hkask:MathematicalPrimitive ;
    rdfs:label "Function Composition" ;
    rdfs:comment "Combining templates/manifests as function composition (f ∘ g)" ;
    hkask:notation "compose(template_a, template_b)" .

:MonadicBinding rdf:type hkask:MathematicalPrimitive ;
    rdfs:label "Monadic Binding" ;
    rdfs:comment "Chaining operations with context (Result<T> monad)" ;
    hkask:type "Result<T>" ;
    hkask:operations "bind, return, map" .

:CapabilitySafety rdf:type ocap:SecurityPrimitive ;
    rdfs:label "Capability Safety" ;
    rdfs:comment "OCAP-enforced access control for composition operations" ;
    ocap:mechanism "cryptographic delegation" ;
    ocap:enforcement "runtime capability check" .

# =============================================================================
# RELATIONSHIPS BETWEEN ENTITIES
# =============================================================================

# Skill Translation Pipeline
:SkillImportPort rdf:type hkask:InboundPort ;
    rdfs:label "Skill Import Port" ;
    rdfs:comment "Ingest external skill definitions (Claude Skills, etc.)" ;
    hkask:accepts :Skill ;
    hkask:produces :Template .

:SkillToTemplateTranslation rdf:type hkask:TranslationProcess ;
    rdfs:label "Skill to Template Translation" ;
    hkask:source :Skill ;
    hkask:target :Template ;
    hkask:stages "parse, map, generate, validate, register" .

:SkillToManifestTranslation rdf:type hkask:TranslationProcess ;
    rdfs:label "Skill to Manifest Translation" ;
    rdfs:comment "Translate skill process logic into YAML manifest" ;
    hkask:source :Skill ;
    hkask:target :Manifest .

# Template Compilation
:TemplateCompilePort rdf:type hkask:InboundPort ;
    rdfs:label "Template Compile Port" ;
    rdfs:comment "Jinja2 template validation and caching" ;
    hkask:validates :Template ;
    hkask:caches :CompiledTemplate .

:ManifestValidatePort rdf:type hkask:InboundPort ;
    rdfs:label "Manifest Validate Port" ;
    rdfs:comment "YAML schema validation and energy cap enforcement" ;
    hkask:validates :Manifest ;
    hkask:enforces :EnergyCap .

# Registry Operations
:RegistryWritePort rdf:type hkask:OutboundPort ;
    rdfs:label "Registry Write Port" ;
    rdfs:comment "Persist templates/manifests to hKask registry" ;
    hkask:accepts :Template, :Manifest ;
    hkask:persistsTo hkask:Registry .

:CNSEmitPort rdf:type hkask:OutboundPort ;
    rdfs:label "CNS Emit Port" ;
    rdfs:comment "Emit cns.prompt.*, cns.tool.*, cns.energy.* spans" ;
    cns:spanTypes "cns.prompt.select, cns.prompt.render, cns.prompt.outcome, cns.energy.allocate, cns.energy.consume" .

:EnergyAccountPort rdf:type hkask:OutboundPort ;
    rdfs:label "Energy Account Port" ;
    rdfs:comment "Debit energy cost per operation" ;
    hkask:debits :EnergyCost ;
    hkask:unit "tokens/4" .

# =============================================================================
# ADAPTERS
# =============================================================================

:YAMLAdapter rdf:type hkask:Adapter ;
    rdfs:label "YAML Adapter" ;
    hkask:technology "serde_yaml" ;
    hkask:function "custom schema enforcement" .

:Jinja2Adapter rdf:type hkask:Adapter ;
    rdfs:label "Jinja2 Adapter" ;
    hkask:technology "minijinja" ;
    hkask:function "sandboxed execution" .

:RDFAdapter rdf:type hkask:Adapter ;
    rdfs:label "RDF Adapter" ;
    hkask:technology "rio_turtle" ;
    hkask:function "TTL serialization" .

:SecurityAdapter rdf:type hkask:Adapter ;
    rdfs:label "Security Adapter" ;
    hkask:principle "Mark Miller OCAP" ;
    hkask:function "capability-based access control" .

# =============================================================================
# ENERGY PRIMITIVES
# =============================================================================

:EnergyAllocate rdf:type :EnergyCost ;
    rdfs:label "Energy Allocate" ;
    rdfs:comment "Energy budget assignment" ;
    cns:span "cns.energy.allocate" .

:EnergyConsume rdf:type :EnergyCost ;
    rdfs:label "Energy Consume" ;
    rdfs:comment "Operation cost debit" ;
    cns:span "cns.energy.consume" .

:EnergyOpportunity rdf:type :EnergyCost ;
    rdfs:label "Energy Opportunity" ;
    rdfs:comment "Alternative cost analysis" ;
    cns:span "cns.energy.opportunity" .

:EnergyDeficit rdf:type :EnergyCost ;
    rdfs:label "Energy Deficit" ;
    rdfs:comment "Algedonic alert trigger (variety deficit)" ;
    cns:span "cns.energy.deficit" ;
    cns:threshold "100" .

# =============================================================================
# VISIBILITY AND OCAP
# =============================================================================

:VisibilityPrivate rdf:type ocap:VisibilityLevel ;
    rdfs:label "Private" ;
    ocap:access "owner-only" .

:VisibilityShared rdf:type ocap:VisibilityLevel ;
    rdfs:label "Shared" ;
    ocap:access "capability-gated" .

:VisibilityPublic rdf:type ocap:VisibilityLevel ;
    rdfs:label "Public" ;
    ocap:access "unrestricted" .

:CapabilityToken rdf:type ocap:Capability ;
    rdfs:label "Capability Token" ;
    rdfs:comment "Cryptographic token for stage transitions" ;
    ocap:grants :StageTransition .

# =============================================================================
# CNS SPANS FOR PRAGMATIC COMPOSITION
# =============================================================================

cns:promptSelect rdf:type cns:Span ;
    rdfs:label "cns.prompt.select" ;
    rdfs:comment "Template selection phase" .

cns:promptRender rdf:type cns:Span ;
    rdfs:label "cns.prompt.render" ;
    rdfs:comment "Template rendering phase" .

cns:promptOutcome rdf:type cns:Span ;
    rdfs:label "cns.prompt.outcome" ;
    rdfs:comment "Template execution outcome" .

cns:toolInvoke rdf:type cns:Span ;
    rdfs:label "cns.tool.invoke" ;
    rdfs:comment "Tool invocation" .

cns:energyAllocate rdf:type cns:Span ;
    rdfs:label "cns.energy.allocate" ;
    rdfs:comment "Energy budget assignment" .

cns:energyConsume rdf:type cns:Span ;
    rdfs:label "cns.energy.consume" ;
    rdfs:comment "Energy cost debit" .

cns:energyOpportunity rdf:type cns:Span ;
    rdfs:label "cns.energy.opportunity" ;
    rdfs:comment "Alternative cost analysis" .

cns:energyDeficit rdf:type cns:Span ;
    rdfs:label "cns.energy.deficit" ;
    rdfs:comment "Algedonic alert on variety deficit >100" .

# =============================================================================
# METADATA
# =============================================================================

:PragmaticCompositionSkill rdf:type :Skill ;
    rdfs:label "Pragmatic Composition Skill" ;
    rdfs:comment "Unified capability for YAML/Jinja2 templating, process expertise, and composability theory" ;
    hkask:version "0.21.0" ;
    hkask:designPrinciple "minimal viable unit of agent platform" .

# End of pragmatic composition semantic graph
