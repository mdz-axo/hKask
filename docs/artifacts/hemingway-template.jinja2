{#
=============================================================================
HEMINGWAY STYLE SYNTHESIZER - JINJA2 TEMPLATE
=============================================================================

This template generates prose in authentic Hemingway style using:
- Kansas City Star rules (1915)
- Paratactic clause coordination (73-76% target)
- Iceberg Theory (emotion shown through action, not stated)
- Strategic polysyndeton/asyndeton

Usage:
  from jinja2 import Environment
  env = Environment()
  template = env.from_string(HEMINGWAY_TEMPLATE)
  result = template.render(clauses=["The sun beat down", "He walked", "The dust rose"])

=============================================================================
#}

{% macro hemingway_clause(clause, conjunction='and') %}
{{ clause | trim }}
{% endmacro %}

{% macro hemingway_sentence(clauses, conjunction='and') %}
{%- set rendered = [] -%}
{%- for clause in clauses -%}
  {%- if loop.first -%}
    {{ clause | capitalize | trim }}
  {%- else -%}
    {%- if loop.revindex == 1 -%}
      {{ conjunction }} {{ clause | lower | trim }}
    {%- else -%}
      , {{ conjunction }} {{ clause | lower | trim }}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
.
{% endmacro %}

{% macro hemingway_paragraph(sentences, sentence_count=3) %}
{%- for sentence in sentences -%}
{{ sentence }}
{%- if not loop.last %} {% endif %}
{%- endfor -%}
{% endmacro %}

{% macro iceberg_surface(action) %}
{# The stated 1/8 - action, sensation, concrete detail #}
{{ action }}
{% endmacro %}

{% macro iceberg_depth(emotion) %}
{# The unstated 7/8 - emotion remains beneath surface #}
{# Do not render. Show through action. #}
{% endmacro %}

{% macro hemingway_opening(scenes) %}
{# Short first paragraph per Kansas City Star rules #}
{%- set first_scene = scenes[0] -%}
{{ first_scene | capitalize }}.
{% endmacro %}

{% macro hemingway_body(scenes) %}
{# Subsequent paragraphs: 3-8 sentences #}
{%- for scene in scenes[1:] -%}
{{ scene | capitalize }}.
{%- endfor -%}
{% endmacro %}

{% macro polysyndeton(clauses) %}
{# Repeated conjunctions for accumulation, struggle, endurance #}
{%- for clause in clauses -%}
{{ clause | trim }}
{%- if not loop.last -%}
 and 
{%- endif -%}
{%- endfor -%}
{% endmacro %}

{% macro asyndeton(clauses) %}
{# No conjunctions for staccato urgency, disorientation #}
{%- for clause in clauses -%}
{{ clause | trim }}.
{%- endfor -%}
{% endmacro %}

{% macro paratactic_sequence(events) %}
{# Side-by-side clauses with equal weight #}
{%- for event in events -%}
{{ event | capitalize }}.
{%- endfor -%}
{% endmacro %}

{% macro hemingway_dialogue(speaker, words) %}
"{{ words }}," {{ speaker }} said.
{% endmacro %}

{% macro hemingway_dialogue_plain(speaker, words) %}
"{{ words }}."
{% endmacro %}

{% macro hemingway_action(actor, action, context) %}
{{ actor }} {{ action }}. {{ context }}.
{% endmacro %}

{% macro hemingway_sensation(subject, sensation) %}
{{ subject }} {{ sensation }}.
{% endmacro %}

{% macro hemingway_loss(subject, lost_thing) %}
{# Loss shown through absence, not lamentation #}
{{ subject }}. The {{ lost_thing }} was gone.
{% endmacro %}

{% macro hemingway_work(subject, task) %}
{# Work as meaning #}
{{ subject }} {{ task }}. The work was all there was.
{% endmacro %}

{% macro hemingway_light(place, quality) %}
{# Clean, well-lighted place against darkness #}
The {{ place }} was {{ quality }}. The light was enough.
{% endmacro %}

{% macro hemingway_silence() %}
{# Silence as fullness, not emptiness #}
There was silence. The silence was not empty. The silence was full.
{% endmacro %}

{% macro hemingway_end() %}
The files end. We do not read past the end. We do not ask.
{% endmacro %}

{#
=============================================================================
USAGE EXAMPLE
=============================================================================

{{ hemingway_sentence(["The sun beat down", "he walked", "the dust rose"]) }}
Output: "The sun beat down and he walked and the dust rose."

{{ polysyndeton(["He was cold", "he was tired", "he was hungry", "he walked on"]) }}
Output: "He was cold and he was tired and he was hungry and he walked on."

{{ asyndeton(["The sun beat down", "The dust rose", "The men walked"]) }}
Output: "The sun beat down. The dust rose. The men walked."

{{ hemingway_light("cafe", "clean and well-lighted") }}
Output: "The cafe was clean and well-lighted. The light was enough."

=============================================================================
#}