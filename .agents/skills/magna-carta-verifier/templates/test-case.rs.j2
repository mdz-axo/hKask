{#- Render Rust test cases as code blocks for the verification report. -#}
{#- Only behavioral_probe and absence_check assertions generate test cases. -#}

{% set ns = namespace(tests = []) %}
{% for principle in principles %}
{% for assertion in principle.assertions %}
{% if assertion.method == 'behavioral_probe' or assertion.method == 'absence_check' %}
{% set test_fn -%}
/// REQ: {{ assertion.id }} — {{ assertion.claim_summary }}
///
/// Principle: {{ principle.display_name }} ({{ principle.principle }})
/// Method: {{ assertion.method }}
/// Manifest: {{ principle.principle }} v{{ principle.version }}
#[test]
fn {{ assertion.id }}_{{ assertion.name }}() {
{% if assertion.method == 'behavioral_probe' %}
    // Arrange: set up the system under test with the condition specified
    // in the assertion targets.
    //
    // Target condition: {{ assertion.condition | default('non-owner WebID, no explicit consent') }}
    //
    // For each target method:
{% for target in assertion.targets -%}
    //   - {{ target.crate }}::{{ target.module }}::{{ target.methods | default(['<unspecified>']) | join(', ') }}
{% endfor -%}

    // Act: attempt access under the specified condition.

    // Assert: access is denied (fail-closed).
    // let result = ... ;
    // assert!(result.is_err() || result == false, "REQ {{ assertion.id }}: access must be denied");
{% elif assertion.method == 'absence_check' %}
    // Search for prohibited constructs across target crates.
    //
    // Prohibited patterns:
{% for prohibited in assertion.prohibited -%}
    //   - {{ prohibited }}
{% endfor -%}
    //
    // Target crates:
{% for target in assertion.targets -%}
    //   - {{ target.crate }}
{% endfor -%}

    // Act: grep for each prohibited pattern.
    // For each match found, this is a violation.

    // Assert: no prohibited patterns exist.
    // assert!(violations.is_empty(), "REQ {{ assertion.id }}: no prohibited constructs");
{% endif %}
}
{% endset %}
{% set ns.tests = ns.tests + [test_fn] %}
{% endif %}
{% endfor %}
{% endfor %}
