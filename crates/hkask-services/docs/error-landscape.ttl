@prefix : <http://hkask.dev/error-landscape#> .
@prefix crate: <http://hkask.dev/crate#> .

# ── Foundation Layer (hkask-types) ──────────────────────────────────────

:InfrastructureError :livesIn crate:hkask-types .
:InfrastructureError :hasVariants :Database, :Serialization, :LockPoisoned, :NotFound, :Io .
:InfrastructureError :isUsedBy crate:hkask-storage, crate:hkask-agents, crate:hkask-cns,
    crate:hkask-memory, crate:hkask-templates, crate:hkask-services, crate:hkask-cli,
    crate:hkask-api, crate:hkask-keystore, crate:hkask-improv .
:InfrastructureError :isPassThrough true .

:HkaskError :livesIn crate:hkask-types .
:HkaskError :wraps :InfrastructureError .
:HkaskError :hasVariants :CapabilityDenied, :InvalidToken, :PermissionDenied .
:HkaskError :isPassThrough true .

:McpErrorKind :livesIn crate:hkask-types .
:McpErrorKind :hasVariants :Internal, :Unavailable, :Timeout, :NotFound, :InvalidArgument,
    :PermissionDenied, :RateLimited, :FailedPrecondition .
:McpErrorKind :isUsedBy crate:hkask-mcp .

:GitError :livesIn crate:hkask-types .
:GitError :hasVariants :CrateNotFound, :Io, :Git .
:GitError :isUsedBy crate:hkask-api .

:InferenceError :livesIn crate:hkask-types:ports .
:InferenceError :hasVariants :Connection, :Model, :Generation, :Json, :CircuitOpen .
:InferenceError :isUsedBy crate:hkask-services, crate:hkask-inference .

:EmbeddingGenerationError :livesIn crate:hkask-types:ports .
:EmbeddingGenerationError :hasVariants :Connection, :Api, :Json, :EmptyResponse, :DimensionMismatch .
:EmbeddingGenerationError :isUsedBy crate:hkask-services .

:RegistryError-ports :livesIn crate:hkask-types:ports .
:RegistryError-ports :hasVariants :NotFound, :Other .
:RegistryError-ports :isUsedBy crate:hkask-services, crate:hkask-cli, crate:hkask-api .

:ToolPortError :livesIn crate:hkask-types:ports .
:ToolPortError :hasVariants :CapabilityDenied, :EnergyBudgetExceeded, :NotFound, :InvocationFailed .
:ToolPortError :isUsedBy crate:hkask-cns .

# ── Domain Layer ─────────────────────────────────────────────────────────

:DatabaseError :livesIn crate:hkask-storage .
:DatabaseError :hasVariants :Sqlite, :SqlCipher, :KeyDerivation .
:DatabaseError :isUsedBy crate:hkask-services .

:AgentRegistryError :livesIn crate:hkask-storage .
:AgentRegistryError :hasVariants :NotFound, :AlreadyRegistered, :Infra .
:AgentRegistryError :wraps :InfrastructureError .
:AgentRegistryError :isUsedBy crate:hkask-services, crate:hkask-cli, crate:hkask-api .

:ConsentStoreError :livesIn crate:hkask-storage .
:ConsentStoreError :hasVariants :NotFound, :Infra .
:ConsentStoreError :wraps :InfrastructureError .
:ConsentStoreError :isUsedBy crate:hkask-services, crate:hkask-api .

:EscalationError :livesIn crate:hkask-storage .
:EscalationError :hasVariants :NotFound, :Infra .
:EscalationError :wraps :InfrastructureError .
:EscalationError :isUsedBy crate:hkask-services, crate:hkask-cli, crate:hkask-api .

:GoalRepositoryError :livesIn crate:hkask-storage .
:GoalRepositoryError :hasVariants :NotFound, :VisibilityDenied, :Infra, :InvalidTransition,
    :MaxDepthExceeded, :Corrupt, :QuarantineFailed .
:GoalRepositoryError :wraps :InfrastructureError .
:GoalRepositoryError :isUsedBy crate:hkask-services, crate:hkask-api .

:NuEventError :livesIn crate:hkask-storage .
:NuEventError :isUsedBy crate:hkask-services, crate:hkask-api .

:SovereigntyStoreError :livesIn crate:hkask-storage .
:SovereigntyStoreError :hasVariants :UuidParse, :Infra .
:SovereigntyStoreError :wraps :InfrastructureError .
:SovereigntyStoreError :isUsedBy crate:hkask-services, crate:hkask-api .

:SpecError :livesIn crate:hkask-storage .
:SpecError :isUsedBy crate:hkask-services .

:TripleError :livesIn crate:hkask-storage .
:TripleError :hasVariants :NotFound, :Infra .
:TripleError :wraps :InfrastructureError .
:TripleError :isUsedBy crate:hkask-services, crate:hkask-api .

:UserStoreError :livesIn crate:hkask-storage .
:UserStoreError :hasVariants :NotFound, :ReplicantNameTaken, :InvalidCredentials, :Encryption,
    :Decryption, :KeyDerivation, :PasswordHash, :PassphraseExpired, :Infra .
:UserStoreError :wraps :InfrastructureError .
:UserStoreError :isUsedBy crate:hkask-services, crate:hkask-cli, crate:hkask-api .

:KataHistoryError :livesIn crate:hkask-storage .
:GalleryStoreError :livesIn crate:hkask-storage .
:EmbeddingError :livesIn crate:hkask-storage .

:AcpError :livesIn crate:hkask-agents .
:AcpError :hasVariants :AgentAlreadyRegistered, :AgentNotFound, :CapabilityDenied,
    :WildcardCapabilityNotAllowed, :MalformedCapability .
:AcpError :isUsedBy crate:hkask-services, crate:hkask-cli, crate:hkask-api .

:ConsentError :livesIn crate:hkask-agents .
:ConsentError :hasVariants :ConsentNotFound .
:ConsentError :isUsedBy crate:hkask-services, crate:hkask-api .

:MetacognitionError :livesIn crate:hkask-agents .
:MetacognitionError :isUsedBy crate:hkask-services, crate:hkask-cli .

:RegistryLoaderError :livesIn crate:hkask-agents .
:RegistryLoaderError :isUsedBy crate:hkask-services, crate:hkask-cli .

:AgentPodError :livesIn crate:hkask-agents .
:AgentPodError :hasVariants :PodNotFound, :PersonaParseError, :InvalidStateTransition .
:AgentPodError :isUsedBy crate:hkask-services, crate:hkask-api .

:McpError :livesIn crate:hkask-agents .
:CoreError :livesIn crate:hkask-agents .
:MemoryError :livesIn crate:hkask-agents .
:RegistryError-agents :livesIn crate:hkask-agents .
:RegistryError-agents :duplicates :RegistryError-cli, :RegistryError-ports .

:EnergyError :livesIn crate:hkask-cns .
:EnergyError :isUsedBy crate:hkask-services .

:EpisodicMemoryError :livesIn crate:hkask-memory .
:EpisodicMemoryError :isUsedBy crate:hkask-services .

:SemanticMemoryError :livesIn crate:hkask-memory .
:SemanticMemoryError :isUsedBy crate:hkask-services .

:TemplateError :livesIn crate:hkask-templates .
:TemplateError :hasVariants :NotFound, :CapabilityDenied, :PathTraversal, :SandboxViolation,
    :Validation .
:TemplateError :isUsedBy crate:hkask-services, crate:hkask-api .

:ImprovError :livesIn crate:hkask-improv .

# ── Service Layer ────────────────────────────────────────────────────────

:ServiceError :livesIn crate:hkask-services .
:ServiceError :wraps :EscalationError, :MetacognitionError, :AcpError, :RegistryLoaderError,
    :AgentRegistryError, :ConsentError, :DatabaseError, :RegistryError-ports, :TemplateError,
    :GoalRepositoryError, :TripleError, :UserStoreError, :ConsentStoreError,
    :SovereigntyStoreError, :SpecError, :NuEventError, :EpisodicMemoryError,
    :SemanticMemoryError, :EnergyError, :AgentPodError, :InferenceError,
    :EmbeddingGenerationError, :InfrastructureError .
:ServiceError :hasVariants :EscalationNotFound, :Escalation, :Metacognition, :AgentNotFound,
    :InvalidAgentType, :AgentRegistrationFailed, :Acp, :AgentRegistry, :AgentRegistryStore,
    :Consent, :Storage, :Registry, :Template, :GoalRepo, :Triple, :UserStore, :ConsentStore,
    :SovereigntyStore, :Spec, :NuEvent, :EpisodicMemory, :SemanticMemory, :Consolidation,
    :Cns, :Keystore, :Gas, :PodNotFound, :Pod, :InferencePort, :Embedding, :UserNotFound,
    :LoginFailed, :InvalidPassphrase, :ValidationError, :InvalidWebID, :Infra,
    :RegistryInitFailed, :RegistryLoadFailed, :Archival, :Embed, :Compose, :Skill,
    :Verification, :Wallet, :RateLimited, :Config, :Matrix .
:ServiceError :surfacesTo :Terminal, :HTTP .
:ServiceError :isUsedBy crate:hkask-cli, crate:hkask-api .

# ── Surface Layer ────────────────────────────────────────────────────────

:AgentError :livesIn crate:hkask-cli .
:AgentError :hasVariants :NotFound, :InvalidType, :RegistrationFailed, :Registry, :RegistryLoader .
:AgentError :wraps :AcpError, :AgentRegistryError, :RegistryError-ports, :RegistryLoaderError .
:AgentError :surfacesTo :Terminal .
:AgentError :duplicates :ServiceError:AgentNotFound, :ServiceError:InvalidAgentType,
    :ServiceError:AgentRegistrationFailed .

:CuratorError :livesIn crate:hkask-cli .
:CuratorError :hasVariants :EscalationNotFound, :Registry, :Escalation, :Metacognition, :Service .
:CuratorError :wraps :RegistryError-cli, :EscalationError, :MetacognitionError, :ServiceError .
:CuratorError :surfacesTo :Terminal .
:CuratorError :duplicates :ServiceError:EscalationNotFound, :ServiceError:Escalation,
    :ServiceError:Metacognition .

:RegistryError-cli :livesIn crate:hkask-cli .
:RegistryError-cli :hasVariants :InitFailed, :LoadFailed, :DatabaseError, :SchemaError, :Infra .
:RegistryError-cli :wraps :InfrastructureError .
:RegistryError-cli :surfacesTo :Terminal .
:RegistryError-cli :duplicates :ServiceError:RegistryInitFailed, :ServiceError:RegistryLoadFailed,
    :ServiceError:Storage .

:UserError :livesIn crate:hkask-cli .
:UserError :hasVariants :NotFound, :SessionNotFound, :LoginFailed, :InvalidPassphrase,
    :ValidationError, :Store, :Infra .
:UserError :wraps :UserStoreError, :InfrastructureError .
:UserError :surfacesTo :Terminal .
:UserError :duplicates :ServiceError:UserNotFound, :ServiceError:LoginFailed,
    :ServiceError:InvalidPassphrase, :ServiceError:ValidationError .

:ApiError :livesIn crate:hkask-api .
:ApiError :hasVariants :NotFound, :Unauthorized, :Forbidden, :BadRequest, :Conflict,
    :ServiceUnavailable, :Internal .
:ApiError :mapsToHttpStatus :StatusCode .
:ApiError :surfacesTo :HTTP .
:ApiError :wraps :TripleError, :GoalRepositoryError, :AgentRegistryError, :NuEventError,
    :ConsentStoreError, :SovereigntyStoreError, :UserStoreError, :InfrastructureError,
    :ConsentError, :EscalationError, :GitError, :AcpError, :TemplateError, :RegistryError-ports,
    :ServiceError .

# ── MCP Layer (out-of-process) ───────────────────────────────────────────

:ServerStartError :livesIn crate:hkask-mcp .
:ServerStartError :surfacesTo :MCP-JSON-RPC .

:McpToolError :livesIn crate:hkask-mcp .
:McpToolError :surfacesTo :MCP-JSON-RPC .
:McpToolError :mapsToMcpKind :McpErrorKind .

# ── Keystore Layer ───────────────────────────────────────────────────────

:KeychainError :livesIn crate:hkask-keystore .
:KeystoreError :livesIn crate:hkask-keystore .
:EncryptionError :livesIn crate:hkask-keystore .
:SpecSignatureError :livesIn crate:hkask-keystore .

# ── Duplication relationships ────────────────────────────────────────────

:AgentError :duplicates :ServiceError .
:CuratorError :duplicates :ServiceError .
:RegistryError-cli :duplicates :ServiceError, :RegistryError-ports .
:UserError :duplicates :ServiceError .
:RegistryError-agents :duplicates :RegistryError-cli, :RegistryError-ports .
